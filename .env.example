# =============================================================================
# Springbok Expeditions - Environment Variables
# Copy this file to .env and fill in the values when ready.
# Leave blank for now - the site will work without these (forms show a notice).
# =============================================================================

# -----------------------------------------------------------------------------
# Database (MySQL - cPanel native)
# Local dev: created earlier via phpMyAdmin or mysql CLI
# Production: create DB + user in cPanel → MySQL Databases
# -----------------------------------------------------------------------------
DATABASE_URL=mysql://springbok_user:YOUR_PASSWORD@localhost:3306/springbok_astro

# -----------------------------------------------------------------------------
# Session / auth secret (admin CMS)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------------
SESSION_SECRET=replace_with_32_char_random_string

# -----------------------------------------------------------------------------
# Resend (transactional email - booking & contact forms)
# Sign up at https://resend.com - free tier: 3,000 emails/month
# Verify your domain (springbokexpeditions.com) via DNS before going live
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_replace_with_your_resend_api_key
RESEND_FROM_EMAIL=noreply@springbokexpeditions.com
RESEND_TO_EMAIL=info@springbokexpeditions.com

# -----------------------------------------------------------------------------
# Cloudflare Turnstile (anti-spam for forms)
# Sign up at https://www.cloudflare.com/products/turnstile/ - free
# -----------------------------------------------------------------------------
PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA_replace_with_your_site_key
TURNSTILE_SECRET_KEY=0x4AAAAAAA_replace_with_your_secret_key

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
PUBLIC_SITE_URL=http://localhost:4321
PUBLIC_SITE_NAME=Springbok Expeditions
PUBLIC_PHONE=+255784136616
PUBLIC_WHATSAPP=+255784136616
PUBLIC_EMAIL=info@springbokexpeditions.com

# -----------------------------------------------------------------------------
# Analytics (optional - leave blank to disable)
# -----------------------------------------------------------------------------
PUBLIC_PLAUSIBLE_DOMAIN=

# -----------------------------------------------------------------------------
# Cloudinary (media CDN - hero video, future images/videos)
# Sign up at https://cloudinary.com - free tier: 25 credits/month
# Only PUBLIC_CLOUDINARY_CLOUD_NAME is needed (no API key/secret - uploads via dashboard)
# Get your cloud name from the Console Dashboard after signing up.
# -----------------------------------------------------------------------------
PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
