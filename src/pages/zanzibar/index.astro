---
import PublicLayout from '@/layouts/PublicLayout.astro';
import { zanzibarAreas, zanzibarRegions } from '@/data/zanzibar-areas';
import { getCollection } from 'astro:content';
import { ArrowRight, MapPin, Calendar, Sparkles, Waves, Camera, Heart, Tent, UtensilsCrossed, Trees, Ship } from '@lucide/astro';
import { withPublisher } from '@/lib/jsonld';

const areas = [...zanzibarAreas].sort((a, b) => a.order - b.order);
const regions = zanzibarRegions();

const allTours = await getCollection('tours');
const zanzibarTours = allTours.filter((t) => t.data.type === 'zanzibar').slice(0, 3);

const regionIcons: Record<string, typeof Waves> = {
  'Stone Town': Camera,
  'North Coast': Waves,
  'Northeast Coast': Waves,
  'East Coast': Waves,
  'South Coast': Waves,
  'West Coast': Waves,
  'Inland': Trees,
};

const monthOrder = [
  'January', 'February', 'March', 'April', 'May', 'June',
  'July', 'August', 'September', 'October', 'November', 'December',
];
const monthShort = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const monthMap: Record<string, string> = Object.fromEntries(monthOrder.map((m, i) => [m, monthShort[i]]));

const monthRatingMap: Record<string, 'high' | 'med' | 'low'> = {
  June: 'high', July: 'high', August: 'high', September: 'high', October: 'high',
  December: 'high', January: 'high', February: 'high',
  March: 'med', November: 'med',
  April: 'low', May: 'low',
};
const monthColorMap: Record<'high' | 'med' | 'low', string> = {
  high: 'bg-safari-600 text-white border-safari-700',
  med: 'bg-savannah-200 text-savannah-900 border-savannah-300',
  low: 'bg-dusk-100 text-dusk-500 border-dusk-200',
};

function getAreaRating(area: typeof areas[number], month: string): 'high' | 'med' | 'low' {
  const found = area.bestTime.find((bt) => bt.month === month);
  return found?.rating ?? 'low';
}

const bestArea = areas[0];
---

<PublicLayout
  title="Zanzibar — Beaches, Stone Town & Island Weeks"
  description="Plan your Zanzibar trip: choose from 8 hand-picked areas — Stone Town, Nungwi, Kendwa, Matemwe, Paje, Jambiani, Jozani Forest, Prison Island. Best seasons, top beaches, things to do, and ready-made packages."
  ogImage="/og/zanzibar.png"
  transparentHeader={true}
>
  <!-- Hero -->
  <section class="relative h-[85vh] min-h-[600px] w-full overflow-hidden bg-safari-900 text-white">
    <img
      src="https://images.unsplash.com/photo-1505881502353-a1986add3762?w=1920&q=80&auto=format&fit=crop"
      alt="Zanzibar beach at sunset"
      class="absolute inset-0 w-full h-full object-cover scale-105"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-tr from-black/85 via-black/45 to-black/20"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-black/40"></div>

    <div class="container-content relative z-10 h-full flex flex-col justify-end pb-16 md:pb-20 pt-32">
      <div class="max-w-3xl">
        <p class="eyebrow text-savannah-300 text-[11px] md:text-xs uppercase tracking-[0.18em] mb-3">The Spice Island · 25 km off the Tanzanian coast</p>

        <h1 class="font-display text-[2.6rem] sm:text-6xl md:text-7xl lg:text-display-lg font-medium tracking-tight text-white mb-5 md:mb-6">
          Zanzibar.<br />
          <span class="italic font-normal text-savannah-300">Beach on your time.</span>
        </h1>

        <p class="text-lg md:text-xl text-dusk-100/90 max-w-2xl leading-relaxed font-light mb-8">
          Eight hand-picked places to stay, eat, and slow down — from the stone alleys of Stone Town to the quiet beaches of the northeast. Pick a coast, build your week, and let us handle the rest.
        </p>

        <div class="flex flex-wrap gap-4">
          <a href="#areas" class="btn btn-primary px-7 py-3.5">
            Browse the 8 areas
            <ArrowRight size={16} />
          </a>
          <a href="/contact?subject=zanzibar" class="btn btn-outline-light px-7 py-3.5 border-white/30 hover:bg-white hover:text-safari-900">
            Plan a Zanzibar trip
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust strip -->
  <section class="bg-safari-900 text-white border-t border-white/10">
    <div class="container-content py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <p class="font-display text-3xl md:text-4xl text-savannah-300">8</p>
          <p class="text-xs uppercase tracking-[0.18em] text-dusk-300 mt-1">Areas to stay</p>
        </div>
        <div>
          <p class="font-display text-3xl md:text-4xl text-savannah-300">2 hr</p>
          <p class="text-xs uppercase tracking-[0.18em] text-dusk-300 mt-1">Flight from Arusha</p>
        </div>
        <div>
          <p class="font-display text-3xl md:text-4xl text-savannah-300">UNESCO</p>
          <p class="text-xs uppercase tracking-[0.18em] text-dusk-300 mt-1">Stone Town</p>
        </div>
        <div>
          <p class="font-display text-3xl md:text-4xl text-savannah-300">26–32°</p>
          <p class="text-xs uppercase tracking-[0.18em] text-dusk-300 mt-1">Year-round</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Zanzibar -->
  <section class="section bg-dusk-50">
    <div class="container-content">
      <div class="grid lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-5">
          <p class="eyebrow text-safari-600 mb-4">Why Zanzibar</p>
          <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-5">
            The perfect add-on to a safari or Kilimanjaro climb
          </h2>
          <p class="text-dusk-700 leading-relaxed text-lg">
            A 2-hour flight from Arusha, Zanzibar is the natural close to any Tanzania trip. Spend your last week on a quiet beach, in a 17th-century Stone Town alley, or in a hammock between dives on Mnemba Atoll. We build the connection, the transfers, and the itinerary — you just show up.
          </p>
        </div>

        <div class="lg:col-span-7 grid sm:grid-cols-2 gap-5">
          <div class="bg-white rounded-2xl p-6 border border-dusk-100 shadow-soft">
            <span class="w-10 h-10 rounded-xl bg-safari-100 text-safari-700 flex items-center justify-center mb-4">
              <Waves size={20} />
            </span>
            <h3 class="font-display text-xl text-safari-900 mb-2">Beach for every mood</h3>
            <p class="text-sm text-dusk-600 leading-relaxed">Lively sunsets in Nungwi, quiet luxury in Kendwa, kitesurfing in Paje, fishing-village life in Jambiani. Pick the beach that fits you.</p>
          </div>
          <div class="bg-white rounded-2xl p-6 border border-dusk-100 shadow-soft">
            <span class="w-10 h-10 rounded-xl bg-savannah-100 text-savannah-700 flex items-center justify-center mb-4">
              <Camera size={20} />
            </span>
            <h3 class="font-display text-xl text-safari-900 mb-2">UNESCO Stone Town</h3>
            <p class="text-sm text-dusk-600 leading-relaxed">A UNESCO World Heritage old town of carved wooden doors, narrow alleys, and rooftop restaurants. Spend 1–2 nights here first or last.</p>
          </div>
          <div class="bg-white rounded-2xl p-6 border border-dusk-100 shadow-soft">
            <span class="w-10 h-10 rounded-xl bg-sunset-100 text-sunset-700 flex items-center justify-center mb-4">
              <Ship size={20} />
            </span>
            <h3 class="font-display text-xl text-safari-900 mb-2">Indian Ocean</h3>
            <p class="text-sm text-dusk-600 leading-relaxed">Mnemba Atoll diving, dhow cruises at sunset, deep-sea fishing, and reef-walking at low tide. Some of the best water in East Africa.</p>
          </div>
          <div class="bg-white rounded-2xl p-6 border border-dusk-100 shadow-soft">
            <span class="w-10 h-10 rounded-xl bg-safari-100 text-safari-700 flex items-center justify-center mb-4">
              <UtensilsCrossed size={20} />
            </span>
            <h3 class="font-display text-xl text-safari-900 mb-2">Spice &amp; food</h3>
            <p class="text-sm text-dusk-600 leading-relaxed">Spice tours, Forodhani night market, Zanzibar pizza, fresh seafood. The food is part of the experience — we plan the must-eats for you.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Areas grid -->
  <section id="areas" class="section bg-white">
    <div class="container-content">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="eyebrow text-safari-600 mb-3">8 areas</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-4">
          Find your Zanzibar
        </h2>
        <p class="text-dusk-600">
          The island is small enough to drive end to end in 2 hours, but each coast has its own personality. Use this as your map.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {areas.map((area) => {
          const Icon = regionIcons[area.region] ?? Waves;
          return (
            <a
              href={`/zanzibar/${area.slug}`}
              class="group relative overflow-hidden rounded-2xl bg-white border border-dusk-100 hover:border-safari-300 hover:shadow-lifted transition-all"
            >
              <div class="aspect-[4/3] overflow-hidden bg-dusk-200">
                <img
                  src={area.hero}
                  alt={area.name}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                  decoding="async"
                />
                <div class="absolute top-3 left-3 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-white/90 backdrop-blur text-xs font-medium text-safari-900">
                  <Icon size={12} />
                  {area.region}
                </div>
              </div>
              <div class="p-5">
                <h3 class="font-display text-xl text-safari-900 mb-2 group-hover:text-safari-700 transition-colors">{area.name}</h3>
                <p class="text-sm text-dusk-600 leading-relaxed mb-4 line-clamp-2">{area.tagline}</p>
                <div class="flex flex-wrap gap-1.5">
                  {area.bestFor.slice(0, 3).map((b) => (
                    <span class="px-2 py-0.5 rounded text-[10px] uppercase tracking-wider bg-safari-100 text-safari-800">
                      {b}
                    </span>
                  ))}
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Best time calendar -->
  <section class="section bg-dusk-50">
    <div class="container-content">
      <div class="grid lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-5">
          <p class="eyebrow text-safari-600 mb-4">When to visit</p>
          <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-5">
            Two main seasons, both excellent
          </h2>
          <p class="text-dusk-700 leading-relaxed text-lg mb-4">
            Zanzibar is a year-round destination, but the dry seasons (June–October and December–February) are the most popular. The long rains (March–May) bring afternoon showers and humid air, but the island is quieter and cheaper. The short rains (November) are usually just a few passing storms.
          </p>
          <p class="text-dusk-700 leading-relaxed">
            The ocean stays warm (26–32°C) year-round. Tides vary by area — Stone Town, the north, and the southeast have smaller tides; the east coast has the largest tidal range.
          </p>
        </div>

        <div class="lg:col-span-7">
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4">
            {monthOrder.map((m) => {
              const rating = monthRatingMap[m];
              return (
                <div class={`rounded-xl border p-4 text-center ${monthColorMap[rating]}`}>
                  <p class="text-xs font-semibold uppercase tracking-wider">{monthMap[m]}</p>
                  <p class="text-[10px] mt-1 uppercase tracking-wider opacity-80">
                    {rating === 'high' ? 'Peak' : rating === 'med' ? 'Shoulder' : 'Off'}
                  </p>
                </div>
              );
            })}
          </div>
          <div class="flex flex-wrap items-center gap-4 text-xs text-dusk-600">
            <span class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-safari-600"></span>Peak season</span>
            <span class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-savannah-300"></span>Shoulder season</span>
            <span class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-dusk-200"></span>Off season (wet)</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Highlight area -->
  {bestArea && (
    <section class="section bg-safari-50">
      <div class="container-content">
        <div class="grid lg:grid-cols-12 gap-12 items-center">
          <div class="lg:col-span-6">
            <div class="aspect-[4/3] overflow-hidden rounded-2xl shadow-lifted">
              <img
                src={bestArea.hero}
                alt={bestArea.name}
                class="w-full h-full object-cover"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
          <div class="lg:col-span-6">
            <p class="eyebrow text-safari-700 mb-3">Start your trip here</p>
            <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-5">
              {bestArea.name}
            </h2>
            <p class="text-dusk-700 leading-relaxed text-lg mb-6">
              {bestArea.description}
            </p>
            <a href={`/zanzibar/${bestArea.slug}`} class="btn btn-primary px-6 py-3">
              See {bestArea.name} in detail
              <ArrowRight size={16} />
            </a>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Ready-made packages -->
  {zanzibarTours.length > 0 && (
    <section class="section bg-white">
      <div class="container-content">
        <div class="flex items-end justify-between mb-8">
          <div>
            <p class="eyebrow text-safari-600 mb-3">Ready-made packages</p>
            <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900">
              Skip the planning, book a Zanzibar trip
            </h2>
          </div>
          <a href="/tours?style=zanzibar" class="hidden md:inline-flex items-center gap-2 text-safari-700 hover:text-safari-900 font-medium">
            See all Zanzibar trips
            <ArrowRight size={16} />
          </a>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {zanzibarTours.map((tour) => (
            <a
              href={`/tours/${tour.id}`}
              class="group relative overflow-hidden rounded-2xl bg-white border border-dusk-100 hover:border-safari-300 hover:shadow-lifted transition-all"
            >
              <div class="aspect-[4/3] overflow-hidden bg-dusk-200">
                <img
                  src={tour.data.hero}
                  alt={tour.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="p-5">
                <h3 class="font-display text-xl text-safari-900 mb-2 group-hover:text-safari-700 transition-colors">{tour.data.title}</h3>
                <p class="text-sm text-dusk-600 leading-relaxed mb-3 line-clamp-2">{tour.data.excerpt}</p>
                <div class="flex items-center gap-3 text-xs text-dusk-500">
                  <span>{tour.data.durationDays} days</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Sample itineraries -->
  <section class="section bg-dusk-50">
    <div class="container-content max-w-5xl">
      <p class="eyebrow text-safari-600 mb-3 text-center">Sample weeks</p>
      <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-10 text-center">
        Three classic Zanzibar weeks
      </h2>

      <div class="grid md:grid-cols-3 gap-5">
        <div class="bg-white rounded-2xl p-6 border border-dusk-100 shadow-soft">
          <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-700 mb-2">4 nights · Honeymoon</p>
          <h3 class="font-display text-xl text-safari-900 mb-3">Stone Town + Kendwa</h3>
          <ul class="text-sm text-dusk-600 space-y-2">
            <li>· Night 1: Stone Town hotel, sunset dhow cruise</li>
            <li>· Day 2: Spice tour, transfer to Kendwa</li>
            <li>· Days 3–4: Kendwa beach, snorkel trip</li>
            <li>· Day 5: Return, transfer to airport</li>
          </ul>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-dusk-100 shadow-soft">
          <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-700 mb-2">7 nights · Family</p>
          <h3 class="font-display text-xl text-safari-900 mb-3">Stone Town + Matemwe</h3>
          <ul class="text-sm text-dusk-600 space-y-2">
            <li>· Nights 1–2: Stone Town (history, food, beaches)</li>
            <li>· Day 3: Prison Island + transfer to Matemwe</li>
            <li>· Days 4–7: Matemwe, Mnemba snorkel, Jozani</li>
            <li>· Day 8: Return</li>
          </ul>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-dusk-100 shadow-soft">
          <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-700 mb-2">10 nights · Adventure</p>
          <h3 class="font-display text-xl text-safari-900 mb-3">Full-island slow trip</h3>
          <ul class="text-sm text-dusk-600 space-y-2">
            <li>· Nights 1–2: Stone Town</li>
            <li>· Nights 3–4: Nungwi (diving, sunset)</li>
            <li>· Nights 5–6: Paje (kitesurf or relax)</li>
            <li>· Nights 7–8: Jambiani (fishing village)</li>
            <li>· Nights 9–10: Matemwe (Mnemba)</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="section bg-white">
    <div class="container-content max-w-3xl">
      <p class="eyebrow text-safari-600 mb-3 text-center">Common questions</p>
      <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-10 text-center">
        Before you book
      </h2>

      <div class="space-y-4">
        {[
          {
            q: 'How many days do I need in Zanzibar?',
            a: 'A classic week (7 nights) is enough for Stone Town plus 2–3 beach areas. 4 nights is enough for a single beach with a Stone Town start. 10+ nights lets you really slow down and try 3–4 different coasts.'
          },
          {
            q: 'Should I add Zanzibar to a safari or Kilimanjaro climb?',
            a: 'Yes — most of our travellers do. The classic combination is 7 nights on Kilimanjaro + 4 nights on safari + 4–7 nights on Zanzibar. We handle all transfers (including the 2-hour Arusha → Zanzibar flight), and offer a 10% discount on the safari and Zanzibar legs when booked with a climb.'
          },
          {
            q: 'Which part of Zanzibar is best for honeymooners?',
            a: 'Kendwa (north) is the most popular honeymoon beach — calm water, no large tides, and a cluster of luxury resorts. Stone Town is a romantic 1–2 night add-on at the start or end.'
          },
          {
            q: 'Which part of Zanzibar is best for families?',
            a: 'Stone Town + Matemwe is our top family combo. Stone Town has culture and the Prison Island trip (giant tortoises); Matemwe has the best snorkeling on Mnemba Atoll and a quiet, safe beach.'
          },
          {
            q: 'Do I need a visa for Zanzibar?',
            a: 'Zanzibar is part of Tanzania, so a single Tanzanian visa covers both. Most nationalities get a visa on arrival at Zanzibar airport ($50 for US/UK/EU passports). Some nationalities can apply for an e-visa in advance.'
          },
          {
            q: 'Is Zanzibar safe?',
            a: 'Yes. Zanzibar is one of the safest parts of East Africa for tourists. Petty theft is rare, and violent crime against tourists is extremely uncommon. The main thing to be aware of is the tide — some east-coast beaches disappear at low tide, so check with your hotel before walking out.'
          },
        ].map((faq) => (
          <details class="group bg-dusk-50 rounded-xl border border-dusk-100">
            <summary class="flex items-center justify-between p-5 cursor-pointer list-none">
              <h3 class="font-display text-lg text-safari-900 pr-4">{faq.q}</h3>
              <span class="w-8 h-8 rounded-full bg-safari-100 text-safari-700 flex items-center justify-center flex-shrink-0 group-open:rotate-45 transition-transform">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
              </span>
            </summary>
            <div class="px-5 pb-5 text-dusk-700 leading-relaxed">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section bg-safari-900 text-white">
    <div class="container-content">
      <div class="max-w-3xl mx-auto text-center">
        <p class="eyebrow text-savannah-300 mb-3">Start planning</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight mb-5">
          Tell us your dates. We'll plan your week.
        </h2>
        <p class="text-lg text-dusk-100/90 mb-8">
          Zanzibar trips are private and fully customized. Tell us your group, preferred beaches, and dates — we'll send a full quote within 24 hours, including transfers from your safari or Kilimanjaro climb.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/contact?subject=zanzibar" class="btn btn-primary px-8 py-3.5">
            Get a custom quote
            <ArrowRight size={16} />
          </a>
          <a href="/tours?style=zanzibar" class="btn btn-outline-light px-8 py-3.5 border-white/30 hover:bg-white hover:text-safari-900">
            See ready-made Zanzibar trips
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- JSON-LD: ItemList of 8 areas -->
  <script type="application/ld+json" set:html={JSON.stringify(withPublisher({
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Zanzibar Areas',
    description: 'Hand-picked areas of Zanzibar for travellers',
    numberOfItems: areas.length,
    itemListElement: areas.map((a, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: a.name,
      description: a.tagline,
      url: `/zanzibar/${a.slug}`,
    })),
  }))} />
</PublicLayout>
