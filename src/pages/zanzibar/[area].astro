---
import PublicLayout from '@/layouts/PublicLayout.astro';
import { zanzibarAreas, zanzibarAreaBySlug } from '@/data/zanzibar-areas';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { withPublisher } from '@/lib/jsonld';
import {
  ArrowRight, ArrowLeft, MapPin, Calendar, WavesHorizontal, Camera, Trees, Check,
} from '@lucide/astro';

export async function getStaticPaths() {
  return zanzibarAreas.map((a) => ({ params: { area: a.slug } }));
}

const { area: areaSlug } = Astro.params;
const area = zanzibarAreaBySlug(areaSlug!)!;
const allTours = await getCollection('tours');
const relatedTours = allTours.filter((t) => t.data.type === 'zanzibar' || t.data.destinations.includes('zanzibar-archipelago')).slice(0, 3);

const otherAreas = zanzibarAreas
  .filter((a) => a.slug !== area.slug)
  .sort((a, b) => a.order - b.order)
  .slice(0, 3);

const monthOrder = [
  'January', 'February', 'March', 'April', 'May', 'June',
  'July', 'August', 'September', 'October', 'November', 'December',
];
const monthShort = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const bestTimeOrdered = monthOrder.map((m) => {
  const found = area.bestTime.find((bt) => bt.month === m);
  return { month: m, short: monthShort[monthOrder.indexOf(m)], rating: found?.rating ?? 'low' };
});

const regionIcons: Record<string, typeof WavesHorizontal> = {
  'Stone Town': Camera,
  'North Coast': WavesHorizontal,
  'Northeast Coast': WavesHorizontal,
  'East Coast': WavesHorizontal,
  'South Coast': WavesHorizontal,
  'West Coast': WavesHorizontal,
  'Inland': Trees,
};
const RegionIcon = regionIcons[area.region] ?? WavesHorizontal;

const ratingColorMap: Record<'high' | 'med' | 'low', string> = {
  high: 'bg-safari-600 text-white border-safari-700',
  med: 'bg-savannah-200 text-savannah-900 border-savannah-300',
  low: 'bg-dusk-100 text-dusk-500 border-dusk-200',
};

const heroUrl = area.hero ? area.hero.replace(/w=800/g, 'w=1920') : '';
---

<PublicLayout
  title={`${area.name}, Zanzibar - Where to Stay & What to Do`}
  description={`Plan your visit to ${area.name}: best beaches, top things to do, where to stay, how to get there, and best time to visit. ${area.tagline}`}
  transparentHeader={true}
>
  <section class="relative h-[65vh] min-h-[460px] md:h-[80vh] md:min-h-[600px] lg:h-screen lg:min-h-[750px] w-full overflow-hidden bg-safari-900 text-white">
    <Image
      src={heroUrl}
      alt={area.name}
      width={1920}
      height={1080}
      class="absolute inset-0 w-full h-full object-cover"
      style={{ objectPosition: (area as any).heroPosition || 'center 30%' }}
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-tr from-black/85 via-black/45 to-black/20"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-black/40"></div>

    <div class="container-content relative z-10 h-full flex flex-col justify-end pb-16 md:pb-20 pt-32">
      <div class="max-w-3xl">
        <a href="/zanzibar" class="inline-flex items-center gap-2 text-savannah-300 hover:text-savannah-200 text-xs uppercase tracking-[0.18em] mb-5 md:mb-6 transition-colors">
          <ArrowLeft size={14} />
          All Zanzibar areas
        </a>

        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 backdrop-blur border border-white/20 text-xs uppercase tracking-wider mb-4">
          <RegionIcon size={12} />
          {area.region}
        </div>

        <h1 class="font-display text-[2.5rem] sm:text-5xl md:text-6xl lg:text-7xl font-medium tracking-tight text-white mb-5 md:mb-6">
          {area.name}
        </h1>

        <p class="text-lg md:text-xl text-dusk-100/90 max-w-2xl leading-relaxed font-light">
          {area.tagline}
        </p>
      </div>
    </div>
  </section>

  <section class="bg-safari-900 text-white border-b border-white/10">
    <div class="container-content">
      <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-white/10">
        <div class="px-4 md:px-6 py-5 md:py-6">
          <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-300/80 mb-1">Region</p>
          <p class="font-display text-xl md:text-2xl text-white">{area.region}</p>
        </div>
        <div class="px-4 md:px-6 py-5 md:py-6">
          <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-300/80 mb-1">Best for</p>
          <p class="font-display text-base md:text-lg text-white">{area.bestFor.slice(0, 3).join(' · ')}</p>
        </div>
        <div class="px-4 md:px-6 py-5 md:py-6">
          <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-300/80 mb-1">Getting there</p>
          <p class="text-sm md:text-base text-white">{area.gettingThere}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-dusk-50">
    <div class="container-content">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
        <div class="lg:col-span-7">
          <p class="eyebrow text-safari-600 mb-4">About {area.name}</p>
          <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-6">
            {area.tagline}
          </h2>
          <div class="prose prose-lg max-w-none text-dusk-700 leading-relaxed space-y-5">
            <p class="text-lg">{area.description}</p>
          </div>
        </div>

        <aside class="lg:col-span-5 space-y-6">
          <div class="bg-white rounded-2xl border border-dusk-100 shadow-soft p-6 md:p-8">
            <p class="eyebrow text-savannah-700 mb-3">Stay</p>
            <p class="text-dusk-700 leading-relaxed mb-6">{area.accommodation}</p>

            <a href={`/contact?subject=zanzibar&area=${area.slug}`} class="btn btn-primary w-full justify-center">
              Plan a {area.name} trip
              <ArrowRight size={16} />
            </a>
            <a href="/tours?style=zanzibar" class="btn btn-outline w-full justify-center mt-3">
              See Zanzibar packages
            </a>

            <div class="border-t border-dusk-100 mt-6 pt-6 space-y-3 text-sm">
              <div class="flex items-start gap-3">
                <MapPin size={16} class="text-safari-600 flex-shrink-0 mt-0.5" />
                <div>
                  <p class="text-dusk-500 text-xs">Region</p>
                  <p class="text-dusk-900">{area.region}</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <Calendar size={16} class="text-safari-600 flex-shrink-0 mt-0.5" />
                <div>
                  <p class="text-dusk-500 text-xs">Getting there</p>
                  <p class="text-dusk-900">{area.gettingThere}</p>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-safari-50 border border-safari-100 rounded-2xl p-6">
            <p class="eyebrow text-safari-700 mb-3">Best for</p>
            <div class="flex flex-wrap gap-2">
              {area.bestFor.map((b) => (
                <span class="px-2.5 py-1 rounded text-xs font-medium bg-safari-100 text-safari-800">
                  {b}
                </span>
              ))}
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-content max-w-4xl">
      <p class="eyebrow text-safari-600 mb-3 text-center">When to visit</p>
      <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-10 text-center">
        Best time for {area.name}
      </h2>

      <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-3 mb-4">
        {bestTimeOrdered.map((m) => (
          <div class={`rounded-xl border p-3 text-center ${ratingColorMap[m.rating]}`}>
            <p class="text-xs font-semibold uppercase tracking-wider">{m.short}</p>
            <p class="text-[10px] mt-1 uppercase tracking-wider opacity-80">
              {m.rating === 'high' ? 'Peak' : m.rating === 'med' ? 'Shoulder' : 'Off'}
            </p>
          </div>
        ))}
      </div>
      <div class="flex flex-wrap items-center justify-center gap-4 text-xs text-dusk-600">
        <span class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-safari-600"></span>Peak season</span>
        <span class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-savannah-300"></span>Shoulder season</span>
        <span class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-dusk-200"></span>Off season</span>
      </div>
    </div>
  </section>

  <section class="section bg-dusk-50">
    <div class="container-content">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="eyebrow text-safari-600 mb-3">Why {area.name}</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900">
          What makes {area.name} stand out
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto">
        {area.highlights.map((highlight) => (
          <div class="flex items-start gap-3 p-5 rounded-xl bg-white border border-dusk-100">
            <span class="w-8 h-8 rounded-lg bg-savannah-100 text-savannah-700 flex items-center justify-center flex-shrink-0">
              <Check size={16} />
            </span>
            <p class="text-dusk-800 leading-relaxed">{highlight}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-content max-w-4xl">
      <p class="eyebrow text-safari-600 mb-3 text-center">Top things to do</p>
      <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-10 text-center">
        Don't miss in {area.name}
      </h2>

      <div class="grid sm:grid-cols-2 gap-4">
        {area.attractions.map((attraction) => (
          <div class="flex items-center gap-4 p-5 rounded-xl bg-dusk-50 border border-dusk-100">
            <span class="w-2 h-2 rounded-full bg-safari-600 flex-shrink-0"></span>
            <p class="text-dusk-800 font-medium">{attraction}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-dusk-50">
    <div class="container-content">
      <div class="flex items-end justify-between mb-8">
        <div>
          <p class="eyebrow text-safari-600 mb-3">Compare</p>
          <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900">
            Other Zanzibar areas
          </h2>
        </div>
        <a href="/zanzibar" class="hidden md:inline-flex items-center gap-2 text-safari-700 hover:text-safari-900 font-medium">
          See all 8 areas
          <ArrowRight size={16} />
        </a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {otherAreas.map((a) => (
          <a
            href={`/zanzibar/${a.slug}`}
            class="group relative overflow-hidden rounded-2xl bg-white border border-dusk-100 hover:border-safari-300 hover:shadow-lifted transition-all"
          >
            <div class="aspect-[4/3] overflow-hidden bg-dusk-200">
              <Image
                src={a.hero}
                alt={a.name}
                width={600}
                height={450}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="p-5">
              <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-700 mb-2">{a.region}</p>
              <h3 class="font-display text-xl text-safari-900 mb-2 group-hover:text-safari-700 transition-colors">{a.name}</h3>
              <p class="text-sm text-dusk-600 leading-relaxed line-clamp-2">{a.tagline}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {relatedTours.length > 0 && (
    <section class="section bg-white">
      <div class="container-content">
        <div class="flex items-end justify-between mb-8">
          <div>
            <p class="eyebrow text-safari-600 mb-3">Ready-made trips</p>
            <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900">
              Zanzibar packages
            </h2>
          </div>
          <a href="/tours?style=zanzibar" class="hidden md:inline-flex items-center gap-2 text-safari-700 hover:text-safari-900 font-medium">
            See all
            <ArrowRight size={16} />
          </a>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {relatedTours.map((tour) => (
            <a
              href={`/tours/${tour.id}`}
              class="group relative overflow-hidden rounded-2xl bg-white border border-dusk-100 hover:border-safari-300 hover:shadow-lifted transition-all"
            >
              <div class="aspect-[4/3] overflow-hidden bg-dusk-200">
                <Image
                  src={tour.data.hero}
                  alt={tour.data.title}
                  width={600}
                  height={450}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="p-5">
                <h3 class="font-display text-xl text-safari-900 mb-2 group-hover:text-safari-700 transition-colors">{tour.data.title}</h3>
                <p class="text-sm text-dusk-600 leading-relaxed mb-3 line-clamp-2">{tour.data.excerpt}</p>
                <div class="flex items-center gap-3 text-xs text-dusk-500">
                  <span>{tour.data.durationDays} days</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section bg-safari-900 text-white">
    <div class="container-content">
      <div class="max-w-3xl mx-auto text-center">
        <p class="eyebrow text-savannah-300 mb-3">Ready to plan?</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight mb-5">
          Plan your {area.name} trip
        </h2>
        <p class="text-lg text-dusk-100/90 mb-8">
          Tell us your dates and group. We'll send a full quote within 24 hours, including transfers, accommodation, and the best things to do in {area.name}.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={`/contact?subject=zanzibar&area=${area.slug}`} class="btn btn-primary px-8 py-3.5">
            Get a custom quote
            <ArrowRight size={16} />
          </a>
          <a href="/zanzibar" class="btn btn-outline-light px-8 py-3.5 border-white/30 hover:bg-white hover:text-safari-900">
            Compare areas
          </a>
        </div>
      </div>
    </div>
  </section>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(withPublisher({
    '@context': 'https://schema.org',
    '@type': 'TouristAttraction',
    name: `${area.name}, Zanzibar`,
    description: area.tagline,
    image: area.hero,
    address: {
      '@type': 'PostalAddress',
      addressCountry: 'TZ',
      addressRegion: area.region,
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: -6.1659,
      longitude: 39.1989,
    },
  }))} />
</PublicLayout>
