---
import CategoryPage from '@/components/templates/CategoryPage.astro';
import { CATEGORY_CONFIG, getToursForCategory } from '@/lib/safari-categories';

const matchingTours = await getToursForCategory('migration');
const config = CATEGORY_CONFIG.migration;
---

<CategoryPage
  category={config.pluralLabel}
  experienceSlug={config.experienceSlug}
  categoryHref="/tours/migration"
  whenToGo={config.whenToGo}
  matchingTours={matchingTours}
/>
