---
import PublicLayout from '@/layouts/PublicLayout.astro';
import { getCollection } from 'astro:content';
import { MapPin, ListFilter, TreePalm, Mountain, Sparkles, Umbrella } from '@lucide/astro';
import { Image } from 'astro:assets';

const destinations = await getCollection('destinations');
const sorted = destinations.sort((a, b) =>
  a.data.name.localeCompare(b.data.name)
);

const regionIcons: Record<string, typeof TreePalm> = {
  'Northern Circuit': TreePalm,
  Coastal: Umbrella,
  Mountain: Mountain,
};

const regions = ['All', 'Northern Circuit', 'Coastal', 'Mountain'];
const regionCount: Record<string, number> = { All: sorted.length };
for (const r of regions.slice(1)) {
  regionCount[r] = sorted.filter((d) => d.data.region === r).length;
}
---

<PublicLayout
  title="All Destinations in Tanzania | National Parks, Islands & Mountains"
  description="Browse every major Tanzania destination - Serengeti, Ngorongoro, Zanzibar, Kilimanjaro, Selous, and more. Wildlife, best time to visit, how to get there, and safari ideas."
  ogImage="/og/destinations.png"
  transparentHeader={true}
>
  <!-- Hero -->
  <section class="relative h-[85vh] min-h-[600px] w-full overflow-hidden bg-safari-900 text-white">
    <Image
      src="https://images.unsplash.com/photo-1547970810-dc1eac37d174?w=1920&q=80&auto=format&fit=crop"
      alt="Tanzania Serengeti plains at sunset"
      width={1920}
      height={1080}
      class="absolute inset-0 w-full h-full object-cover scale-105"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-tr from-black/85 via-black/45 to-black/20"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-black/40"></div>

    <div class="container-content relative z-10 h-full flex flex-col justify-end pb-12 sm:pb-20 pt-36 sm:pt-32">
      <div class="max-w-3xl">
        <p class="eyebrow text-savannah-300 text-[10px] sm:text-xs uppercase tracking-wider sm:tracking-[0.18em] leading-relaxed mb-3">6 national parks · 2 mountains · 1 island archipelago</p>

        <h1 class="font-display text-3xl xs:text-4xl sm:text-6xl md:text-7xl lg:text-display-lg font-medium tracking-tight text-white mb-4 sm:mb-6">
          Where will<br />
          <span class="italic font-normal text-savannah-300">Northern Tanzania take you?</span>
        </h1>

        <p class="text-base sm:text-lg md:text-xl text-dusk-100/90 max-w-2xl leading-relaxed font-light mb-0">
          From the open plains of the Serengeti to the alleys of Stone Town, the glaciers of Kilimanjaro to the ridgelines of Mount Meru - these are the parks, islands, and mountains of Northern Tanzania and Zanzibar.
        </p>
      </div>
    </div>
  </section>

  <!-- Region filter -->
  <section class="bg-white border-b border-dusk-100 sticky top-0 z-30">
    <div class="container-content py-4 flex flex-wrap items-center gap-3">
      <span class="text-sm font-medium text-dusk-700 flex items-center gap-2 mr-2">
        <ListFilter size={16} /> Region:
      </span>
      {regions.map((r) => (
        <button
          class:list={[
            'dest-filter px-3 py-1.5 text-sm rounded-full transition-colors',
            r === 'All'
              ? 'bg-safari-700 text-white'
              : 'bg-dusk-100 text-dusk-700 hover:bg-dusk-200',
          ]}
          data-filter={r}
        >
          {r} ({regionCount[r]})
        </button>
      ))}
    </div>
  </section>

  <!-- Destination grid -->
  <section class="section bg-dusk-50">
    <div class="container-content">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sorted.map((dest) => {
          const Icon = regionIcons[dest.data.region] ?? Sparkles;
          return (
            <a
              href={`/destinations/${dest.id}`}
              class="card card-hover group block dest-card"
              data-region={dest.data.region}
            >
              <div class="relative aspect-[4/3] overflow-hidden">
                <Image
                  src={dest.data.hero}
                  alt={dest.data.name}
                  width={600}
                  height={450}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-safari-900/85 via-safari-900/20 to-transparent"></div>
                <div class="absolute top-3 left-3 inline-flex items-center gap-1.5 bg-white/95 backdrop-blur text-safari-900 text-[10px] font-semibold tracking-wider uppercase px-2.5 py-1 rounded-full">
                  <Icon size={11} />
                  {dest.data.region}
                </div>
                <div class="absolute bottom-0 left-0 right-0 p-5">
                  <h2 class="font-display text-xl md:text-2xl font-medium text-white mb-1.5 group-hover:text-savannah-300 transition-colors">
                    {dest.data.name}
                  </h2>
                </div>
              </div>
              <div class="p-6">
                <p class="text-sm text-dusk-700 leading-relaxed mb-4 line-clamp-3">
                  {dest.data.summary}
                </p>
                <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-dusk-600">
                  <span class="inline-flex items-center gap-1.5">
                    <MapPin size={12} />
                    {dest.data.region}
                  </span>
                  {dest.data.wildlife.length > 0 && (
                    <span class="inline-flex items-center gap-1.5">
                      <Sparkles size={12} />
                      {dest.data.wildlife.length} key species
                    </span>
                  )}
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Why Tanzania -->
  <section class="section bg-white">
    <div class="container-content max-w-4xl">
      <div class="text-center mb-12">
        <p class="eyebrow mb-3">Why Tanzania</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium text-safari-900 mb-4">
          One small country, an entire continent of wildlife
        </h2>
        <p class="text-lg text-dusk-700 leading-relaxed">
          Tanzania is home to roughly a third of Africa's large mammal species, plus an Indian Ocean coastline and the highest mountain in Africa. The destinations below are the places we know best.
        </p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="text-center">
          <p class="font-display text-3xl font-medium text-savannah-700">22</p>
          <p class="text-sm text-dusk-600 mt-1">National parks</p>
        </div>
        <div class="text-center">
          <p class="font-display text-3xl font-medium text-savannah-700">1.5M</p>
          <p class="text-sm text-dusk-600 mt-1">Migrating wildebeest</p>
        </div>
        <div class="text-center">
          <p class="font-display text-3xl font-medium text-savannah-700">5,895m</p>
          <p class="text-sm text-dusk-600 mt-1">Kilimanjaro summit</p>
        </div>
        <div class="text-center">
          <p class="font-display text-3xl font-medium text-savannah-700">1,400+</p>
          <p class="text-sm text-dusk-600 mt-1">Bird species</p>
        </div>
      </div>
    </div>
  </section>


</PublicLayout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.dest-filter');
  const cards = document.querySelectorAll<HTMLElement>('.dest-card');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;
      filterBtns.forEach((b) => {
        b.classList.remove('bg-safari-700', 'text-white');
        b.classList.add('bg-dusk-100', 'text-dusk-700');
      });
      btn.classList.add('bg-safari-700', 'text-white');
      btn.classList.remove('bg-dusk-100', 'text-dusk-700');

      cards.forEach((card) => {
        if (filter === 'All' || card.dataset.region === filter) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>
