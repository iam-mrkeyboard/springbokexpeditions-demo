---
import { getEntry, getCollection, render } from 'astro:content';
import PublicLayout from '@/layouts/PublicLayout.astro';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const treks = await getCollection('trekking');
  return treks.map((trek) => ({
    params: { id: trek.id },
    props: {},
  }));
}
import { withPublisher } from '@/lib/jsonld';
import {
  ArrowRight, MapPin, Calendar, Check, X, Mountain, TrendingUp,
  HeartPulse, Stethoscope, Droplets, Clock, Users, Compass,
} from '@lucide/astro';

const { id } = Astro.params;
if (!id) return Astro.rewrite('/404');
const trek = await getEntry('trekking', id);
if (!trek) return Astro.rewrite('/404');

const route = trek.data.mountain === 'kilimanjaro' ? await getEntry('kilimanjaro', trek.data.route) : null;
const { Content } = await render(trek as any);

const difficultyLabel: Record<string, string> = {
  easy: 'Easy',
  moderate: 'Moderate',
  challenging: 'Challenging',
  strenuous: 'Strenuous',
};

const accommodationLabel: Record<string, string> = {
  tents: 'Tented camps',
  huts: 'Mountain huts',
};

const tazamaImages = {
  cta: 'https://res.cloudinary.com/drhl0yu7y/image/upload/v1759133537/kilimanjaro/call-to-action/cta-3_rhubqu.jpg',
  prep: 'https://res.cloudinary.com/drhl0yu7y/image/upload/v1759229190/kilimanjaro/main-page/kilimanjaro5_y8r9ru.webp',
};

const rawHero = (trek.data.hero ?? route?.data.hero) || '';
const heroUrl = rawHero ? rawHero.replace(/w=800/g, 'w=1920') : '';
---

<PublicLayout
  title={trek.data.seo?.title ?? `${trek.data.title}`}
  description={trek.data.seo?.description ?? trek.data.excerpt}
  transparentHeader={true}
>
  <section class="relative h-[65vh] min-h-[460px] md:h-[80vh] md:min-h-[600px] lg:h-screen lg:min-h-[750px] w-full overflow-hidden bg-safari-900 text-white">
    <Image
      src={heroUrl || ''}
      alt={`${trek.data.title} landscape`}
      width={1920}
      height={1080}
      class="absolute inset-0 w-full h-full object-cover"
      style={{ objectPosition: (trek.data as any).heroPosition || 'center 30%' }}
      loading="eager"
      fetchpriority="high"
    />
    <!-- Single gradient overlay for readability and image vividness -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-black/15"></div>

    <div class="container-content relative z-10 h-full flex flex-col justify-end pb-20 md:pb-24 pt-32">
      <div class="max-w-3xl">
        <nav aria-label="Breadcrumb" class="mb-5 md:mb-6">
          <ol class="inline-flex items-center gap-2 text-savannah-300 text-xs uppercase tracking-[0.18em]">
            <li><a href="/kilimanjaro" class="hover:text-savannah-200 transition-colors">Kilimanjaro</a></li>
            <li class="text-savannah-400/70">/</li>
            {route && (
              <>
                <li><a href={`/kilimanjaro/${route.id}`} class="hover:text-savannah-200 transition-colors">{route.data.name}</a></li>
                <li class="text-savannah-400/70">/</li>
              </>
            )}
            <li class="text-savannah-100" aria-current="page">{trek.data.durationDays}-day trek</li>
          </ol>
        </nav>

        <p class="eyebrow text-savannah-300 text-[11px] md:text-xs uppercase tracking-[0.18em] mb-3">
          {trek.data.durationDays}-day itinerary
        </p>

        <h1 class="font-display text-[2.5rem] sm:text-5xl md:text-6xl lg:text-7xl font-medium tracking-tight text-white mb-5 md:mb-6 leading-[1.05]">
          {trek.data.title}
        </h1>

        <p class="text-lg md:text-xl text-dusk-100/90 max-w-2xl leading-relaxed font-light">
          {trek.data.summary}
        </p>
      </div>
    </div>
  </section>

  <section class="bg-safari-900 text-white border-b border-white/10">
    <div class="container-content">
      <div class="grid grid-cols-2 md:grid-cols-5 divide-x divide-white/10">
        <div class="px-4 md:px-6 py-5 md:py-6">
          <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-300/80 mb-1">Duration</p>
          <p class="font-display text-xl md:text-2xl text-white">{trek.data.durationDays} days</p>
        </div>
        <div class="px-4 md:px-6 py-5 md:py-6">
          <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-300/80 mb-1">Difficulty</p>
          <p class="font-display text-xl md:text-2xl text-white">{difficultyLabel[trek.data.difficulty ?? '']}</p>
        </div>
        <div class="px-4 md:px-6 py-5 md:py-6">
          <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-300/80 mb-1">Success rate</p>
          <p class="font-display text-xl md:text-2xl text-white">{trek.data.successRate}</p>
        </div>
        <div class="px-4 md:px-6 py-5 md:py-6">
          <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-300/80 mb-1">Sleep</p>
          <p class="font-display text-xl md:text-2xl text-white capitalize">{accommodationLabel[trek.data.accommodation ?? ''] ?? trek.data.accommodation}</p>
        </div>
        <div class="px-4 md:px-6 py-5 md:py-6">
          <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-300/80 mb-1">Best months</p>
          <p class="font-display text-xl md:text-2xl text-white">{trek.data.bestMonths.length}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-dusk-50">
    <div class="container-content">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
        <div class="lg:col-span-7">
          <p class="eyebrow text-safari-600 mb-4">About this trek</p>
          <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-6">
            {trek.data.title}
          </h2>
          <div class="prose prose-lg max-w-none text-dusk-700 leading-relaxed space-y-5">
            <p class="text-lg">{trek.data.excerpt}</p>
            <Content />
          </div>
        </div>

        <aside class="lg:col-span-5 space-y-6">
          <div class="bg-white rounded-2xl border border-dusk-100 shadow-soft p-6 md:p-8">
            <p class="eyebrow text-savannah-700 mb-3">Plan this trek</p>
            <p class="text-dusk-700 leading-relaxed mb-6">Get a custom quote with exact pricing for your dates and group size.</p>

            <a href={`/contact?trek=${trek.id}`} class="btn btn-primary w-full justify-center">
              Plan this climb
              <ArrowRight size={16} />
            </a>

            <div class="border-t border-dusk-100 mt-6 pt-6 space-y-3 text-sm">
              <div class="flex items-start gap-3">
                <MapPin size={16} class="text-safari-600 flex-shrink-0 mt-0.5" />
                <div>
                  <p class="text-dusk-500 text-xs">Route</p>
                  <p class="text-dusk-900">{route?.data.name ?? trek.data.route}</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <Calendar size={16} class="text-safari-600 flex-shrink-0 mt-0.5" />
                <div>
                  <p class="text-dusk-500 text-xs">Best months</p>
                  <p class="text-dusk-900">{trek.data.bestMonths.slice(0, 4).join(', ')}{trek.data.bestMonths.length > 4 ? `, +${trek.data.bestMonths.length - 4} more` : ''}</p>
                </div>
              </div>
            </div>
          </div>

          {route && (
            <div class="bg-safari-50 border border-safari-100 rounded-2xl p-6">
              <p class="eyebrow text-safari-700 mb-3">About the route</p>
              <h3 class="font-display text-xl text-safari-900 mb-2">{route.data.name}</h3>
              <p class="text-sm text-dusk-600 leading-relaxed mb-4 line-clamp-3">{route.data.summary}</p>
              <a href={`/kilimanjaro/${route.id}`} class="inline-flex items-center gap-2 text-safari-700 hover:text-safari-900 font-medium text-sm">
                Explore the route
                <ArrowRight size={14} />
              </a>
            </div>
          )}

          <div class="bg-white border border-dusk-100 rounded-2xl p-6">
            <p class="eyebrow text-safari-700 mb-3">Why book with us</p>
            <ul class="space-y-2 text-sm text-dusk-700">
              <li class="flex items-start gap-2">
                <Check size={14} class="text-safari-600 flex-shrink-0 mt-0.5" />
                Arusha-based team, no middlemen
              </li>
              <li class="flex items-start gap-2">
                <Check size={14} class="text-safari-600 flex-shrink-0 mt-0.5" />
                Certified guides + full support crew
              </li>
              <li class="flex items-start gap-2">
                <Check size={14} class="text-safari-600 flex-shrink-0 mt-0.5" />
                Oxygen, pulse oximeter, medical kits
              </li>
              <li class="flex items-start gap-2">
                <Check size={14} class="text-safari-600 flex-shrink-0 mt-0.5" />
                Fair porter wages, KPAP-aligned
              </li>
              <li class="flex items-start gap-2">
                <Check size={14} class="text-safari-600 flex-shrink-0 mt-0.5" />
                Private portable toilets on every trek
              </li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-content">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="eyebrow text-safari-600 mb-3">Why this trek</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900">
          What makes this itinerary stand out
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto">
        {trek.data.highlights.map((highlight) => (
          <div class="flex items-start gap-3 p-5 rounded-xl bg-dusk-50 border border-dusk-100 hover:border-savannah-300/60 transition-colors">
            <span class="w-8 h-8 rounded-lg bg-savannah-100 text-savannah-700 flex items-center justify-center flex-shrink-0">
              <Check size={16} />
            </span>
            <p class="text-dusk-800 leading-relaxed">{highlight}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="itinerary" class="section bg-dusk-50">
    <div class="container-content">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="eyebrow text-safari-600 mb-3">Day by day</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900">
          The {trek.data.durationDays}-day itinerary
        </h2>
        <p class="text-dusk-600 mt-4">
          Every day below is led by your guide, supported by our full mountain crew. Times are approximate - the schedule adjusts to weather, fitness, and how the group is acclimatizing.
        </p>
      </div>

      <div class="max-w-4xl mx-auto">
        <ol class="relative border-l-2 border-safari-200 ml-3 md:ml-6 space-y-8">
          {trek.data.itinerary.map((day) => (
            <li class="pl-6 md:pl-10 relative">
              <span class="absolute -left-[11px] md:-left-[15px] top-0 flex items-center justify-center w-6 h-6 md:w-8 md:h-8 rounded-full bg-safari-600 text-white font-display text-sm">
                {day.day}
              </span>

              <div class="bg-white rounded-xl border border-dusk-100 p-6 md:p-7 shadow-soft hover:shadow-lifted transition-shadow">
                <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 mb-3">
                  <h3 class="font-display text-xl md:text-2xl text-safari-900">Day {day.day} · {day.title}</h3>
                </div>

                <p class="text-xs text-dusk-500 mb-4 flex flex-wrap items-center gap-x-2 gap-y-1">
                  <span class="inline-flex items-center gap-1"><TrendingUp size={12} class="text-safari-600" />{day.elevation}</span>
                  <span class="text-dusk-300">·</span>
                  <span class="inline-flex items-center gap-1"><Calendar size={12} class="text-safari-600" />{day.timeWalking}</span>
                  <span class="text-dusk-300">·</span>
                  <span class="inline-flex items-center gap-1"><Mountain size={12} class="text-safari-600" />{day.terrain}</span>
                  <span class="text-dusk-300">·</span>
                  <span class="text-savannah-700 font-medium">Meals {day.meals}</span>
                </p>

                <p class="text-dusk-700 leading-relaxed mb-3">{day.description}</p>

                <p class="text-sm text-dusk-500">
                  <span class="font-semibold text-dusk-700">Sleep:</span> {day.accommodation}
                </p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- Safety & comfort -->
  <section class="section bg-safari-900 text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <Image
        src={tazamaImages.cta}
        alt="Mountain landscape background"
        width={1920}
        height={1080}
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-safari-900 via-safari-900/95 to-safari-900"></div>

    <div class="container-content relative z-10">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="eyebrow text-savannah-300 mb-3">Safety & Comfort</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight mb-4">
          The details that keep you moving upward.
        </h2>
        <p class="text-dusk-200 text-lg">
          Altitude is the real test on Kilimanjaro. We stack the odds in your favor with careful pacing, daily health checks, and gear you can rely on.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 backdrop-blur-sm hover:bg-white/10 transition-colors">
          <span class="w-11 h-11 rounded-xl bg-savannah-500/20 text-savannah-300 flex items-center justify-center mb-4">
            <HeartPulse size={22} />
          </span>
          <h3 class="font-display text-lg text-white mb-2">Daily health checks</h3>
          <p class="text-sm text-dusk-200/80 leading-relaxed">Oxygen saturation, pulse, and symptom reviews every morning and evening.</p>
        </div>
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 backdrop-blur-sm hover:bg-white/10 transition-colors">
          <span class="w-11 h-11 rounded-xl bg-savannah-500/20 text-savannah-300 flex items-center justify-center mb-4">
            <Stethoscope size={22} />
          </span>
          <h3 class="font-display text-lg text-white mb-2">Rescue-ready crew</h3>
          <p class="text-sm text-dusk-200/80 leading-relaxed">Wilderness First Responder guides with oxygen, stretcher, and emergency comms.</p>
        </div>
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 backdrop-blur-sm hover:bg-white/10 transition-colors">
          <span class="w-11 h-11 rounded-xl bg-savannah-500/20 text-savannah-300 flex items-center justify-center mb-4">
            <Droplets size={22} />
          </span>
          <h3 class="font-display text-lg text-white mb-2">Private toilets</h3>
          <p class="text-sm text-dusk-200/80 leading-relaxed">Portable camp toilets at every stop for hygiene, privacy, and dignity.</p>
        </div>
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 backdrop-blur-sm hover:bg-white/10 transition-colors">
          <span class="w-11 h-11 rounded-xl bg-savannah-500/20 text-savannah-300 flex items-center justify-center mb-4">
            <Clock size={22} />
          </span>
          <h3 class="font-display text-lg text-white mb-2">Pole pole pacing</h3>
          <p class="text-sm text-dusk-200/80 leading-relaxed">Slow walking, rest days, and sleep-low ascents built into the itinerary.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Preparation -->
  <section class="section bg-white">
    <div class="container-content">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="eyebrow text-safari-600 mb-4">Prepare for Success</p>
          <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-5">
            Your part of the partnership.
          </h2>
          <p class="text-dusk-700 leading-relaxed text-lg mb-6">
            We handle permits, logistics, crew, and meals. Your job is to arrive fit, well-equipped, and ready to walk slowly. The better you prepare, the more you will enjoy every camp and every sunrise.
          </p>
          <div class="space-y-4">
            {[
              { icon: Clock, title: 'Train over 8–12 weeks', body: 'Build endurance with hiking, cycling, or swimming. Add a weighted daypack in the final month.' },
              { icon: Compass, title: 'Break in your boots', body: 'Blisters end more treks than fatigue. Wear your trekking boots on long walks before you fly.' },
              { icon: Mountain, title: 'Practice layering', body: 'Summit night can drop below -15°C. Learn to add and remove layers quickly.' },
              { icon: Users, title: 'Trust the team', body: 'Your guide sets the pace. Pole pole is not slow - it is the fastest way to the top.' },
            ].map((item) => (
              <div class="flex items-start gap-4 p-4 rounded-xl bg-dusk-50 border border-dusk-100">
                <span class="w-10 h-10 rounded-xl bg-safari-100 text-safari-700 flex items-center justify-center flex-shrink-0">
                  <item.icon size={18} />
                </span>
                <div>
                  <p class="font-medium text-safari-900">{item.title}</p>
                  <p class="text-sm text-dusk-600 leading-relaxed">{item.body}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-lifted">
          <Image
            src={tazamaImages.prep}
            alt="Kilimanjaro trekking team preparing for the day's hike"
            width={800}
            height={600}
            class="w-full h-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-dusk-50">
    <div class="container-content">
      <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <div class="bg-safari-50 rounded-2xl border border-safari-100 p-7 md:p-8">
          <div class="flex items-center gap-3 mb-5">
            <span class="w-10 h-10 rounded-xl bg-safari-600 text-white flex items-center justify-center">
              <Check size={20} />
            </span>
            <h3 class="font-display text-2xl text-safari-900">What's included</h3>
          </div>
          <ul class="space-y-3">
            {trek.data.inclusions.map((item) => (
              <li class="flex items-start gap-3 text-dusk-700">
                <Check size={16} class="text-safari-600 flex-shrink-0 mt-1" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-white rounded-2xl border border-dusk-100 p-7 md:p-8">
          <div class="flex items-center gap-3 mb-5">
            <span class="w-10 h-10 rounded-xl bg-dusk-300 text-dusk-900 flex items-center justify-center">
              <X size={20} />
            </span>
            <h3 class="font-display text-2xl text-dusk-900">Not included</h3>
          </div>
          <ul class="space-y-3">
            {trek.data.exclusions.map((item) => (
              <li class="flex items-start gap-3 text-dusk-700">
                <X size={16} class="text-dusk-400 flex-shrink-0 mt-1" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-safari-900 text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-15">
      <Image
        src={tazamaImages.cta}
        alt="Mountain landscape background"
        width={1920}
        height={1080}
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-safari-900 via-safari-900/95 to-safari-900"></div>

    <div class="container-content relative z-10">
      <div class="max-w-3xl mx-auto text-center">
        <p class="eyebrow text-savannah-300 mb-3">Ready to climb?</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight mb-5">
          Plan your {trek.data.title.toLowerCase()}
        </h2>
        <p class="text-lg text-dusk-100/90 mb-8">
          Tell us your dates and group size. We'll send a full quote within 24 hours, including gear list, sample schedule, and what to expect on the mountain.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={`/contact?trek=${trek.id}`} class="btn btn-primary px-8 py-3.5">
            Get a custom quote
            <ArrowRight size={16} />
          </a>
          {route && (
            <a href={`/kilimanjaro/${route.id}`} class="btn btn-outline-light px-8 py-3.5 border-white/30 hover:bg-white hover:text-safari-900">
              About the route
            </a>
          )}
        </div>
      </div>
    </div>
  </section>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(withPublisher({
    '@context': 'https://schema.org',
    '@type': 'TouristAttraction',
    name: trek.data.title,
    description: trek.data.summary,
    image: trek.data.hero,
    address: {
      '@type': 'PostalAddress',
      addressCountry: 'TZ',
      addressRegion: 'Kilimanjaro',
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: -3.0674,
      longitude: 37.3556,
    },
  }))} />
</PublicLayout>
