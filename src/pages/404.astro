---
import PublicLayout from '@/layouts/PublicLayout.astro';
import { Compass, MapPin, Mail, ArrowRight, Phone, MessageCircle } from '@lucide/astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const tours = await getCollection('tours');
const featuredTours = tours
  .filter((t) => t.data.featured)
  .slice(0, 3);

const popularLinks = [
  { label: 'All Safaris', href: '/tours', desc: 'Browse our complete safari collection' },
  { label: 'Kilimanjaro Climbs', href: '/tours?type=kilimanjaro', desc: 'Machame, Lemosho, Marangu & Rongai routes' },
  { label: 'Zanzibar Holidays', href: '/tours?type=zanzibar', desc: 'Beach escapes & island tours' },
  { label: 'Plan a Custom Safari', href: '/contact', desc: 'Tell us what you want to see' },
];
---

<PublicLayout
  title="Page Not Found | Springbok Expeditions"
  description="The page you're looking for doesn't exist. Explore our safaris, Kilimanjaro climbs, and Zanzibar holidays instead."
  noindex={true}
  transparentHeader={true}
>
  <!-- Hero -->
  <section class="relative bg-safari-900 text-white overflow-hidden">
    <div class="absolute inset-0 z-0">
      <Image
        src="https://images.unsplash.com/photo-1547471080-7cc2caa01a7e?w=1920&q=80&auto=format&fit=crop"
        alt="Safari landscape at golden hour"
        width={1920}
        height={1080}
        class="w-full h-full object-cover opacity-50"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-br from-safari-900/80 via-safari-900/60 to-safari-900/80"></div>
    </div>

    <div class="container-content relative z-10 py-24 md:py-32 text-center">
      <div class="inline-flex items-center gap-2 bg-savannah-500/20 border border-savannah-500/30 text-savannah-300 px-4 py-1.5 rounded-full text-sm font-medium mb-6">
        <Compass size={14} /> 404 · Off the Beaten Path
      </div>

      <p class="text-display-2xl md:text-display-3xl font-display font-medium tracking-tight text-safari-100 mb-4">
        4<span class="text-savannah-500">0</span>4
      </p>

      <h1 class="text-3xl md:text-5xl font-display font-medium text-white mb-6 max-w-2xl mx-auto">
        Looks like that trail doesn't lead anywhere
      </h1>

      <p class="text-lg text-dusk-200 max-w-xl mx-auto mb-10">
        The page you were looking for has moved, been retired, or never existed.
        But Tanzania is full of paths worth following - let's get you back on one.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/" class="btn btn-primary">
          <MapPin size={16} />
          Back to Home
        </a>
        <a href="/tours" class="btn bg-white/10 hover:bg-white/20 text-white border border-white/20">
          Browse Safaris
          <ArrowRight size={16} />
        </a>
      </div>
    </div>
  </section>

  <!-- Quick links -->
  <section class="py-16 md:py-20 bg-dusk-50">
    <div class="container-content">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-display font-medium text-safari-900 mb-3">
          Try one of these instead
        </h2>
        <p class="text-dusk-600">
          Most travelers end up starting their safari research in one of these four places.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-4xl mx-auto">
        {popularLinks.map((link) => (
          <a
            href={link.href}
            class="group bg-white rounded-2xl p-6 border border-dusk-100 hover:border-savannah-500 hover:shadow-soft transition-all"
          >
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="font-display text-lg font-medium text-safari-900 group-hover:text-savannah-700 transition-colors mb-1">
                  {link.label}
                </h3>
                <p class="text-sm text-dusk-600">{link.desc}</p>
              </div>
              <ArrowRight size={20} class="text-dusk-300 group-hover:text-savannah-500 group-hover:translate-x-1 transition-all shrink-0" />
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured tours (only show if we have any) -->
  {featuredTours.length > 0 && (
    <section class="py-16 md:py-20 bg-white">
      <div class="container-content">
        <div class="text-center mb-10">
          <h2 class="text-3xl md:text-4xl font-display font-medium text-safari-900 mb-3">
            Or start with one of our most-loved safaris
          </h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {featuredTours.map((tour) => (
            <a
              href={`/tours/${tour.id}`}
              class="group bg-white rounded-2xl overflow-hidden border border-dusk-100 hover:shadow-soft transition-all"
            >
              <div class="aspect-[4/3] overflow-hidden">
                <Image
                  src={tour.data.hero}
                  alt={tour.data.title}
                  width={600}
                  height={450}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              </div>
              <div class="p-5">
                <h3 class="font-display text-lg font-medium text-safari-900 group-hover:text-savannah-700 transition-colors mb-2">
                  {tour.data.title}
                </h3>
                <p class="text-sm text-dusk-600 line-clamp-2 mb-3">{tour.data.excerpt}</p>
                <p class="text-safari-900 font-semibold">
                  {tour.data.durationDays} {tour.data.durationDays === 1 ? 'day' : 'days'}
                </p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Contact CTA -->
  <section class="py-16 md:py-20 bg-safari-900 text-white">
    <div class="container-content text-center">
      <h2 class="text-3xl md:text-4xl font-display font-medium text-white mb-4">
        Still can't find what you're looking for?
      </h2>
      <p class="text-dusk-300 text-lg max-w-2xl mx-auto mb-8">
        Our team is based in Arusha and we reply to every message - usually within a few hours.
        Tell us what kind of trip you have in mind and we'll design it.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/contact" class="btn btn-primary">
          <Mail size={16} />
          Send Us a Message
        </a>
        <a
          href="https://wa.me/255784136616"
          target="_blank"
          rel="noopener"
          class="btn bg-[#1B8750] hover:bg-[#127140] text-white"
        >
          <MessageCircle size={16} />
          Chat on WhatsApp
        </a>
        <a href="tel:+255784136616" class="btn bg-white/10 hover:bg-white/20 text-white border border-white/20">
          <Phone size={16} />
          +255 784 136 616
        </a>
      </div>
    </div>
  </section>
</PublicLayout>
