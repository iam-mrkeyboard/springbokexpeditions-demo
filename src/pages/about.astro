---
import PublicLayout from '@/layouts/PublicLayout.astro';
import { Compass, Heart, Users, Globe, MapPin, Calendar, ArrowRight, Shield, Sparkles } from '@lucide/astro';
import { getCollection } from 'astro:content';

const tours = await getCollection('tours');
const featuredTours = tours.filter((t) => t.data.featured).slice(0, 3);

const stats = [
  { value: '15+', label: 'Years Guiding', sublabel: 'In Tanzania since 2010' },
  { value: '2,400+', label: 'Happy Travelers', sublabel: 'From 60+ countries' },
  { value: '98%', label: '5-Star Reviews', sublabel: 'On TripAdvisor & Google' },
  { value: '100%', label: 'Local-Owned', sublabel: 'Arusha-headquartered' },
];

const values = [
  {
    icon: Heart,
    title: 'Travel That Gives Back',
    body: 'A portion of every booking supports local schools, anti-poaching units, and Maasai community projects. We don\'t just visit — we contribute.',
  },
  {
    icon: Users,
    title: 'Real Local Guides',
    body: 'Our guides grew up here. Many hold advanced certifications from the Kenya/Tanzania Professional Safari Guides Association, and all speak English, Swahili, and at least one other language.',
  },
  {
    icon: Shield,
    title: 'Fair Pricing, No Gimmicks',
    body: 'Quoted prices are final. No "park fees added later" surprises, no commission-loaded commissions. The price you see is the price you pay.',
  },
  {
    icon: Sparkles,
    title: 'Tailored, Not Templated',
    body: 'Every itinerary is a starting point. Tell us your travel style, pace, and dreams, and we\'ll reshape any tour to fit you — at no extra design fee.',
  },
];

const team = [
  { name: 'Daniel Mwakikoti', role: 'Founder & Lead Guide', bio: 'Born and raised in Arusha. 18 years guiding across the Serengeti, Ngorongoro, and Kilimanjaro.' },
  { name: 'Grace Mwangi', role: 'Operations Director', bio: 'Keeps every booking running smoothly. Former lodge manager at Tarangire Tented Camps.' },
  { name: 'Joseph Laizer', role: 'Senior Mountain Guide', bio: 'Led 200+ Kilimanjaro summits. Wilderness First Responder and UIAGM certified.' },
  { name: 'Amina Hassan', role: 'Cultural Tours Coordinator', bio: 'Maasai heritage and community-based tourism specialist. Builds our village visits from the ground up.' },
];
---

<PublicLayout
  title="About Springbok Expeditions | Local Tanzanian Safari Operator"
  description="Meet the locally-owned Arusha tour operator behind Springbok Expeditions. 15+ years guiding safaris, Kilimanjaro climbs, and Zanzibar holidays with fair pricing and real local guides."
  transparentHeader={true}
>
  <!-- Hero -->
  <section class="relative h-[85vh] min-h-[600px] w-full overflow-hidden bg-safari-900 text-white">
    <div class="absolute inset-0 z-0 overflow-hidden bg-safari-900">
      <img
        src="https://images.unsplash.com/photo-1516426122078-c23e76319801?w=1920&q=80&auto=format&fit=crop"
        alt=""
        class="absolute inset-0 w-full h-full object-cover scale-105"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-tr from-black/85 via-black/45 to-black/20"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-black/40"></div>
    </div>

    <div class="container-content relative z-10 h-full flex flex-col justify-end pb-16 md:pb-20 pt-32">
      <div class="max-w-3xl">
        <p class="eyebrow text-savannah-300 text-[11px] md:text-xs uppercase tracking-[0.18em] mb-3">About Us</p>
        <h1 class="font-display text-[2.6rem] sm:text-6xl md:text-7xl lg:text-display-lg font-medium tracking-tight text-white mb-5 md:mb-6">
          Experience the Wild,<br />
          <span class="italic font-normal text-savannah-300">Explore the Extraordinary.</span>
        </h1>
        <p class="text-lg md:text-xl text-dusk-100/90 max-w-2xl leading-relaxed font-light mb-8">
          We are passionate storytellers of Tanzania's breathtaking landscapes, rich cultures, and unforgettable wildlife encounters.
        </p>
      </div>
    </div>
  </section>

  <!-- Who We Are -->
  <section class="section bg-white">
    <div class="container-content">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="eyebrow mb-4">Who We Are</p>
          <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-5">
            A locally owned Tanzanian tour company
          </h2>
          <div class="prose prose-lg max-w-none text-dusk-700">
            <p>We are a locally owned and operated tour company, committed to responsible tourism that benefits local communities and conserves the natural beauty of Tanzania. Our team of expert guides, travel planners, and hospitality professionals ensures that every journey is seamless, exciting, and deeply enriching.</p>
            <p>We believe the best journeys happen when you travel with people who know the land by heart. That's why every itinerary is shaped by guides, planners, and hospitality professionals who live here — people who grew up beneath these skies, walked these trails, and know the rhythms of the bush.</p>
            <p>Today we're still locally owned. Still based in Arusha, the heart of Northern Tanzania. Still answering our own emails and answering our own phones. We've grown, but we haven't lost the part that matters: every booking gets a real human reply, usually within a few hours, from someone who has walked the trails you're asking about.</p>
          </div>
        </div>
        <div>
          <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-lifted">
            <img
              src="https://images.unsplash.com/photo-1547471080-7cc2caa01a7e?w=1200&q=80&auto=format&fit=crop"
              alt="Safari vehicle on the plains at golden hour"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Travel With Us -->
  <section class="section bg-safari-50">
    <div class="container-wide">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="eyebrow mb-4">Why Travel With Us</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-4">
          Four reasons travelers choose us
        </h2>
        <p class="text-dusk-600 text-lg">
          We don't just offer tours — we create unforgettable experiences.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <a href="#" class="card card-hover p-7 group block">
          <div class="w-14 h-14 rounded-2xl bg-savannah-100 flex items-center justify-center mb-5 group-hover:bg-savannah-500 transition-colors">
            <Compass size={26} class="text-savannah-700 group-hover:text-white transition-colors" />
          </div>
          <h3 class="font-display text-xl font-medium text-safari-900 mb-2">Expertly Curated Safaris</h3>
          <p class="text-sm text-dusk-700 leading-relaxed mb-4">Whether it's the Great Migration in the Serengeti, the majestic Ngorongoro Crater, or trekking Mount Kilimanjaro, we provide tailor-made experiences that match your travel style.</p>
          <span class="inline-flex items-center gap-1.5 text-sm font-medium text-savannah-700 group-hover:text-sunset-500 transition-colors">
            Learn more
            <ArrowRight size={14} class="transition-transform group-hover:translate-x-1" />
          </span>
        </a>
        <a href="#" class="card card-hover p-7 group block">
          <div class="w-14 h-14 rounded-2xl bg-savannah-100 flex items-center justify-center mb-5 group-hover:bg-savannah-500 transition-colors">
            <Users size={26} class="text-savannah-700 group-hover:text-white transition-colors" />
          </div>
          <h3 class="font-display text-xl font-medium text-safari-900 mb-2">Local Expertise</h3>
          <p class="text-sm text-dusk-700 leading-relaxed mb-4">Our guides are highly knowledgeable about Tanzania's wildlife, history, and hidden gems. They grew up here and hold advanced certifications from professional guide associations.</p>
          <span class="inline-flex items-center gap-1.5 text-sm font-medium text-savannah-700 group-hover:text-sunset-500 transition-colors">
            Learn more
            <ArrowRight size={14} class="transition-transform group-hover:translate-x-1" />
          </span>
        </a>
        <a href="#" class="card card-hover p-7 group block">
          <div class="w-14 h-14 rounded-2xl bg-savannah-100 flex items-center justify-center mb-5 group-hover:bg-savannah-500 transition-colors">
            <Sparkles size={26} class="text-savannah-700 group-hover:text-white transition-colors" />
          </div>
          <h3 class="font-display text-xl font-medium text-safari-900 mb-2">Sustainable &amp; Ethical Travel</h3>
          <p class="text-sm text-dusk-700 leading-relaxed mb-4">We support local communities and conservation efforts, ensuring responsible tourism. A portion of every booking supports local schools, anti-poaching units, and Maasai community projects.</p>
          <span class="inline-flex items-center gap-1.5 text-sm font-medium text-savannah-700 group-hover:text-sunset-500 transition-colors">
            Learn more
            <ArrowRight size={14} class="transition-transform group-hover:translate-x-1" />
          </span>
        </a>
        <a href="#" class="card card-hover p-7 group block">
          <div class="w-14 h-14 rounded-2xl bg-savannah-100 flex items-center justify-center mb-5 group-hover:bg-savannah-500 transition-colors">
            <Sparkles size={26} class="text-savannah-700 group-hover:text-white transition-colors" />
          </div>
          <h3 class="font-display text-xl font-medium text-safari-900 mb-2">Personalized Service</h3>
          <p class="text-sm text-dusk-700 leading-relaxed mb-4">Whether you prefer luxury lodges or off-the-grid adventures, we design trips that suit your budget and preferences — at no extra design fee.</p>
          <span class="inline-flex items-center gap-1.5 text-sm font-medium text-savannah-700 group-hover:text-sunset-500 transition-colors">
            Learn more
            <ArrowRight size={14} class="transition-transform group-hover:translate-x-1" />
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-16 md:py-20">
    <div class="container-content">
      <div class="max-w-2xl mx-auto text-center mb-12">
        <div class="inline-flex items-center gap-2 text-savannah-700 text-sm font-semibold tracking-wider uppercase mb-3">
          <span class="w-8 h-px bg-savannah-500"></span> The Team
        </div>
        <h2 class="text-display-sm md:text-display-md font-display font-medium text-safari-900 mb-4">
          The people behind your safari
        </h2>
        <p class="text-lg text-dusk-600">
          A small core team, plus a wider network of 20+ guides, drivers, and lodge staff who help make every trip work.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {team.map((member) => (
          <div class="bg-white rounded-2xl p-6 border border-dusk-100 text-center">
            <div class="w-20 h-20 rounded-full bg-gradient-to-br from-safari-700 to-safari-500 text-safari-100 flex items-center justify-center font-display text-2xl font-medium mx-auto mb-4">
              {member.name.split(' ').map(n => n[0]).join('').slice(0, 2)}
            </div>
            <h3 class="font-display text-lg font-medium text-safari-900 mb-1">{member.name}</h3>
            <p class="text-sm text-savannah-700 font-medium mb-3">{member.role}</p>
            <p class="text-sm text-dusk-600 leading-relaxed">{member.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Where we operate -->
  <section class="py-16 md:py-20 bg-safari-900 text-white">
    <div class="container-content">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 text-savannah-300 text-sm font-semibold tracking-wider uppercase mb-3">
            <Globe size={14} /> Where We Operate
          </div>
          <h2 class="text-display-sm md:text-display-md font-display font-medium text-white mb-6">
            Tanzania — and only Tanzania
          </h2>
          <p class="text-lg text-dusk-200 leading-relaxed mb-6">
            We don't do Kenya, Botswana, or South Africa. We do Tanzania, and we do it deeply. Every guide has worked the
            Serengeti, climbed Kilimanjaro, and traveled the back roads of Zanzibar. That focus is the whole reason we can
            deliver what bigger operators can't.
          </p>
          <div class="flex flex-wrap gap-2">
            {['Serengeti', 'Ngorongoro', 'Tarangire', 'Lake Manyara', 'Kilimanjaro', 'Mount Meru', 'Zanzibar', 'Pemba', 'Mahale', 'Selous', 'Ruaha', 'Katavi'].map((place) => (
              <span class="bg-safari-800/60 border border-safari-700 text-dusk-200 px-3 py-1 rounded-full text-sm">
                {place}
              </span>
            ))}
          </div>
        </div>
        <div class="bg-safari-800/50 rounded-2xl p-8 border border-safari-700">
          <h3 class="font-display text-2xl font-medium text-white mb-6">Quick Facts</h3>
          <dl class="space-y-4">
            {[
              { dt: 'Founded', dd: '2010, Arusha, Tanzania' },
              { dt: 'Headquarters', dd: 'Sokoine Drive, Arusha' },
              { dt: 'Registration', dd: 'TATO member · TZ tourism licensed' },
              { dt: 'Insurance', dd: 'Fully insured vehicles + AMREF Flying Doctors evacuation cover on every safari' },
              { dt: 'Languages', dd: 'English, Swahili, French, German, Spanish, Italian' },
              { dt: 'Vehicles', dd: 'Toyota Land Cruisers (4x4) with pop-top roofs' },
            ].map((row) => (
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-2 pb-3 border-b border-safari-700 last:border-0 last:pb-0">
                <dt class="text-dusk-400 text-sm font-medium">{row.dt}</dt>
                <dd class="text-dusk-100 sm:col-span-2">{row.dd}</dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured tours CTA -->
  {featuredTours.length > 0 && (
    <section class="py-16 md:py-20 bg-white">
      <div class="container-content">
        <div class="text-center mb-10">
          <h2 class="text-display-sm md:text-display-md font-display font-medium text-safari-900 mb-3">
            Ready to travel with us?
          </h2>
          <p class="text-lg text-dusk-600 max-w-2xl mx-auto">
            Start with one of our most-loved safaris, or design your own from scratch.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
          {featuredTours.map((tour) => (
            <a href={`/tours/${tour.id}`} class="group bg-white rounded-2xl overflow-hidden border border-dusk-100 hover:shadow-soft transition-all">
              <div class="aspect-[4/3] overflow-hidden">
                <img
                  src={tour.data.hero}
                  alt={tour.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              </div>
              <div class="p-5">
                <h3 class="font-display text-lg font-medium text-safari-900 group-hover:text-savannah-700 transition-colors mb-2">
                  {tour.data.title}
                </h3>
                <p class="text-sm text-dusk-600 line-clamp-2 mb-3">{tour.data.excerpt}</p>
                <p class="text-safari-900 font-semibold">
                  {tour.data.durationDays} {tour.data.durationDays === 1 ? 'day' : 'days'}
                </p>
              </div>
            </a>
          ))}
        </div>
        <div class="text-center">
          <a href="/contact" class="btn btn-primary">
            <Calendar size={16} />
            Plan Your Trip With Us
            <ArrowRight size={16} />
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Contact CTA -->
  <section class="py-16 md:py-20 bg-dusk-50">
    <div class="container-content text-center">
      <h2 class="text-display-sm md:text-display-md font-display font-medium text-safari-900 mb-4">
        Got a question? Want to design your trip?
      </h2>
      <p class="text-lg text-dusk-600 max-w-2xl mx-auto mb-8">
        Send us a message, or chat on WhatsApp. We reply to every enquiry — usually within a few hours.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/contact" class="btn btn-primary">
          <MapPin size={16} />
          Contact Us
        </a>
        <a href="/tours" class="btn btn-outline">
          Browse All Safaris
          <ArrowRight size={16} />
        </a>
      </div>
    </div>
  </section>
</PublicLayout>
