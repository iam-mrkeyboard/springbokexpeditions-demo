---
import { getCollection } from 'astro:content';
import PublicLayout from '../layouts/PublicLayout.astro';
import Hero from '../components/home/Hero.astro';
import Features from '../components/home/Features.astro';
import FeaturedTours from '../components/home/FeaturedTours.astro';
import Destinations from '../components/home/Destinations.astro';
import Testimonials from '../components/home/Testimonials.astro';
import WhyUs from '../components/home/WhyUs.astro';
import Seasons from '../components/home/Seasons.astro';
import MigrationVideo from '../components/home/MigrationVideo.astro';
import TrekkingVideo from '../components/home/TrekkingVideo.astro';
import ZanzibarVideo from '../components/home/ZanzibarVideo.astro';
import { siteInfo, absoluteUrl } from '../lib/site';
import { organizationJsonLd, websiteId, organizationId } from '../lib/jsonld';

const orgGraph = {
  ...organizationJsonLd(),
  '@graph': [
    ...organizationJsonLd()['@graph'],
    {
      '@type': 'WebSite',
      '@id': websiteId,
      url: absoluteUrl('/'),
      name: siteInfo.name,
      inLanguage: 'en',
      publisher: { '@id': organizationId },
    },
    {
      '@type': 'LocalBusiness',
      '@id': absoluteUrl('/#localbusiness'),
      name: siteInfo.name,
      image: absoluteUrl('/logo.png'),
      telephone: siteInfo.phone,
      email: siteInfo.email,
      address: {
        '@type': 'PostalAddress',
        streetAddress: siteInfo.address.street,
        addressLocality: siteInfo.address.city,
        addressCountry: siteInfo.address.countryCode,
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: siteInfo.geo.latitude,
        longitude: siteInfo.geo.longitude,
      },
      parentOrganization: { '@id': organizationId },
    },
  ],
};

// Featured tours - dynamically loaded from MDX, sorted by featured flag then publishedAt
const allTours = await getCollection('tours');

const typeLabels: Record<string, string> = {
  safari: 'Wildlife Safari',
  kilimanjaro: 'Kilimanjaro Climb',
  meru: 'Mount Meru',
  zanzibar: 'Zanzibar',
  'day-trip': 'Day Trip',
  honeymoon: 'Honeymoon',
  family: 'Family',
  cultural: 'Cultural',
  migration: 'Migration',
};

const featuredTours = allTours
  .filter((t) => t.data.featured)
  .sort((a, b) => new Date(b.data.publishedAt ?? '').getTime() - new Date(a.data.publishedAt ?? '').getTime())
  .slice(0, 8)
  .map((tour) => ({
    slug: tour.id,
    title: tour.data.title,
    durationDays: tour.data.durationDays,
    summary: tour.data.excerpt,
    hero: tour.data.hero,
    destination: tour.data.destinations[0]?.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase()) || 'Tanzania',
    type: tour.data.type,
    typeLabel: typeLabels[tour.data.type] || tour.data.type,
    styles: tour.data.styles,
    badges: tour.data.badges || [],
  }));
---

<PublicLayout
  title="Premium Tanzania Safaris & Kilimanjaro Climbs"
  description="Locally-owned Tanzanian tour operator crafting unforgettable safaris, Kilimanjaro climbs, and Zanzibar beach holidays. 15+ years experience, expert guides, sustainable travel."
  ogImage="/og/index.png"
  transparentHeader={true}
>
  <Hero />
  <Features />
  <FeaturedTours tours={featuredTours} />
  <MigrationVideo />
  <Destinations />
  <TrekkingVideo />
  <WhyUs />
  <Testimonials />
  <ZanzibarVideo />
  <Seasons />

  <script is:inline type="application/ld+json" set:html={JSON.stringify(orgGraph)} slot="head" />
</PublicLayout>
