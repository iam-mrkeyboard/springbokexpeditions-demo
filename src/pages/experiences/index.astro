---
import PublicLayout from '@/layouts/PublicLayout.astro';
import { getCollection } from 'astro:content';
import { ArrowRight, Heart, Tent, Camera, Sparkles, Trees, Users, MapPin, UtensilsCrossed, Ship, Sun, Moon, Star, Bird, Wind } from '@lucide/astro';
import { withPublisher } from '@/lib/jsonld';
import { Image } from 'astro:assets';

const experiences = (await getCollection('activities'))
  .sort((a, b) => ((a.data as any).order as number) - ((b.data as any).order as number));

const allTours = await getCollection('tours');
const allTourCount = allTours.length;

const iconMap: Record<string, typeof Heart> = {
  Heart, Tent, Camera, Sparkles, Trees, Users, MapPin, UtensilsCrossed, Ship, Sun, Moon, Star, Bird, Wind,
};

const experienceStats = [
  { value: '8', label: 'Safari activities' },
  { value: `${allTourCount}+`, label: 'Ready-made tours' },
  { value: '24 hr', label: 'Quote turnaround' },
  { value: '100%', label: 'Private guides' },
];

const monthOrder = [
  'January', 'February', 'March', 'April', 'May', 'June',
  'July', 'August', 'September', 'October', 'November', 'December',
];
const monthShort = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const monthMap: Record<string, string> = Object.fromEntries(monthOrder.map((m, i) => [m, monthShort[i]]));

function expRating(exp: typeof experiences[number], month: string): 'high' | 'med' | 'low' {
  return exp.data.bestMonths.includes(month) ? 'high' : 'low';
}
const monthColorMap: Record<'high' | 'med' | 'low', string> = {
  high: 'bg-safari-600 text-white border-safari-700',
  med: 'bg-savannah-200 text-savannah-900 border-savannah-300',
  low: 'bg-dusk-100 text-dusk-700 border-dusk-200',
};

const howItWorks = [
  {
    step: '01',
    title: 'Tell us what you want',
    body: 'When you travel, who you are travelling with, what kind of experience you are looking for, and any must-do moments. Most people start with a phone call or a short form.',
  },
  {
    step: '02',
    title: 'We draft a route',
    body: 'Within 24 hours, we send a written itinerary with a map, the lodges, the prices, and what is and is not included. No pressure, no deposit until you are ready.',
  },
  {
    step: '03',
    title: 'You refine it',
    body: 'Most trips take two or three drafts. Add a Zanzibar finish, swap a lodge, push the dates, drop a day - we adjust until it is right.',
  },
  {
    step: '04',
    title: 'We book it',
    body: 'When you are happy, we confirm everything with the lodges and the parks, send the booking pack, and you are good to go. Our office is open 24/7 while you are travelling.',
  },
];

const faqs = [
  {
    q: 'Are these fixed packages?',
    a: 'No. Every itinerary we send is built from scratch around your dates, group size, and what you want to come home with. The experiences here are starting points - not menus.',
  },
  {
    q: 'How long does a Tanzania trip usually take?',
    a: 'A classic northern-circuit safari is 7 to 10 days. With Kilimanjaro added, 12 to 14 days. With Zanzibar added, 10 to 14 days. The longest trips we plan are around 21 days, often combining the safari circuit, the southern parks, and the coast.',
  },
  {
    q: 'Do you handle international flights?',
    a: 'No - we are a ground operator. We can recommend flight options and routes, and we will meet you at the airport, but we leave the booking of your international flights to you or your travel agent.',
  },
  {
    q: 'What is the booking process?',
    a: 'A 30% deposit secures the trip. The balance is due 60 days before arrival. We accept bank transfer and major credit cards (with a 2% processing fee).',
  },
  {
    q: 'Can I pay in instalments?',
    a: 'Yes. The deposit is 30%, the balance is 60 days before arrival, but you can pay in as many instalments as you like between booking and the balance date.',
  },
  {
    q: 'What if I have to cancel?',
    a: 'Our standard cancellation terms are on the booking form. In short: more than 60 days out, the deposit is refundable minus bank charges. Within 60 days, the deposit is non-refundable but we will try to move the booking to new dates at no extra cost. We strongly recommend travel insurance.',
  },
];
---

<PublicLayout
  title="Tanzania Safari Activities & Experiences - Hot Air Balloon, Walking Safaris & More"
  description="Seven ways to enhance your Tanzania safari: hot air balloon flights, walking safaris, cultural tours, night game drives, and more. Customize your perfect itinerary."
  transparentHeader={true}
>
  <!-- Hero -->
  <section class="relative h-[65vh] min-h-[460px] md:h-[80vh] md:min-h-[600px] lg:h-screen lg:min-h-[750px] w-full overflow-hidden bg-safari-900 text-white">
    <Image
      src="https://res.cloudinary.com/wqmnkfgf/image/upload/q_auto,f_auto/v1784554900/springbokexpeditions/images/photo-1516426122078-c23e76319801.jpg"
      alt="Tanzania safari at sunset"
      width={1920}
      height={1080}
      class="absolute inset-0 w-full h-full object-cover"
      style={{ objectPosition: 'center 30%' }}
      loading="eager"
      fetchpriority="high"
    />
    <!-- Single gradient overlay for readability and image vividness -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-black/15"></div>

    <div class="container-content relative z-10 h-full flex flex-col justify-end pb-16 md:pb-20 pt-32">
      <div class="max-w-3xl">
        <p class="eyebrow text-savannah-300 text-[11px] md:text-xs uppercase tracking-[0.18em] mb-3">Safari Activities & Enhancements</p>

        <h1 class="font-display text-[2.6rem] sm:text-6xl md:text-7xl lg:text-display-lg font-medium tracking-tight text-white mb-5 md:mb-6">
          Seven ways to<br />
          <span class="italic font-normal text-savannah-300">experience Tanzania.</span>
        </h1>

        <p class="text-lg md:text-xl text-dusk-100/90 max-w-2xl leading-relaxed font-light mb-0">
          Make your safari unforgettable. Enhance your journey with our seven standalone activities - from soaring in a hot air balloon at sunrise to tracking wildlife on foot with armed rangers.
        </p>
      </div>
    </div>
  </section>

  <!-- Trust strip -->
  <section class="bg-safari-900 text-white border-t border-white/10">
    <div class="container-content py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        {experienceStats.map((s) => (
          <div>
            <p class="font-display text-3xl md:text-4xl text-savannah-300">{s.value}</p>
            <p class="text-xs uppercase tracking-[0.18em] text-dusk-300 mt-1">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Experience grid -->
  <section id="experiences" class="section bg-dusk-50">
    <div class="container-content">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="eyebrow text-safari-600 mb-3">Activities</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-4">
          Seven ways to enhance your safari
        </h2>
        <p class="text-dusk-700 leading-relaxed">
          Add unique experiences to your custom travel plan. Choose from the activities below to make your adventure truly your own.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {experiences.map((exp) => {
          const Icon = iconMap[exp.data.icon ?? ''] ?? Sparkles;
          return (
            <a
              href={`/experiences/${exp.id}`}
              class="group relative overflow-hidden rounded-2xl bg-white border border-dusk-100 hover:border-safari-300 hover:shadow-md transition-all duration-300 flex flex-col"
            >
              <div class="aspect-[5/3] overflow-hidden bg-dusk-200 relative">
                <Image
                  src={exp.data.hero || ''}
                  alt={exp.data.name}
                  width={600}
                  height={360}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                  loading="lazy"
                  decoding="async"
                />
                <!-- Top Left Duration Badge -->
                <div class="absolute top-3 left-3 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-white/95 backdrop-blur text-[9px] uppercase tracking-wider text-safari-800 font-bold shadow-sm">
                  <Icon size={11} class="text-safari-600" />
                  {exp.data.duration}
                </div>
                <!-- Top Right Location Badge -->
                <div class="absolute top-3 right-3 inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-black/60 backdrop-blur text-[9px] uppercase tracking-wider text-white font-medium shadow-sm">
                  <MapPin size={10} class="text-savannah-300" />
                  {exp.data.location}
                </div>
              </div>
              <div class="p-6 flex flex-col flex-1">
                <h3 class="font-display text-xl text-safari-900 mb-2 group-hover:text-safari-700 transition-colors">
                  {exp.data.name}
                </h3>
                <p class="text-xs text-dusk-500 leading-relaxed mb-4 font-light">
                  {exp.data.tagline}
                </p>
                <ul class="space-y-2 mb-5 flex-1 border-t border-dusk-50 pt-4">
                  {exp.data.highlights.slice(0, 3).map((h: string) => (
                    <li class="flex items-start gap-2 text-xs text-dusk-600">
                      <span class="w-1 h-1 rounded-full bg-savannah-500 flex-shrink-0 mt-1.5"></span>
                      <span class="line-clamp-1 font-light">{h}</span>
                    </li>
                  ))}
                </ul>
                <div class="flex items-center justify-between pt-4 border-t border-dusk-100">
                  <span class="inline-flex items-center gap-1 text-safari-700 group-hover:text-safari-900 text-xs font-semibold transition-colors">
                    Explore Activity
                    <ArrowRight size={12} />
                  </span>
                  <span class="text-xs font-bold text-savannah-700 bg-savannah-50 px-2 py-0.5 rounded">
                    {exp.data.pricingLevel ?? '$$'}
                  </span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- When to go -->
  <section class="section bg-white">
    <div class="container-content">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="eyebrow text-safari-600 mb-3">When to go</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-4">
          Best time of year for each experience
        </h2>
        <p class="text-dusk-700 leading-relaxed">
          Most of our experiences work year-round, but the timing changes what you will see. The dry season (June–October) is best for big game and the migration; the wet season (November–April) is best for birding and the calving.
        </p>
      </div>

      <div class="overflow-x-auto">
        <div class="inline-block min-w-full">
          <div class="grid gap-2" style="grid-template-columns: minmax(180px, 240px) repeat(12, minmax(56px, 1fr));">
            <div></div>
            {monthOrder.map((m) => (
              <div class="text-center text-[10px] uppercase tracking-wider text-dusk-500 font-semibold">
                {monthMap[m]}
              </div>
            ))}
          </div>

          {experiences.map((exp) => {
            const Icon = iconMap[exp.data.icon ?? ''] ?? Sparkles;
            return (
              <div class="grid gap-2 mt-2" style="grid-template-columns: minmax(180px, 240px) repeat(12, minmax(56px, 1fr));">
                <div class="flex items-center gap-2 px-3 py-2">
                  <Icon size={14} class="text-safari-600 flex-shrink-0" />
                  <span class="text-sm font-medium text-safari-900 truncate">{exp.data.name}</span>
                </div>
                {monthOrder.map((m) => {
                  const rating = expRating(exp, m);
                  return (
                    <div class={`rounded-md border text-center py-2 text-[10px] uppercase tracking-wider font-semibold ${monthColorMap[rating]}`}>
                      {rating === 'high' ? 'Peak' : ' - '}
                    </div>
                  );
                })}
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section bg-dusk-50">
    <div class="container-content">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="eyebrow text-safari-600 mb-3">How we work</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-4">
          From first call to first game drive
        </h2>
        <p class="text-dusk-700 leading-relaxed">
          We are a small team in Arusha, and every trip is built by one of us - not a website form and not a call centre. Here is what to expect.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {howItWorks.map((step) => (
          <div class="bg-white rounded-2xl border border-dusk-100 p-6">
            <p class="font-display text-3xl text-savannah-300 mb-3">{step.step}</p>
            <h3 class="font-display text-xl text-safari-900 mb-3">{step.title}</h3>
            <p class="text-sm text-dusk-600 leading-relaxed">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="section bg-white">
    <div class="container-content max-w-3xl">
      <div class="text-center mb-12">
        <p class="eyebrow text-safari-600 mb-3">Common questions</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900">
          Booking and planning
        </h2>
      </div>

      <div class="space-y-3">
        {faqs.map((f) => (
          <details class="group bg-dusk-50 rounded-xl border border-dusk-100 overflow-hidden">
            <summary class="cursor-pointer list-none flex items-center justify-between gap-4 p-5 hover:bg-dusk-100 transition-colors">
              <h3 class="font-display text-base md:text-lg text-safari-900">{f.q}</h3>
              <span class="w-7 h-7 rounded-full bg-white border border-dusk-200 flex items-center justify-center flex-shrink-0 transition-transform group-open:rotate-45">
                <span class="w-3 h-3 relative block">
                  <span class="absolute top-1/2 left-0 w-full h-px bg-safari-900 -translate-y-1/2"></span>
                  <span class="absolute top-0 left-1/2 h-full w-px bg-safari-900 -translate-x-1/2"></span>
                </span>
              </span>
            </summary>
            <div class="px-5 pb-5 text-dusk-700 leading-relaxed">
              {f.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>



  <!-- JSON-LD -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(withPublisher({
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Tanzania Safari Experiences',
    itemListElement: experiences.map((exp, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `/experiences/${exp.id}`,
      name: exp.data.name,
    })),
  }))} />
</PublicLayout>
