---
import { getCollection } from 'astro:content';
import PublicLayout from '@/layouts/PublicLayout.astro';
import { withPublisher } from '@/lib/jsonld';
import {
  ArrowRight, Mountain, Users, Check, TrendingUp, Shield, HeartPulse,
  Tent, UtensilsCrossed, Stethoscope, Briefcase, Leaf, Droplets,
  Clock, Compass, MapPin, Star,
} from '@lucide/astro';

const routes = (await getCollection('kilimanjaro')).sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0)
);

const trafficLabel: Record<string, string> = {
  quiet: 'Quiet',
  moderate: 'Moderate',
  busy: 'Busy',
  'very-busy': 'Very busy',
};

const difficultyLabel: Record<string, string> = {
  moderate: 'Moderate',
  challenging: 'Challenging',
  strenuous: 'Strenuous',
  expert: 'Expert',
};

type SeasonRating = 'high' | 'med' | 'low';
const monthRatings: Record<string, SeasonRating> = {
  Jan: 'high', Feb: 'high', Mar: 'med',
  Apr: 'low', May: 'low', Jun: 'high',
  Jul: 'high', Aug: 'high', Sep: 'high',
  Oct: 'high', Nov: 'low', Dec: 'med',
};
const monthColorMap: Record<SeasonRating, string> = {
  high: 'bg-safari-600 text-white border-safari-700',
  med: 'bg-savannah-200 text-savannah-900 border-savannah-300',
  low: 'bg-dusk-100 text-dusk-500 border-dusk-200',
};

const allTreks = await getCollection('trekking');
const kilimanjaroTreks = allTreks
  .filter((t) => t.data.mountain === 'kilimanjaro')
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

const routeBlurb: Record<string, string> = {
  'lemosho': 'A remote western start through rainforest and the Shira Plateau. The most balanced blend of scenery, solitude, and acclimatization.',
  'machame': 'The classic southern circuit with the famous Barranco Wall. Dramatic, varied, and the most popular camping route.',
  'marangu': 'The only route with mountain huts. Gentler gradient but a steeper acclimatization curve — best for experienced trekkers short on time.',
  'rongai': 'The quiet northern approach near the Kenyan border. Drier conditions and a different perspective of the mountain.',
  'northern-circuit': 'The longest official route, circling the summit cone for unmatched acclimatization and the highest success rate.',
  'umbwe': 'A steep, direct, and demanding line up the southern forest. Recommended only for strong hikers comfortable with long days.',
};

const tazamaImages = {
  hero: 'https://images.pexels.com/photos/5109704/pexels-photo-5109704.jpeg?auto=compress&cs=tinysrgb&w=1920',
  cta: 'https://res.cloudinary.com/drhl0yu7y/image/upload/v1759133497/kilimanjaro/call-to-action/itinerary-cta-4_y8z4uu.jpg',
  scenery1: 'https://res.cloudinary.com/drhl0yu7y/image/upload/v1759229205/kilimanjaro/main-page/kilimanjaro19_lpdch6.webp',
  scenery2: 'https://res.cloudinary.com/drhl0yu7y/image/upload/v1759229199/kilimanjaro/main-page/kilimanjaro11_hyxmwe.webp',
  scenery3: 'https://res.cloudinary.com/drhl0yu7y/image/upload/v1759229197/kilimanjaro/main-page/kilimanjaro12_h4dou2.webp',
  scenery4: 'https://res.cloudinary.com/drhl0yu7y/image/upload/v1759229190/kilimanjaro/main-page/kilimanjaro4_wclu5t.webp',
};
---

<PublicLayout
  title="Climb Kilimanjaro — 7 Routes to the Roof of Africa"
  description="Plan your Mount Kilimanjaro climb with a local Arusha operator. Compare 6 routes, expert guides, high safety standards, and responsible trekking practices."
  ogImage="/og/kilimanjaro.png"
  transparentHeader={true}
>
  <!-- Hero -->
  <section class="relative h-[92vh] min-h-[700px] w-full overflow-hidden bg-safari-900 text-white">
    <img
      src={tazamaImages.hero}
      alt="Mount Kilimanjaro snow-capped peak above the clouds"
      class="absolute inset-0 w-full h-full object-cover scale-105"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-tr from-black/90 via-black/50 to-black/30"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-black/50"></div>

    <div class="container-content relative z-10 h-full flex flex-col justify-end pb-20 md:pb-28 pt-32">
      <div class="max-w-3xl">
        <p class="eyebrow text-savannah-300 text-[11px] md:text-xs uppercase tracking-[0.18em] mb-3">5,895m · 7 official routes · Uhuru Peak</p>

        <h1 class="font-display text-[3rem] sm:text-6xl md:text-7xl lg:text-[5.5rem] font-medium tracking-tight text-white mb-5 md:mb-6 leading-[1.05]">
          The Roof of<br />
          <span class="italic font-normal text-savannah-300">Africa Awaits.</span>
        </h1>

        <p class="text-lg md:text-xl text-dusk-100/90 max-w-2xl leading-relaxed font-light mb-8">
          Mount Kilimanjaro stands alone: the highest point on the continent and the tallest free-standing mountain on Earth. No ropes, no technical climbing — just determination, solid preparation, and the right team beside you.
        </p>

        <div class="flex flex-wrap gap-4">
          <a href="#routes" class="btn btn-primary px-7 py-3.5">
            Explore the routes
            <ArrowRight size={16} />
          </a>
          <a href="/contact?subject=kilimanjaro" class="btn btn-outline-light px-7 py-3.5 border-white/30 hover:bg-white hover:text-safari-900">
            Plan your ascent
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust strip -->
  <section class="bg-safari-900 text-white border-t border-white/10">
    <div class="container-content py-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <p class="font-display text-4xl md:text-5xl text-savannah-300">5,895m</p>
          <p class="text-xs uppercase tracking-[0.18em] text-dusk-300 mt-2">Uhuru Peak</p>
        </div>
        <div>
          <p class="font-display text-4xl md:text-5xl text-savannah-300">6</p>
          <p class="text-xs uppercase tracking-[0.18em] text-dusk-300 mt-2">Official routes</p>
        </div>
        <div>
          <p class="font-display text-4xl md:text-5xl text-savannah-300">98%</p>
          <p class="text-xs uppercase tracking-[0.18em] text-dusk-300 mt-2">Top route success</p>
        </div>
        <div>
          <p class="font-display text-4xl md:text-5xl text-savannah-300">5</p>
          <p class="text-xs uppercase tracking-[0.18em] text-dusk-300 mt-2">Climate zones</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Intro -->
  <section class="section bg-white">
    <div class="container-content">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="eyebrow text-safari-600 mb-4">The Mountain</p>
          <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-6">
            An icon that needs no introduction — yet rewards every question you ask of it.
          </h2>
          <div class="space-y-4 text-dusk-700 leading-relaxed text-lg">
            <p>
              Rising from the East African savanna, Kilimanjaro is more than a mountain. It is a vertical journey through five distinct climate zones, from humid rainforest to arctic summit, each with its own character and challenges.
            </p>
            <p>
              The beauty of climbing here is accessibility. You do not need prior mountaineering experience, ice axes, or rock-climbing skills. What you need is a steady level of fitness, a willingness to walk slowly, and a crew that knows how to keep you safe as the air thins.
            </p>
            <p>
              We are an Arusha-based operator. Our guides, porters, and chefs live within sight of the mountain. When you climb with us, you are not passed to a third party — you are looked after by a team that treats every ascent as its own.
            </p>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="space-y-4 mt-10">
            <div class="aspect-[3/4] rounded-2xl overflow-hidden shadow-lifted">
              <img
                src={tazamaImages.scenery2}
                alt="Kilimanjaro crater rim above the clouds"
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
          <div class="space-y-4">
            <div class="aspect-[3/4] rounded-2xl overflow-hidden shadow-lifted">
              <img
                src={tazamaImages.scenery3}
                alt="Trekkers on the Kilimanjaro summit ridge"
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Safety first -->
  <section class="section bg-safari-900 text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <img
        src={tazamaImages.scenery4}
        alt=""
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-safari-900 via-safari-900/95 to-safari-900"></div>

    <div class="container-content relative z-10">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center mb-16">
        <div>
          <p class="eyebrow text-savannah-300 mb-4">Safety First</p>
          <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight mb-5">
            Altitude is the real challenge. We treat it that way.
          </h2>
          <p class="text-dusk-200 text-lg leading-relaxed">
            The trails themselves are not extreme. What makes Kilimanjaro demanding is the thin air above 4,000 meters. That is why our entire operation is built around prevention, monitoring, and response — before a problem ever has a chance to develop.
          </p>
        </div>
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 md:p-8 backdrop-blur-sm">
          <ul class="space-y-4">
            {[
              'Twice-daily health checks: oxygen saturation, pulse, and hydration',
              'Wilderness First Responder certified guides trained in mountain rescue',
              'Portable oxygen and comprehensive medical kits on every climb',
              'Private portable toilets at every camp for hygiene and dignity',
              'Itineraries designed for gradual acclimatization, not speed',
              '“Climb high, sleep low” built into each day where possible',
            ].map((item) => (
              <li class="flex items-start gap-3 text-dusk-100">
                <span class="w-5 h-5 rounded-full bg-savannah-500/20 text-savannah-300 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <Check size={12} />
                </span>
                <span class="leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 backdrop-blur-sm hover:bg-white/10 transition-colors">
          <span class="w-11 h-11 rounded-xl bg-savannah-500/20 text-savannah-300 flex items-center justify-center mb-4">
            <HeartPulse size={22} />
          </span>
          <h3 class="font-display text-lg text-white mb-2">Daily vitals</h3>
          <p class="text-sm text-dusk-200/80 leading-relaxed">Your guide records oxygen levels, pulse, and symptoms every morning and evening.</p>
        </div>
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 backdrop-blur-sm hover:bg-white/10 transition-colors">
          <span class="w-11 h-11 rounded-xl bg-savannah-500/20 text-savannah-300 flex items-center justify-center mb-4">
            <Stethoscope size={22} />
          </span>
          <h3 class="font-display text-lg text-white mb-2">Rescue ready</h3>
          <p class="text-sm text-dusk-200/80 leading-relaxed">Certified guides carry oxygen, a stretcher, and communicate with rescue services.</p>
        </div>
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 backdrop-blur-sm hover:bg-white/10 transition-colors">
          <span class="w-11 h-11 rounded-xl bg-savannah-500/20 text-savannah-300 flex items-center justify-center mb-4">
            <Droplets size={22} />
          </span>
          <h3 class="font-display text-lg text-white mb-2">Clean facilities</h3>
          <p class="text-sm text-dusk-200/80 leading-relaxed">Private portable toilets at every camp so you are never relying on shared latrines.</p>
        </div>
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 backdrop-blur-sm hover:bg-white/10 transition-colors">
          <span class="w-11 h-11 rounded-xl bg-savannah-500/20 text-savannah-300 flex items-center justify-center mb-4">
            <Clock size={22} />
          </span>
          <h3 class="font-display text-lg text-white mb-2">Pole pole pace</h3>
          <p class="text-sm text-dusk-200/80 leading-relaxed">Slow walking, rest, and generous itineraries give your body time to adapt.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How hard -->
  <section class="section bg-dusk-50">
    <div class="container-content">
      <div class="grid lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-5">
          <p class="eyebrow text-safari-600 mb-4">Is It For You?</p>
          <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-5">
            More accessible than you think — but never to be underestimated.
          </h2>
          <p class="text-dusk-700 leading-relaxed text-lg mb-4">
            Most people are surprised to learn that Kilimanjaro is open to first-time trekkers. The paths are walking trails, not technical climbs. The real test is the altitude, which affects everyone differently regardless of fitness.
          </p>
          <p class="text-dusk-700 leading-relaxed">
            A typical trekking day lasts 5 to 8 hours. The summit push is longer — usually 10 to 12 hours from midnight to sunrise. If you can comfortably hike 10–15 kilometers or jog a few kilometers without strain, you are in the right zone to start training.
          </p>
        </div>

        <div class="lg:col-span-7">
          <div class="bg-white rounded-2xl p-6 md:p-8 border border-dusk-100 shadow-soft">
            <h3 class="font-display text-xl text-safari-900 mb-6">What a standard climb feels like</h3>
            <div class="space-y-5">
              <div class="flex items-start gap-4">
                <span class="w-10 h-10 rounded-xl bg-safari-100 text-safari-700 flex items-center justify-center flex-shrink-0">
                  <Clock size={18} />
                </span>
                <div>
                  <p class="font-medium text-safari-900">Daily walking time</p>
                  <p class="text-sm text-dusk-600">5–8 hours on most days, with the final summit night stretching to 10–12 hours.</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <span class="w-10 h-10 rounded-xl bg-savannah-100 text-savannah-700 flex items-center justify-center flex-shrink-0">
                  <TrendingUp size={18} />
                </span>
                <div>
                  <p class="font-medium text-safari-900">Altitude gain</p>
                  <p class="text-sm text-dusk-600">You start near 1,800m and reach 5,895m. The key is a slow, staged ascent.</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <span class="w-10 h-10 rounded-xl bg-sunset-100 text-sunset-700 flex items-center justify-center flex-shrink-0">
                  <Mountain size={18} />
                </span>
                <div>
                  <p class="font-medium text-safari-900">Technical difficulty</p>
                  <p class="text-sm text-dusk-600">None. No ropes, crampons, or rock climbing. It is a high-altitude trek from start to finish.</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <span class="w-10 h-10 rounded-xl bg-safari-100 text-safari-700 flex items-center justify-center flex-shrink-0">
                  <Shield size={18} />
                </span>
                <div>
                  <p class="font-medium text-safari-900">Best success strategy</p>
                  <p class="text-sm text-dusk-600">Choose a 7+ day route, train consistently for 2–3 months, and trust your guide’s pace.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What's included -->
  <section class="section bg-white">
    <div class="container-content">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="eyebrow text-safari-600 mb-3">What's Included</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-4">
          Everything that matters, nothing hidden.
        </h2>
        <p class="text-dusk-600 text-lg">
          From the moment you land to the moment you celebrate, we handle the logistics so you can focus on the climb.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {[
          { icon: Briefcase, title: 'Airport transfers', body: 'Pick-up and drop-off in Moshi or Arusha, plus 4×4 transport to your route gate.' },
          { icon: MapPin, title: 'Park fees & permits', body: 'All Kilimanjaro National Park entry, rescue, and camping fees are covered.' },
          { icon: Tent, title: 'Quality camping gear', body: '4-season mountain tents, sleeping mats, private dining tent, and portable toilet.' },
          { icon: UtensilsCrossed, title: 'All meals on trek', body: 'Three hot meals daily plus snacks and hot drinks. Dietary requirements happily accommodated.' },
          { icon: Users, title: 'Full mountain crew', body: 'Professional lead guide, assistant guides, chef, and porters — all employed directly by us.' },
          { icon: Stethoscope, title: 'Safety equipment', body: 'Oxygen cylinder, pulse oximeter, first-aid kit, and emergency communication.' },
          { icon: Compass, title: 'Pre-climb briefing', body: 'Gear check, route overview, and Q&A before you leave town.' },
          { icon: Check, title: 'Summit certificate', body: 'Official KINAPA certificate for every successful trekker.' },
        ].map((item) => (
          <div class="bg-dusk-50 rounded-2xl p-6 border border-dusk-100 hover:border-savannah-300/60 hover:shadow-soft transition-all">
            <span class="w-10 h-10 rounded-xl bg-safari-100 text-safari-700 flex items-center justify-center mb-4">
              <item.icon size={20} />
            </span>
            <h3 class="font-display text-lg text-safari-900 mb-2">{item.title}</h3>
            <p class="text-sm text-dusk-600 leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>

      <div class="mt-10 max-w-3xl mx-auto bg-safari-50 border border-safari-100 rounded-2xl p-6 text-center">
        <p class="text-dusk-700 leading-relaxed">
          <span class="font-semibold text-safari-900">Not included:</span> international flights, Tanzania visa, travel insurance, personal trekking gear, sleeping bag (rentable locally), and crew gratuities. We share a transparent tipping guide with every booking.
        </p>
      </div>
    </div>
  </section>

  <!-- Ethical / why us -->
  <section class="section bg-dusk-50">
    <div class="container-content">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="eyebrow text-safari-600 mb-4">Climb With Conscience</p>
          <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-5">
            A fair climb for you, and for everyone who makes it possible.
          </h2>
          <p class="text-dusk-700 leading-relaxed text-lg mb-4">
            The cheapest quote is rarely the best one. Low-cost operators often cut wages, serve poor food, use worn-out tents, and rush itineraries — which raises the risk of altitude illness and leaves the mountain worse than they found it.
          </p>
          <p class="text-dusk-700 leading-relaxed">
            We do the opposite. Our porters and guides earn above-industry wages and eat the same meals as our guests. We follow recognized porter-welfare standards, provide proper equipment, and design itineraries that prioritize safety over speed.
          </p>

          <div class="mt-8 grid sm:grid-cols-2 gap-4">
            <div class="flex items-start gap-3">
              <span class="w-8 h-8 rounded-lg bg-safari-100 text-safari-700 flex items-center justify-center flex-shrink-0">
                <Users size={16} />
              </span>
              <div>
                <p class="font-medium text-safari-900">Fair wages</p>
                <p class="text-xs text-dusk-600">Crew paid above local standards, on time, every climb.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="w-8 h-8 rounded-lg bg-savannah-100 text-savannah-700 flex items-center justify-center flex-shrink-0">
                <Leaf size={16} />
              </span>
              <div>
                <p class="font-medium text-safari-900">Leave no trace</p>
                <p class="text-xs text-dusk-600">Refillable bottles, reusable packaging, and trash carried out.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="w-8 h-8 rounded-lg bg-sunset-100 text-sunset-700 flex items-center justify-center flex-shrink-0">
                <Shield size={16} />
              </span>
              <div>
                <p class="font-medium text-safari-900">Proper equipment</p>
                <p class="text-xs text-dusk-600">Quality tents, clothing allowances, and sleeping conditions for crew.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="w-8 h-8 rounded-lg bg-safari-100 text-safari-700 flex items-center justify-center flex-shrink-0">
                <HeartPulse size={16} />
              </span>
              <div>
                <p class="font-medium text-safari-900">Safety-first itineraries</p>
                <p class="text-xs text-dusk-600">Longer routes and slower pacing for better acclimatization.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="relative">
          <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-lifted">
            <img
              src={tazamaImages.cta}
              alt="Kilimanjaro climbing team on the trail"
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="absolute -bottom-6 -left-6 bg-safari-900 text-white rounded-2xl p-6 shadow-soft max-w-xs hidden lg:block">
            <p class="font-display text-3xl font-medium mb-1">95%+</p>
            <p class="text-sm text-dusk-200">Summit success on our recommended 8-day Lemosho itineraries.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Routes (no images, clean cards) -->
  <section id="routes" class="section bg-white">
    <div class="container-content">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="eyebrow text-safari-600 mb-3">The Routes</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-4">
          Seven paths. One summit.
        </h2>
        <p class="text-dusk-600 text-lg">
          Every route reaches Uhuru Peak. The difference is scenery, pace, acclimatization, and how much of the mountain you get to yourself.
        </p>
      </div>

      <!-- Recommended highlight -->
      {routes[0] && (
        <div class="mb-8 bg-gradient-to-br from-safari-900 to-safari-800 rounded-2xl p-8 md:p-10 text-white relative overflow-hidden">
          <div class="absolute top-0 right-0 w-64 h-64 bg-savannah-500/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
          <div class="relative z-10 grid md:grid-cols-2 gap-8 items-center">
            <div>
              <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-savannah-500/20 text-savannah-300 text-xs font-semibold uppercase tracking-wider mb-4">
                <Star size={12} /> Top recommendation
              </span>
              <h3 class="font-display text-3xl md:text-4xl mb-3">{routes[0].data.name}</h3>
              <p class="text-dusk-200 text-lg leading-relaxed mb-6">
                {routeBlurb[routes[0].id] ?? routes[0].data.summary}
              </p>
              <div class="flex flex-wrap gap-4 mb-6">
                <span class="text-sm bg-white/10 px-3 py-1.5 rounded-full">{routes[0].data.durationDays} days</span>
                <span class="text-sm bg-white/10 px-3 py-1.5 rounded-full">{routes[0].data.successRate} summit success</span>
                <span class="text-sm bg-white/10 px-3 py-1.5 rounded-full">{difficultyLabel[routes[0].data.difficulty ?? '']}</span>
              </div>
              <a href={`/kilimanjaro/${routes[0].id}`} class="btn btn-primary">
                View {routes[0].data.name} itinerary
                <ArrowRight size={16} />
              </a>
            </div>
            <div class="bg-white/5 border border-white/10 rounded-xl p-6 backdrop-blur-sm">
              <h4 class="font-display text-lg mb-4 text-savannah-300">Why it leads our list</h4>
              <ul class="space-y-3 text-dusk-100">
                {routes[0].data.highlights.slice(0, 4).map((h) => (
                  <li class="flex items-start gap-3">
                    <Check size={16} class="text-savannah-300 flex-shrink-0 mt-0.5" />
                    <span class="text-sm leading-relaxed">{h}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      )}

      <!-- Route grid -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {routes.slice(1).map((r) => {
          const dots = Array.from({ length: 5 }, (_, k) => k < (r.data.scenery ?? 0));
          return (
            <a
              href={`/kilimanjaro/${r.id}`}
              class="group bg-dusk-50 rounded-2xl p-6 border border-dusk-100 hover:border-savannah-300/60 hover:shadow-lifted hover:-translate-y-1 transition-all"
            >
              <div class="flex items-start justify-between mb-4">
                <div>
                  <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-700 mb-1">{r.data.tagline}</p>
                  <h3 class="font-display text-xl text-safari-900 group-hover:text-safari-700 transition-colors">{r.data.name}</h3>
                </div>
                <span class="w-8 h-8 rounded-full bg-white text-safari-700 flex items-center justify-center group-hover:bg-safari-700 group-hover:text-white transition-colors">
                  <ArrowRight size={14} />
                </span>
              </div>

              <p class="text-sm text-dusk-600 leading-relaxed mb-5 line-clamp-3">
                {routeBlurb[r.id] ?? r.data.summary}
              </p>

              <div class="flex flex-wrap gap-2 text-xs mb-4">
                <span class="px-2 py-1 rounded-md bg-white text-dusk-700 border border-dusk-100">{r.data.successRate}</span>
                <span class="px-2 py-1 rounded-md bg-white text-dusk-700 border border-dusk-100">{difficultyLabel[r.data.difficulty ?? '']}</span>
              </div>

              <div class="flex items-center justify-between pt-4 border-t border-dusk-200/60">
                <div class="flex gap-0.5">
                  {dots.map((filled) => (
                    <span class={`w-1.5 h-1.5 rounded-full ${filled ? 'bg-savannah-500' : 'bg-dusk-200'}`}></span>
                  ))}
                </div>
                <span class="text-xs text-dusk-500">{trafficLabel[r.data.traffic ?? '']} · {r.data.accommodation}</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Best time -->
  <section class="section bg-dusk-50">
    <div class="container-content">
      <div class="grid lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-5">
          <p class="eyebrow text-safari-600 mb-4">When to Climb</p>
          <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-5">
            Two dry windows, each with its own feel.
          </h2>
          <p class="text-dusk-700 leading-relaxed text-lg mb-4">
            Kilimanjaro can be climbed year-round, but the most stable weather falls between January and mid-March, and again from June to October.
          </p>
          <p class="text-dusk-700 leading-relaxed mb-4">
            The June–October window is the driest and busiest. December and March are quieter shoulder months with excellent conditions. We generally advise first-timers to avoid the long rains from mid-March to May.
          </p>
          <p class="text-dusk-700 leading-relaxed">
            If you must travel in November or April, the Rongai Route is often the driest choice because it sits in the mountain’s rain shadow.
          </p>
        </div>

        <div class="lg:col-span-7">
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4">
            {['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'].map((m) => {
              const rating = monthRatings[m];
              return (
                <div class={`rounded-xl border p-4 text-center ${monthColorMap[rating]}`}>
                  <p class="text-xs font-semibold uppercase tracking-wider">{m}</p>
                  <p class="text-[10px] mt-1 uppercase tracking-wider opacity-80">
                    {rating === 'high' ? 'Peak' : rating === 'med' ? 'Shoulder' : 'Off'}
                  </p>
                </div>
              );
            })}
          </div>
          <div class="flex flex-wrap items-center gap-4 text-xs text-dusk-600">
            <span class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-safari-600"></span>Peak season</span>
            <span class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-savannah-300"></span>Shoulder season</span>
            <span class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-dusk-200"></span>Off season (wet)</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Your role in planning -->
  <section class="section bg-white">
    <div class="container-content">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="order-2 lg:order-1">
          <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-lifted">
            <img
              src={tazamaImages.scenery1}
              alt="Kilimanjaro trekker silhouetted against the summit glaciers"
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <p class="eyebrow text-safari-600 mb-4">Your Part</p>
          <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-5">
            We handle the logistics. You handle the preparation.
          </h2>
          <p class="text-dusk-700 leading-relaxed text-lg mb-6">
            From the day you book, we stay in close contact. You receive a detailed preparation pack with training guidance, a packing checklist, visa information, and answers to the questions you have not thought of yet.
          </p>
          <div class="space-y-4">
            {[
              { title: 'Train consistently', body: 'Start 8–12 weeks out with hiking, stair climbing, or cardio. The fitter you are, the more you will enjoy the trek.' },
              { title: 'Share your needs', body: 'Tell us about dietary requirements, medical conditions, and any concerns before arrival so we can plan around them.' },
              { title: 'Pack smart', body: 'We provide a full gear list and can arrange rental of sleeping bags, trekking poles, and warm layers in Moshi or Arusha.' },
              { title: 'Trust the pace', body: 'The mountain rewards patience. Pole pole — slowly, slowly — is the mantra that gets people to the top.' },
            ].map((item) => (
              <div class="flex items-start gap-4 p-4 rounded-xl bg-dusk-50 border border-dusk-100">
                <span class="w-8 h-8 rounded-lg bg-safari-100 text-safari-700 flex items-center justify-center flex-shrink-0">
                  <Check size={14} />
                </span>
                <div>
                  <p class="font-medium text-safari-900">{item.title}</p>
                  <p class="text-sm text-dusk-600 leading-relaxed">{item.body}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured itineraries -->
  {kilimanjaroTreks.length > 0 && (
    <section class="section bg-safari-50">
      <div class="container-content">
        <div class="flex items-end justify-between mb-10">
          <div>
            <p class="eyebrow text-safari-700 mb-3">Ready-Made Treks</p>
            <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900">
              Itineraries already planned for you
            </h2>
          </div>
          <a href="/trekking" class="hidden md:inline-flex items-center gap-2 text-safari-700 hover:text-safari-900 font-medium">
            See all treks
            <ArrowRight size={16} />
          </a>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {kilimanjaroTreks.map((trek) => (
            <a
              href={`/trekking/${trek.id}`}
              class="group bg-white rounded-2xl overflow-hidden border border-dusk-100 hover:border-savannah-300/60 hover:shadow-lifted hover:-translate-y-1 transition-all"
            >
              <div class="aspect-[16/10] overflow-hidden bg-dusk-200">
                <img
                  src={trek.data.hero}
                  alt={trek.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="p-5">
                <span class="text-xs text-dusk-500 mb-3 block">{trek.data.successRate}</span>
                <h3 class="font-display text-lg text-safari-900 mb-2 group-hover:text-safari-700 transition-colors line-clamp-2">
                  {trek.data.title}
                </h3>
                <p class="text-sm text-dusk-600 leading-relaxed line-clamp-2 mb-4">
                  {trek.data.excerpt}
                </p>
                <span class="inline-flex items-center gap-1 text-sm text-safari-700 font-medium group-hover:gap-2 transition-all">
                  View itinerary <ArrowRight size={14} />
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- FAQs -->
  <section class="section bg-white">
    <div class="container-content max-w-3xl">
      <p class="eyebrow text-safari-600 mb-3 text-center">Common Questions</p>
      <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-10 text-center">
        Before you book
      </h2>

      <div class="space-y-4">
        {[
          {
            q: 'Which route is best for a first Kilimanjaro climb?',
            a: 'We usually recommend the 8-day Lemosho Route. It offers the best acclimatization profile, the highest success rate, and the most varied scenery. Machame (7 days) is an excellent alternative if you prefer a slightly shorter trip.'
          },
          {
            q: 'How fit do I need to be?',
            a: 'You do not need to be an athlete, but you should be comfortable walking 5–7 hours on uneven terrain. Start a training routine 8–12 weeks before departure — hiking, cycling, swimming, and stair climbing all help. We send a detailed training guide with every booking.'
          },
          {
            q: 'How do you prevent altitude sickness?',
            a: 'We prevent it through route choice (7+ days), slow pacing, twice-daily health checks, and the “climb high, sleep low” principle. Our guides are trained to recognize early symptoms and respond immediately with oxygen, rest, or descent if needed.'
          },
          {
            q: 'What is the accommodation like on the mountain?',
            a: 'On camping routes you sleep in quality 4-season tents with foam sleeping mats. On the Marangu Route you stay in basic mountain huts. We also provide a private dining tent and portable toilet at every camp.'
          },
          {
            q: 'Can you accommodate dietary requirements?',
            a: 'Yes. Our mountain chefs prepare three hot meals daily and can cater to vegetarian, vegan, gluten-free, halal, and most other requirements. Just let us know in advance.'
          },
          {
            q: 'What should I bring?',
            a: 'You will need layered trekking clothing, a warm down jacket, quality hiking boots, a headlamp, sun protection, and a sleeping bag rated to at least -10°C. We provide a full packing list and can arrange gear rental in Moshi or Arusha.'
          },
          {
            q: 'Can I combine Kilimanjaro with a safari or Zanzibar?',
            a: 'Absolutely. Most climbers add a 4–5 day northern-circuit safari and/or a beach break in Zanzibar. We handle all transfers, accommodation, and park bookings as one seamless trip.'
          },
        ].map((faq) => (
          <details class="group bg-dusk-50 rounded-xl border border-dusk-100 shadow-soft hover:shadow-lifted transition-shadow">
            <summary class="flex items-center justify-between p-5 cursor-pointer list-none">
              <h3 class="font-display text-lg text-safari-900 pr-4">{faq.q}</h3>
              <span class="w-8 h-8 rounded-full bg-safari-100 text-safari-700 flex items-center justify-center flex-shrink-0 group-open:rotate-45 transition-transform">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
              </span>
            </summary>
            <div class="px-5 pb-5 text-dusk-700 leading-relaxed">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section bg-safari-900 text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-15">
      <img
        src={tazamaImages.scenery4}
        alt=""
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-safari-900 via-safari-900/95 to-safari-900"></div>

    <div class="container-content relative z-10">
      <div class="max-w-3xl mx-auto text-center">
        <p class="eyebrow text-savannah-300 mb-3">Start Planning</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight mb-5">
          Tell us your dates. We will build your climb.
        </h2>
        <p class="text-lg text-dusk-100/90 mb-8">
          Every Kilimanjaro expedition is private and tailored. Share your group size, preferred route, and travel dates — we will respond within 24 hours with a detailed plan, gear list, and everything you need to prepare.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/contact?subject=kilimanjaro" class="btn btn-primary px-8 py-3.5">
            Get a custom quote
            <ArrowRight size={16} />
          </a>
          <a href="/trekking" class="btn btn-outline-light px-8 py-3.5 border-white/30 hover:bg-white hover:text-safari-900">
            Browse ready-made treks
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- JSON-LD -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify(withPublisher({
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Kilimanjaro Climbing Routes',
    description: 'The 6 official routes up Mount Kilimanjaro, Tanzania',
    numberOfItems: routes.length,
    itemListElement: routes.map((r, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: r.data.name,
      description: r.data.summary,
      url: `/kilimanjaro/${r.id}`,
    })),
  }))} />
</PublicLayout>

