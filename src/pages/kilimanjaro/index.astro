---
export const prerender = true;
import { getCollection } from 'astro:content';
import PublicLayout from '@/layouts/PublicLayout.astro';
import { withPublisher } from '@/lib/jsonld';
import {
  ArrowRight, Mountain, TrendingUp, Calendar, Users, Home,
  Check, Star, Tent, MountainSnow,
} from '@lucide/astro';


const routes = (await getCollection('kilimanjaro')).sort(
  (a, b) => a.data.order - b.data.order
);

const trafficLabel: Record<string, string> = {
  quiet: 'Quiet',
  moderate: 'Moderate',
  busy: 'Busy',
  'very-busy': 'Very busy',
};

const difficultyLabel: Record<string, string> = {
  moderate: 'Moderate',
  challenging: 'Challenging',
  strenuous: 'Strenuous',
  expert: 'Expert',
};

type SeasonRating = 'high' | 'med' | 'low';
const monthRatings: Record<string, SeasonRating> = {
  Jan: 'high', Feb: 'high', Mar: 'med',
  Apr: 'low', May: 'low', Jun: 'high',
  Jul: 'high', Aug: 'high', Sep: 'high',
  Oct: 'high', Nov: 'low', Dec: 'med',
};
const monthColorMap: Record<SeasonRating, string> = {
  high: 'bg-safari-600 text-white border-safari-700',
  med: 'bg-savannah-200 text-savannah-900 border-savannah-300',
  low: 'bg-dusk-100 text-dusk-500 border-dusk-200',
};

const recommended = routes[0];
const allTours = await getCollection('tours');
const kilimanjaroTours = allTours.filter((t) => t.data.type === 'kilimanjaro').slice(0, 3);
---

<PublicLayout
  title="Kilimanjaro Climbing Routes — 7 Ways to the Roof of Africa"
  description="Compare all 7 official Kilimanjaro routes: Marangu, Machame, Lemosho, Rongai, Northern Circuit, Umbwe, and Shira. Find the right climb for your fitness, schedule, and ambition."
  ogImage="/og/kilimanjaro.png"
  transparentHeader={true}
>
  <!-- Hero -->
  <section class="relative h-[85vh] min-h-[600px] w-full overflow-hidden bg-safari-900 text-white">
    <img
      src="https://images.unsplash.com/photo-1589308078059-be1415eab4c3?w=1920&q=80&auto=format&fit=crop"
      alt="Kilimanjaro at sunrise"
      class="absolute inset-0 w-full h-full object-cover scale-105"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-tr from-black/85 via-black/45 to-black/20"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-black/40"></div>

    <div class="container-content relative z-10 h-full flex flex-col justify-end pb-16 md:pb-20 pt-32">
      <div class="max-w-3xl">
        <p class="eyebrow text-savannah-300 text-[11px] md:text-xs uppercase tracking-[0.18em] mb-3">7 official routes · 5,895m · One summit</p>

        <h1 class="font-display text-[2.6rem] sm:text-6xl md:text-7xl lg:text-display-lg font-medium tracking-tight text-white mb-5 md:mb-6">
          Climb<br />
          <span class="italic font-normal text-savannah-300">Kilimanjaro.</span>
        </h1>

        <p class="text-lg md:text-xl text-dusk-100/90 max-w-2xl leading-relaxed font-light mb-8">
          Seven official routes, one roof of Africa. Compare success rates, scenery, traffic, and difficulty — and pick the climb that matches your time, fitness, and ambition.
        </p>

        <div class="flex flex-wrap gap-4">
          <a href="#routes" class="btn btn-primary px-7 py-3.5">
            Compare the 7 routes
            <ArrowRight size={16} />
          </a>
          <a href="/contact?subject=kilimanjaro" class="btn btn-outline-light px-7 py-3.5 border-white/30 hover:bg-white hover:text-safari-900">
            Get a custom quote
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust strip -->
  <section class="bg-safari-900 text-white border-t border-white/10">
    <div class="container-content py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <p class="font-display text-3xl md:text-4xl text-savannah-300">7</p>
          <p class="text-xs uppercase tracking-[0.18em] text-dusk-300 mt-1">Official routes</p>
        </div>
        <div>
          <p class="font-display text-3xl md:text-4xl text-savannah-300">98%</p>
          <p class="text-xs uppercase tracking-[0.18em] text-dusk-300 mt-1">Best success rate</p>
        </div>
        <div>
          <p class="font-display text-3xl md:text-4xl text-savannah-300">5,895m</p>
          <p class="text-xs uppercase tracking-[0.18em] text-dusk-300 mt-1">Uhuru Peak</p>
        </div>
        <div>
          <p class="font-display text-3xl md:text-4xl text-savannah-300">5 zones</p>
          <p class="text-xs uppercase tracking-[0.18em] text-dusk-300 mt-1">Climate &amp; terrain</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why climb with us -->
  <section class="section bg-dusk-50">
    <div class="container-content">
      <div class="grid lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-5">
          <p class="eyebrow text-safari-600 mb-4">Why climb with us</p>
          <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-5">
            Arusha-based guides, no middlemen, no surprises.
          </h2>
          <p class="text-dusk-700 leading-relaxed text-lg">
            Our climbing team is based in Arusha, lives near the mountain, and has summited Kilimanjaro hundreds of times. We don't resell other operators' trips. The guides, porters, and chefs you meet on day one are our full-time staff — paid fairly, equipped properly, and trained in altitude response.
          </p>
        </div>

        <div class="lg:col-span-7 grid sm:grid-cols-2 gap-5">
          <div class="bg-white rounded-2xl p-6 border border-dusk-100 shadow-soft">
            <span class="w-10 h-10 rounded-xl bg-safari-100 text-safari-700 flex items-center justify-center mb-4">
              <Mountain size={20} />
            </span>
            <h3 class="font-display text-xl text-safari-900 mb-2">Top-tier guides</h3>
            <p class="text-sm text-dusk-600 leading-relaxed">Wilderness First Responder certified, 200+ summits each, English-speaking, and trained in altitude emergency response.</p>
          </div>
          <div class="bg-white rounded-2xl p-6 border border-dusk-100 shadow-soft">
            <span class="w-10 h-10 rounded-xl bg-savannah-100 text-savannah-700 flex items-center justify-center mb-4">
              <Users size={20} />
            </span>
            <h3 class="font-display text-xl text-safari-900 mb-2">Full support crew</h3>
            <p class="text-sm text-dusk-600 leading-relaxed">Porters, chef, and summit porter included. You carry a daypack; we carry the rest. Fair wages, proper gear, regulated by Kilimanjaro National Park.</p>
          </div>
          <div class="bg-white rounded-2xl p-6 border border-dusk-100 shadow-soft">
            <span class="w-10 h-10 rounded-xl bg-sunset-100 text-sunset-700 flex items-center justify-center mb-4">
              <TrendingUp size={20} />
            </span>
            <h3 class="font-display text-xl text-safari-900 mb-2">High success rates</h3>
            <p class="text-sm text-dusk-600 leading-relaxed">Published success rates above industry average: 90% on Machame, 95% on Lemosho, 98% on the Northern Circuit.</p>
          </div>
          <div class="bg-white rounded-2xl p-6 border border-dusk-100 shadow-soft">
            <span class="w-10 h-10 rounded-xl bg-safari-100 text-safari-700 flex items-center justify-center mb-4">
              <Check size={20} />
            </span>
            <h3 class="font-display text-xl text-safari-900 mb-2">Transparent pricing</h3>
            <p class="text-sm text-dusk-600 leading-relaxed">Park fees, rescue insurance, crew wages, food, and transfers all included. No surprise add-ons. Tipping guide shared up front.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Routes comparison table -->
  <section id="routes" class="section bg-white">
    <div class="container-content">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="eyebrow text-safari-600 mb-3">All 7 routes</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-4">
          Find the right climb for you
        </h2>
        <p class="text-dusk-600">
          Every route reaches the same summit. The differences are in scenery, traffic, acclimatization profile, and difficulty. Use the table to compare, then click through to each route for the full day-by-day itinerary.
        </p>
      </div>

      <!-- Desktop table -->
      <div class="hidden md:block overflow-x-auto rounded-2xl border border-dusk-100">
        <table class="w-full text-left">
          <thead>
            <tr class="bg-safari-50 border-b border-dusk-100">
              <th class="px-4 py-4 font-semibold text-safari-900 text-sm">Route</th>
              <th class="px-4 py-4 font-semibold text-safari-900 text-sm">Days</th>
              <th class="px-4 py-4 font-semibold text-safari-900 text-sm">Success</th>
              <th class="px-4 py-4 font-semibold text-safari-900 text-sm">Difficulty</th>
              <th class="px-4 py-4 font-semibold text-safari-900 text-sm">Scenery</th>
              <th class="px-4 py-4 font-semibold text-safari-900 text-sm">Traffic</th>
              <th class="px-4 py-4 font-semibold text-safari-900 text-sm">Sleep</th>
              <th class="px-4 py-4 font-semibold text-safari-900 text-sm">From</th>
              <th class="px-4 py-4 font-semibold text-safari-900 text-sm sr-only">View</th>
            </tr>
          </thead>
          <tbody>
            {routes.map((r, i) => {
              const dots = Array.from({ length: 5 }, (_, k) => k < r.data.scenery);
              return (
                <tr class={`border-b border-dusk-100 hover:bg-safari-50/50 transition-colors ${i === 0 ? 'bg-savannah-50/40' : ''}`}>
                  <td class="px-4 py-4">
                    <a href={`/kilimanjaro/${r.id}`} class="font-display text-base text-safari-900 hover:text-safari-700">
                      {r.data.name}
                    </a>
                    {i === 0 && (
                      <span class="ml-2 inline-block px-2 py-0.5 rounded text-[10px] uppercase tracking-wider bg-savannah-200 text-savannah-900">
                        Recommended
                      </span>
                    )}
                  </td>
                  <td class="px-4 py-4 text-dusk-700">{r.data.durationDays} days</td>
                  <td class="px-4 py-4 text-dusk-700 font-medium">{r.data.successRate}</td>
                  <td class="px-4 py-4 text-dusk-700">{difficultyLabel[r.data.difficulty]}</td>
                  <td class="px-4 py-4">
                    <div class="flex gap-0.5">
                      {dots.map((filled) => (
                        <span class={`w-1.5 h-1.5 rounded-full ${filled ? 'bg-savannah-500' : 'bg-dusk-200'}`}></span>
                      ))}
                    </div>
                  </td>
                  <td class="px-4 py-4 text-dusk-700">{trafficLabel[r.data.traffic]}</td>
                  <td class="px-4 py-4 text-dusk-700 capitalize">{r.data.accommodation}</td>
                  <td class="px-4 py-4 font-medium text-safari-900">${r.data.priceFromUSD.toLocaleString()}</td>
                  <td class="px-4 py-4 text-right">
                    <a href={`/kilimanjaro/${r.id}`} class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-safari-100 text-safari-700 hover:bg-safari-200 transition-colors">
                      <ArrowRight size={14} />
                    </a>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      <!-- Mobile cards -->
      <div class="md:hidden space-y-4">
        {routes.map((r) => (
          <a href={`/kilimanjaro/${r.id}`} class="block bg-white rounded-2xl border border-dusk-100 p-5 hover:border-safari-300 hover:shadow-soft transition-all">
            <div class="flex items-start justify-between mb-2">
              <h3 class="font-display text-lg text-safari-900">{r.data.name}</h3>
              <span class="text-safari-900 font-medium">${r.data.priceFromUSD.toLocaleString()}</span>
            </div>
            <p class="text-sm text-dusk-600 leading-relaxed mb-3 line-clamp-2">{r.data.tagline}</p>
            <div class="flex flex-wrap gap-2 text-xs">
              <span class="px-2 py-1 rounded bg-dusk-100 text-dusk-700">{r.data.durationDays} days</span>
              <span class="px-2 py-1 rounded bg-safari-100 text-safari-800">{r.data.successRate}</span>
              <span class="px-2 py-1 rounded bg-savannah-100 text-savannah-800">{difficultyLabel[r.data.difficulty]}</span>
              <span class="px-2 py-1 rounded bg-dusk-100 text-dusk-700">{trafficLabel[r.data.traffic]}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Route cards (more visual) -->
  <section class="section bg-dusk-50">
    <div class="container-content">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="eyebrow text-safari-600 mb-3">Route deep-dives</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900">
          Each route, in pictures and detail
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {routes.map((r) => (
          <a
            href={`/kilimanjaro/${r.id}`}
            class="group relative overflow-hidden rounded-2xl bg-white border border-dusk-100 hover:border-safari-300 hover:shadow-lifted transition-all"
          >
            <div class="aspect-[4/3] overflow-hidden bg-dusk-200 relative">
              <img
                src={r.data.hero}
                alt={r.data.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
                decoding="async"
              />
              <div class="absolute top-3 left-3 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-white/90 backdrop-blur text-xs font-medium text-safari-900">
                {r.data.successRate} success
              </div>
            </div>
            <div class="p-5">
              <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-700 mb-2">{r.data.tagline}</p>
              <h3 class="font-display text-xl text-safari-900 mb-2 group-hover:text-safari-700 transition-colors">{r.data.name}</h3>
              <p class="text-sm text-dusk-600 leading-relaxed mb-4 line-clamp-3">{r.data.summary}</p>
              <div class="flex items-center justify-between text-xs text-dusk-500 pt-4 border-t border-dusk-100">
                <span>{r.data.durationDays} days · {difficultyLabel[r.data.difficulty]}</span>
                <span class="font-medium text-safari-900">From ${r.data.priceFromUSD.toLocaleString()}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Best time to climb -->
  <section class="section bg-white">
    <div class="container-content">
      <div class="grid lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-5">
          <p class="eyebrow text-safari-600 mb-4">When to climb</p>
          <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-5">
            Two climbing seasons, each with its own character
          </h2>
          <p class="text-dusk-700 leading-relaxed text-lg mb-4">
            Kilimanjaro can be climbed year-round, but two windows offer the best weather: January to mid-March and June to October. The dry-season climbs (June–October) are busier; the shoulder months (December, March) are quieter and still excellent.
          </p>
          <p class="text-dusk-700 leading-relaxed">
            We recommend avoiding the long rains (mid-March to May) and the short rains (November) for first-time climbers. The Rongai Route is the best option during rainy months.
          </p>
        </div>

        <div class="lg:col-span-7">
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4">
            {['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'].map((m) => {
              const rating = monthRatings[m];
              return (
                <div class={`rounded-xl border p-4 text-center ${monthColorMap[rating]}`}>
                  <p class="text-xs font-semibold uppercase tracking-wider">{m}</p>
                  <p class="text-[10px] mt-1 uppercase tracking-wider opacity-80">
                    {rating === 'high' ? 'Peak' : rating === 'med' ? 'Shoulder' : 'Off'}
                  </p>
                </div>
              );
            })}
          </div>
          <div class="flex flex-wrap items-center gap-4 text-xs text-dusk-600">
            <span class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-safari-600"></span>Peak season</span>
            <span class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-savannah-300"></span>Shoulder season</span>
            <span class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-dusk-200"></span>Off season (wet)</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Recommended for first-timers -->
  {recommended && (
    <section class="section bg-safari-50">
      <div class="container-content">
        <div class="grid lg:grid-cols-12 gap-12 items-center">
          <div class="lg:col-span-6">
            <div class="aspect-[4/3] overflow-hidden rounded-2xl shadow-lifted">
              <img
                src={recommended.data.hero}
                alt={recommended.data.name}
                class="w-full h-full object-cover"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
          <div class="lg:col-span-6">
            <p class="eyebrow text-safari-700 mb-3">Our pick for first-timers</p>
            <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-5">
              {recommended.data.name}
            </h2>
            <p class="text-dusk-700 leading-relaxed text-lg mb-6">
              {recommended.data.summary}
            </p>
            <div class="grid grid-cols-3 gap-4 mb-6 max-w-md">
              <div>
                <p class="font-display text-2xl text-safari-900">{recommended.data.durationDays} days</p>
                <p class="text-xs text-dusk-500 uppercase tracking-wider">Duration</p>
              </div>
              <div>
                <p class="font-display text-2xl text-safari-900">{recommended.data.successRate}</p>
                <p class="text-xs text-dusk-500 uppercase tracking-wider">Success</p>
              </div>
              <div>
                <p class="font-display text-2xl text-safari-900">${recommended.data.priceFromUSD.toLocaleString()}</p>
                <p class="text-xs text-dusk-500 uppercase tracking-wider">From</p>
              </div>
            </div>
            <a href={`/kilimanjaro/${recommended.id}`} class="btn btn-primary px-6 py-3">
              See the full {recommended.data.name} itinerary
              <ArrowRight size={16} />
            </a>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Ready-made packages -->
  {kilimanjaroTours.length > 0 && (
    <section class="section bg-white">
      <div class="container-content">
        <div class="flex items-end justify-between mb-8">
          <div>
            <p class="eyebrow text-safari-600 mb-3">Ready-made climbs</p>
            <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900">
              Skip the planning, book a package
            </h2>
          </div>
          <a href="/tours?style=kilimanjaro" class="hidden md:inline-flex items-center gap-2 text-safari-700 hover:text-safari-900 font-medium">
            See all climbs
            <ArrowRight size={16} />
          </a>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {kilimanjaroTours.map((tour) => (
            <a
              href={`/tours/${tour.id}`}
              class="group relative overflow-hidden rounded-2xl bg-white border border-dusk-100 hover:border-safari-300 hover:shadow-lifted transition-all"
            >
              <div class="aspect-[4/3] overflow-hidden bg-dusk-200">
                <img
                  src={tour.data.hero}
                  alt={tour.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="p-5">
                <h3 class="font-display text-xl text-safari-900 mb-2 group-hover:text-safari-700 transition-colors">{tour.data.title}</h3>
                <p class="text-sm text-dusk-600 leading-relaxed mb-3 line-clamp-2">{tour.data.excerpt}</p>
                <div class="flex items-center gap-3 text-xs text-dusk-500">
                  <span>{tour.data.durationDays} days</span>
                  <span>·</span>
                  <span>From ${tour.data.priceFromUSD.toLocaleString()}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- FAQs -->
  <section class="section bg-dusk-50">
    <div class="container-content max-w-3xl">
      <p class="eyebrow text-safari-600 mb-3 text-center">Common questions</p>
      <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-10 text-center">
        Before you book
      </h2>

      <div class="space-y-4">
        {[
          {
            q: 'Which Kilimanjaro route is the best for first-time climbers?',
            a: 'Lemosho (8 days) or the Northern Circuit (9 days) are the easiest routes to summit successfully, with published success rates of 95% and 98%. Machame (7 days) is the most popular and a good middle ground. Marangu (6 days) is the shortest and easiest physically, but has a lower success rate because of the shorter acclimatization profile.'
          },
          {
            q: 'How fit do I need to be?',
            a: 'You don\'t need to be an athlete, but you do need to be able to walk 5–7 hours per day on steep, uneven terrain. The best preparation is 3–4 months of regular hiking, cycling, or stair climbing before your trip. We send a training plan with every booking.'
          },
          {
            q: 'How do you handle altitude sickness?',
            a: 'Our guides are Wilderness First Responder certified and carry oxygen and pulse oximeters. We follow the "climb high, sleep low" principle on every route, and our guides check every climber twice daily. The most important thing is choosing a route with enough days for acclimatization — 7+ days gives your body time to adjust.'
          },
          {
            q: 'What\'s the best time of year to climb?',
            a: 'January to mid-March and June to October are the dry-season windows. July, August, and September are busiest. December and March are quieter shoulder months with excellent weather. We avoid the long rains (mid-March to May) and short rains (November) for first-timers.'
          },
          {
            q: 'How much should I tip the crew?',
            a: 'Tipping is customary on Kilimanjaro and is a meaningful supplement to crew wages. The recommended total is $350–$500 per climber for the full mountain team, split between the lead guide, assistant guides, chef, and porters. We share the exact breakdown and tipping protocol with your booking confirmation.'
          },
          {
            q: 'Can I climb Kilimanjaro and add a safari or Zanzibar?',
            a: 'Absolutely — most of our climbers do. The classic combination is 7 days on Kilimanjaro + 4 days on safari (Tarangire, Ngorongoro, Serengeti) + 4 days on Zanzibar. We can build any combination, and we offer a 10% discount on safari + Zanzibar when booked with a climb.'
          },
        ].map((faq) => (
          <details class="group bg-white rounded-xl border border-dusk-100 shadow-soft">
            <summary class="flex items-center justify-between p-5 cursor-pointer list-none">
              <h3 class="font-display text-lg text-safari-900 pr-4">{faq.q}</h3>
              <span class="w-8 h-8 rounded-full bg-safari-100 text-safari-700 flex items-center justify-center flex-shrink-0 group-open:rotate-45 transition-transform">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
              </span>
            </summary>
            <div class="px-5 pb-5 text-dusk-700 leading-relaxed">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section bg-safari-900 text-white">
    <div class="container-content">
      <div class="max-w-3xl mx-auto text-center">
        <p class="eyebrow text-savannah-300 mb-3">Start planning</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight mb-5">
          Tell us your dates. We'll build your climb.
        </h2>
        <p class="text-lg text-dusk-100/90 mb-8">
          All climbs are private and fully customized. Tell us your group size, preferred route, and travel dates — we'll send a full quote within 24 hours, including gear list, sample schedule, and what to expect on the mountain.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/contact?subject=kilimanjaro" class="btn btn-primary px-8 py-3.5">
            Get a custom quote
            <ArrowRight size={16} />
          </a>
          <a href="/tours?style=kilimanjaro" class="btn btn-outline-light px-8 py-3.5 border-white/30 hover:bg-white hover:text-safari-900">
            See ready-made climbs
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- JSON-LD: ItemList of 7 routes -->
  <script type="application/ld+json" set:html={JSON.stringify(withPublisher({
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Kilimanjaro Climbing Routes',
    description: 'The 7 official routes up Mount Kilimanjaro, Tanzania',
    numberOfItems: routes.length,
    itemListElement: routes.map((r, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: r.data.name,
      description: r.data.summary,
      url: `/kilimanjaro/${r.id}`,
    })),
  }))} />
</PublicLayout>
