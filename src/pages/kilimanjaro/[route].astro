---
import { getCollection, getEntry, render } from 'astro:content';
import PublicLayout from '@/layouts/PublicLayout.astro';
import { withPublisher } from '@/lib/jsonld';
import {
  ArrowLeft, ArrowRight, MapPin, Calendar, TrendingUp, Mountain,
  Users, Home, Sparkles, Star, Tent, Check, X, MountainSnow,
} from '@lucide/astro';

export async function getStaticPaths() {
  const routes = await getCollection('kilimanjaro');
  return routes.map((r) => ({ params: { route: r.id } }));
}

const { route: routeId } = Astro.params;
const route = await getEntry('kilimanjaro', routeId!);
const { Content } = await render(route);

const allTours = await getCollection('tours');
const relatedTours = allTours.filter((t) => t.data.type === 'kilimanjaro').slice(0, 3);

const allRoutes = await getCollection('kilimanjaro');
const relatedRoutes = allRoutes
  .filter((r) => r.id !== route.id)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const trafficLabel: Record<string, string> = {
  quiet: 'Quiet',
  moderate: 'Moderate',
  busy: 'Busy',
  'very-busy': 'Very busy',
};

const trafficColor: Record<string, string> = {
  quiet: 'bg-safari-100 text-safari-800',
  moderate: 'bg-savannah-100 text-savannah-800',
  busy: 'bg-sunset-100 text-sunset-800',
  'very-busy': 'bg-sunset-200 text-sunset-900',
};

const difficultyLabel: Record<string, string> = {
  moderate: 'Moderate',
  challenging: 'Challenging',
  strenuous: 'Strenuous',
  expert: 'Expert',
};

const difficultyColor: Record<string, string> = {
  moderate: 'bg-safari-100 text-safari-800',
  challenging: 'bg-savannah-100 text-savannah-800',
  strenuous: 'bg-sunset-200 text-sunset-900',
  expert: 'bg-sunset-300 text-sunset-900',
};

const sceneryDots = Array.from({ length: 5 }, (_, i) => i < route.data.scenery);
---

<PublicLayout
  title={route.data.seo?.title ?? `${route.data.name} — ${route.data.durationDays} Days`}
  description={route.data.seo?.description ?? route.data.summary}
  transparentHeader={true}
>
  <section class="relative h-[80vh] min-h-[560px] w-full overflow-hidden bg-safari-900 text-white">
    <img
      src={route.data.hero}
      alt={`${route.data.name} landscape`}
      class="absolute inset-0 w-full h-full object-cover scale-105"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-tr from-black/85 via-black/45 to-black/20"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-black/40"></div>

    <div class="container-content relative z-10 h-full flex flex-col justify-end pb-16 md:pb-20 pt-32">
      <div class="max-w-3xl">
        <a href="/kilimanjaro" class="inline-flex items-center gap-2 text-savannah-300 hover:text-savannah-200 text-xs uppercase tracking-[0.18em] mb-5 md:mb-6 transition-colors">
          <ArrowLeft size={14} />
          All Kilimanjaro routes
        </a>

        <p class="eyebrow text-savannah-300 text-[11px] md:text-xs uppercase tracking-[0.18em] mb-3">{route.data.tagline}</p>

        <h1 class="font-display text-[2.5rem] sm:text-5xl md:text-6xl lg:text-7xl font-medium tracking-tight text-white mb-5 md:mb-6">
          {route.data.name}
        </h1>

        <p class="text-lg md:text-xl text-dusk-100/90 max-w-2xl leading-relaxed font-light">
          {route.data.summary}
        </p>
      </div>
    </div>
  </section>

  <section class="bg-safari-900 text-white border-b border-white/10">
    <div class="container-content">
      <div class="grid grid-cols-2 md:grid-cols-6 divide-x divide-white/10">
        <div class="px-4 md:px-6 py-5 md:py-6">
          <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-300/80 mb-1">Duration</p>
          <p class="font-display text-xl md:text-2xl text-white">{route.data.durationDays} days</p>
        </div>
        <div class="px-4 md:px-6 py-5 md:py-6">
          <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-300/80 mb-1">Success rate</p>
          <p class="font-display text-xl md:text-2xl text-white">{route.data.successRate}</p>
        </div>
        <div class="px-4 md:px-6 py-5 md:py-6">
          <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-300/80 mb-1">Difficulty</p>
          <p class="font-display text-xl md:text-2xl text-white">{difficultyLabel[route.data.difficulty]}</p>
        </div>
        <div class="px-4 md:px-6 py-5 md:py-6">
          <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-300/80 mb-1">Scenery</p>
          <div class="flex gap-1 mt-2">
            {sceneryDots.map((filled) => (
              <span class={`w-2 h-2 rounded-full ${filled ? 'bg-savannah-400' : 'bg-white/20'}`}></span>
            ))}
          </div>
        </div>
        <div class="px-4 md:px-6 py-5 md:py-6">
          <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-300/80 mb-1">Traffic</p>
          <p class="font-display text-xl md:text-2xl text-white">{trafficLabel[route.data.traffic]}</p>
        </div>
        <div class="px-4 md:px-6 py-5 md:py-6">
          <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-300/80 mb-1">Sleep</p>
          <p class="font-display text-xl md:text-2xl text-white capitalize">{route.data.accommodation}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-dusk-50">
    <div class="container-content">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
        <div class="lg:col-span-7">
          <p class="eyebrow text-safari-600 mb-4">About this route</p>
          <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-6">
            {route.data.tagline}
          </h2>
          <div class="prose prose-lg max-w-none text-dusk-700 leading-relaxed space-y-5">
            <p class="text-lg">{route.data.summary}</p>
            {route.data.description && (
              <p>{route.data.description}</p>
            )}
            <Content />
          </div>
        </div>

        <aside class="lg:col-span-5 space-y-6">
          <div class="bg-white rounded-2xl border border-dusk-100 shadow-soft p-6 md:p-8">
            <p class="eyebrow text-savannah-700 mb-3">Plan your climb</p>
            <p class="text-dusk-700 leading-relaxed mb-6">Get a custom quote with exact pricing for your dates and group size.</p>

            <a href={`/contact?route=${route.id}`} class="btn btn-primary w-full justify-center">
              Plan this climb
              <ArrowRight size={16} />
            </a>
            <a href="#itinerary" class="btn btn-outline w-full justify-center mt-3">
              See full itinerary
            </a>

            <div class="border-t border-dusk-100 mt-6 pt-6 space-y-3 text-sm">
              <div class="flex items-start gap-3">
                <MapPin size={16} class="text-safari-600 flex-shrink-0 mt-0.5" />
                <div>
                  <p class="text-dusk-500 text-xs">Start</p>
                  <p class="text-dusk-900">{route.data.startPoint}</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <MapPin size={16} class="text-sunset-500 flex-shrink-0 mt-0.5" />
                <div>
                  <p class="text-dusk-500 text-xs">Finish</p>
                  <p class="text-dusk-900">{route.data.endPoint}</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <Calendar size={16} class="text-safari-600 flex-shrink-0 mt-0.5" />
                <div>
                  <p class="text-dusk-500 text-xs">Best months</p>
                  <p class="text-dusk-900">{route.data.bestMonths.slice(0, 4).join(', ')}{route.data.bestMonths.length > 4 ? `, +${route.data.bestMonths.length - 4} more` : ''}</p>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-safari-50 border border-safari-100 rounded-2xl p-6">
            <p class="eyebrow text-safari-700 mb-3">Why book with us</p>
            <ul class="space-y-2 text-sm text-dusk-700">
              <li class="flex items-start gap-2">
                <Check size={14} class="text-safari-600 flex-shrink-0 mt-0.5" />
                Arusha-based team, no middlemen
              </li>
              <li class="flex items-start gap-2">
                <Check size={14} class="text-safari-600 flex-shrink-0 mt-0.5" />
                Top-tier guides, full support crew
              </li>
              <li class="flex items-start gap-2">
                <Check size={14} class="text-safari-600 flex-shrink-0 mt-0.5" />
                Oxygen + pulse oximeter standard
              </li>
              <li class="flex items-start gap-2">
                <Check size={14} class="text-safari-600 flex-shrink-0 mt-0.5" />
                Flexible payment, fair cancellation
              </li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-content">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="eyebrow text-safari-600 mb-3">Why this route</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900">
          What makes {route.data.name} stand out
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto">
        {route.data.highlights.map((highlight) => (
          <div class="flex items-start gap-3 p-5 rounded-xl bg-dusk-50 border border-dusk-100">
            <span class="w-8 h-8 rounded-lg bg-savannah-100 text-savannah-700 flex items-center justify-center flex-shrink-0">
              <Check size={16} />
            </span>
            <p class="text-dusk-800 leading-relaxed">{highlight}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="itinerary" class="section bg-dusk-50">
    <div class="container-content">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="eyebrow text-safari-600 mb-3">Day by day</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900">
          The {route.data.durationDays}-day itinerary
        </h2>
        <p class="text-dusk-600 mt-4">
          Every day below is led by your guide, supported by our full mountain crew. Times are approximate — the schedule adjusts to weather, fitness, and how the group is acclimatizing.
        </p>
      </div>

      <div class="max-w-4xl mx-auto">
        <ol class="relative border-l-2 border-safari-200 ml-3 md:ml-6 space-y-8">
          {route.data.itinerary.map((day) => (
            <li class="pl-6 md:pl-10 relative">
              <span class="absolute -left-[11px] md:-left-[15px] top-0 flex items-center justify-center w-6 h-6 md:w-8 md:h-8 rounded-full bg-safari-600 text-white font-display text-sm">
                {day.day}
              </span>

              <div class="bg-white rounded-xl border border-dusk-100 p-6 md:p-7 shadow-soft">
                <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 mb-3">
                  <h3 class="font-display text-xl md:text-2xl text-safari-900">Day {day.day} · {day.title}</h3>
                </div>

                <div class="flex flex-wrap gap-3 text-xs text-dusk-600 mb-4">
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-dusk-100">
                    <TrendingUp size={12} class="text-safari-600" />
                    {day.elevation}
                  </span>
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-dusk-100">
                    <Calendar size={12} class="text-safari-600" />
                    {day.timeWalking}
                  </span>
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-dusk-100">
                    <Mountain size={12} class="text-safari-600" />
                    {day.terrain}
                  </span>
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-savannah-50 text-savannah-900">
                    Meals: {day.meals}
                  </span>
                </div>

                <p class="text-dusk-700 leading-relaxed mb-3">{day.description}</p>

                <p class="text-sm text-dusk-500">
                  <span class="font-semibold text-dusk-700">Sleep:</span> {day.accommodation}
                </p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-content">
      <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <div class="bg-safari-50 rounded-2xl border border-safari-100 p-7 md:p-8">
          <div class="flex items-center gap-3 mb-5">
            <span class="w-10 h-10 rounded-xl bg-safari-600 text-white flex items-center justify-center">
              <Check size={20} />
            </span>
            <h3 class="font-display text-2xl text-safari-900">What's included</h3>
          </div>
          <ul class="space-y-3">
            {route.data.inclusions.map((item) => (
              <li class="flex items-start gap-3 text-dusk-700">
                <Check size={16} class="text-safari-600 flex-shrink-0 mt-1" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-dusk-50 rounded-2xl border border-dusk-100 p-7 md:p-8">
          <div class="flex items-center gap-3 mb-5">
            <span class="w-10 h-10 rounded-xl bg-dusk-300 text-dusk-900 flex items-center justify-center">
              <X size={20} />
            </span>
            <h3 class="font-display text-2xl text-dusk-900">Not included</h3>
          </div>
          <ul class="space-y-3">
            {route.data.exclusions.map((item) => (
              <li class="flex items-start gap-3 text-dusk-700">
                <X size={16} class="text-dusk-400 flex-shrink-0 mt-1" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-dusk-50">
    <div class="container-content">
      <div class="flex items-end justify-between mb-8">
        <div>
          <p class="eyebrow text-safari-600 mb-3">Compare</p>
          <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900">
            Other Kilimanjaro routes
          </h2>
        </div>
        <a href="/kilimanjaro" class="hidden md:inline-flex items-center gap-2 text-safari-700 hover:text-safari-900 font-medium">
          See all 7 routes
          <ArrowRight size={16} />
        </a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {relatedRoutes.map((r) => (
          <a
            href={`/kilimanjaro/${r.id}`}
            class="group relative overflow-hidden rounded-2xl bg-white border border-dusk-100 hover:border-safari-300 hover:shadow-lifted transition-all"
          >
            <div class="aspect-[4/3] overflow-hidden bg-dusk-200">
              <img
                src={r.data.hero}
                alt={r.data.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="p-5">
              <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-700 mb-2">{r.data.tagline}</p>
              <h3 class="font-display text-xl text-safari-900 mb-2 group-hover:text-safari-700 transition-colors">{r.data.name}</h3>
              <p class="text-sm text-dusk-600 leading-relaxed mb-3 line-clamp-2">{r.data.summary}</p>
              <div class="flex items-center gap-3 text-xs text-dusk-500">
                <span>{r.data.durationDays} days</span>
                <span>·</span>
                <span>{r.data.successRate} success</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {relatedTours.length > 0 && (
    <section class="section bg-white">
      <div class="container-content">
        <div class="flex items-end justify-between mb-8">
          <div>
            <p class="eyebrow text-safari-600 mb-3">Kilimanjaro packages</p>
            <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900">
              Ready-made climbs on {route.data.name}
            </h2>
          </div>
          <a href="/tours?style=kilimanjaro" class="hidden md:inline-flex items-center gap-2 text-safari-700 hover:text-safari-900 font-medium">
            See all climbs
            <ArrowRight size={16} />
          </a>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {relatedTours.map((tour) => (
            <a
              href={`/tours/${tour.id}`}
              class="group relative overflow-hidden rounded-2xl bg-white border border-dusk-100 hover:border-safari-300 hover:shadow-lifted transition-all"
            >
              <div class="aspect-[4/3] overflow-hidden bg-dusk-200">
                <img
                  src={tour.data.hero}
                  alt={tour.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="p-5">
                <h3 class="font-display text-xl text-safari-900 mb-2 group-hover:text-safari-700 transition-colors">{tour.data.title}</h3>
                <p class="text-sm text-dusk-600 leading-relaxed mb-3 line-clamp-2">{tour.data.excerpt}</p>
                <div class="flex items-center gap-3 text-xs text-dusk-500">
                  <span>{tour.data.durationDays} days</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section bg-safari-900 text-white">
    <div class="container-content">
      <div class="max-w-3xl mx-auto text-center">
        <p class="eyebrow text-savannah-300 mb-3">Ready to climb?</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight mb-5">
          Plan your {route.data.name} climb
        </h2>
        <p class="text-lg text-dusk-100/90 mb-8">
          Tell us your dates and group size. We'll send a full quote within 24 hours, including gear list, sample schedule, and what to expect on the mountain.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={`/contact?route=${route.id}`} class="btn btn-primary px-8 py-3.5">
            Get a custom quote
            <ArrowRight size={16} />
          </a>
          <a href="/kilimanjaro" class="btn btn-outline-light px-8 py-3.5 border-white/30 hover:bg-white hover:text-safari-900">
            Compare routes
          </a>
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(withPublisher({
    '@context': 'https://schema.org',
    '@type': 'TouristAttraction',
    name: route.data.name,
    description: route.data.summary,
    image: route.data.hero,
    address: {
      '@type': 'PostalAddress',
      addressCountry: 'TZ',
      addressRegion: 'Kilimanjaro',
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: -3.0674,
      longitude: 37.3556,
    },
  }))} />
</PublicLayout>
