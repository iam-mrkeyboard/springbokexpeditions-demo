---
import { getCollection, getEntry, render } from 'astro:content';
import PublicLayout from '@/layouts/PublicLayout.astro';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const routes = await getCollection('kilimanjaro');
  return routes.map((r) => ({ params: { route: r.id } }));
}
import { withPublisher } from '@/lib/jsonld';
import {
  ArrowLeft, ArrowRight, MapPin, Calendar, Check, X, Mountain,
  HeartPulse, Stethoscope, Droplets, Clock, Users, Compass,
} from '@lucide/astro';

const { route: routeId } = Astro.params;
if (!routeId) return Astro.rewrite('/404');
const route = await getEntry('kilimanjaro', routeId);
if (!route) return Astro.rewrite('/404');
const { Content } = await render(route as any);

const allRoutes = await getCollection('kilimanjaro');
const relatedRoutes = allRoutes
  .filter((r) => r.id !== route.id)
  .sort((a, b) => ((a.data as any).order ?? 0) - ((b.data as any).order ?? 0))
  .slice(0, 3);

const allTreks = await getCollection('trekking');
const routeTreks = allTreks
  .filter((t) => t.data.route === route.id)
  .sort((a, b) => ((a.data as any).order ?? 0) - ((b.data as any).order ?? 0));

const trafficLabel: Record<string, string> = {
  quiet: 'Quiet',
  moderate: 'Moderate',
  busy: 'Busy',
  'very-busy': 'Very busy',
};

const difficultyLabel: Record<string, string> = {
  moderate: 'Moderate',
  challenging: 'Challenging',
  strenuous: 'Strenuous',
  expert: 'Expert',
};

const sceneryDots = Array.from({ length: 5 }, (_, i) => i < (route.data.scenery ?? 0));

const tazamaImages = {
  cta: 'https://res.cloudinary.com/drhl0yu7y/image/upload/v1759133537/kilimanjaro/call-to-action/cta-3_rhubqu.jpg',
  prep: 'https://res.cloudinary.com/drhl0yu7y/image/upload/v1759229190/kilimanjaro/main-page/kilimanjaro5_y8r9ru.webp',
};
---

<PublicLayout
  title={(route.data.seo as any)?.title ?? `${route.data.name} - ${route.data.durationDays} Days`}
  description={(route.data.seo as any)?.description ?? route.data.summary}
  transparentHeader={true}
>
  <section class="relative h-[85vh] min-h-[620px] w-full overflow-hidden bg-safari-900 text-white">
    <Image
      src={route.data.hero || ''}
      alt={`${route.data.name} landscape`}
      width={1920}
      height={1080}
      class="absolute inset-0 w-full h-full object-cover scale-105"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-tr from-black/90 via-black/50 to-black/30"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-black/40"></div>

    <div class="container-content relative z-10 h-full flex flex-col justify-end pb-20 md:pb-24 pt-32">
      <div class="max-w-3xl">
        <a href="/kilimanjaro" class="inline-flex items-center gap-2 text-savannah-300 hover:text-savannah-200 text-xs uppercase tracking-[0.18em] mb-5 md:mb-6 transition-colors">
          <ArrowLeft size={14} />
          All Kilimanjaro routes
        </a>

        <p class="eyebrow text-savannah-300 text-[11px] md:text-xs uppercase tracking-[0.18em] mb-3">{route.data.tagline}</p>

        <h1 class="font-display text-[2.8rem] sm:text-5xl md:text-6xl lg:text-7xl font-medium tracking-tight text-white mb-5 md:mb-6 leading-[1.05]">
          {route.data.name}
        </h1>

        <p class="text-lg md:text-xl text-dusk-100/90 max-w-2xl leading-relaxed font-light">
          {route.data.summary}
        </p>
      </div>
    </div>
  </section>

  <section class="bg-safari-900 text-white border-b border-white/10">
    <div class="container-content">
      <div class="grid grid-cols-2 md:grid-cols-6 divide-x divide-white/10">
        <div class="px-4 md:px-6 py-5 md:py-6">
          <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-300/80 mb-1">Duration</p>
          <p class="font-display text-xl md:text-2xl text-white">{route.data.durationDays} days</p>
        </div>
        <div class="px-4 md:px-6 py-5 md:py-6">
          <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-300/80 mb-1">Success rate</p>
          <p class="font-display text-xl md:text-2xl text-white">{route.data.successRate}</p>
        </div>
        <div class="px-4 md:px-6 py-5 md:py-6">
          <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-300/80 mb-1">Difficulty</p>
          <p class="font-display text-xl md:text-2xl text-white">{difficultyLabel[route.data.difficulty ?? '']}</p>
        </div>
        <div class="px-4 md:px-6 py-5 md:py-6">
          <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-300/80 mb-1">Scenery</p>
          <div class="flex gap-1 mt-2">
            {sceneryDots.map((filled) => (
              <span class={`w-2 h-2 rounded-full ${filled ? 'bg-savannah-400' : 'bg-white/20'}`}></span>
            ))}
          </div>
        </div>
        <div class="px-4 md:px-6 py-5 md:py-6">
          <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-300/80 mb-1">Traffic</p>
          <p class="font-display text-xl md:text-2xl text-white">{trafficLabel[route.data.traffic ?? '']}</p>
        </div>
        <div class="px-4 md:px-6 py-5 md:py-6">
          <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-300/80 mb-1">Sleep</p>
          <p class="font-display text-xl md:text-2xl text-white capitalize">{route.data.accommodation}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-dusk-50">
    <div class="container-content">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
        <div class="lg:col-span-7">
          <p class="eyebrow text-safari-600 mb-4">About this route</p>
          <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-6">
            {route.data.tagline}
          </h2>
          <div class="prose prose-lg max-w-none text-dusk-700 leading-relaxed space-y-5">
            <p class="text-lg">{route.data.summary}</p>
            {route.data.description && (
              <p>{route.data.description}</p>
            )}
            <Content />
          </div>
        </div>

        <aside class="lg:col-span-5 space-y-6">
          <div class="bg-white rounded-2xl border border-dusk-100 shadow-soft p-6 md:p-8">
            <p class="eyebrow text-savannah-700 mb-3">Plan your climb</p>
            <p class="text-dusk-700 leading-relaxed mb-6">Get a custom quote with exact pricing for your dates and group size.</p>

            <a href={`/contact?route=${route.id}`} class="btn btn-primary w-full justify-center">
              Plan this climb
              <ArrowRight size={16} />
            </a>

            <div class="border-t border-dusk-100 mt-6 pt-6 space-y-3 text-sm">
              <div class="flex items-start gap-3">
                <MapPin size={16} class="text-safari-600 flex-shrink-0 mt-0.5" />
                <div>
                  <p class="text-dusk-500 text-xs">Start</p>
                  <p class="text-dusk-900">{route.data.startPoint}</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <MapPin size={16} class="text-sunset-500 flex-shrink-0 mt-0.5" />
                <div>
                  <p class="text-dusk-500 text-xs">Finish</p>
                  <p class="text-dusk-900">{route.data.endPoint}</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <Calendar size={16} class="text-safari-600 flex-shrink-0 mt-0.5" />
                <div>
                  <p class="text-dusk-500 text-xs">Best months</p>
                  <p class="text-dusk-900">{route.data.bestMonths.slice(0, 4).join(', ')}{route.data.bestMonths.length > 4 ? `, +${route.data.bestMonths.length - 4} more` : ''}</p>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-safari-50 border border-safari-100 rounded-2xl p-6">
            <p class="eyebrow text-safari-700 mb-3">Why book with us</p>
            <ul class="space-y-2 text-sm text-dusk-700">
              <li class="flex items-start gap-2">
                <Check size={14} class="text-safari-600 flex-shrink-0 mt-0.5" />
                Arusha-based team, no middlemen
              </li>
              <li class="flex items-start gap-2">
                <Check size={14} class="text-safari-600 flex-shrink-0 mt-0.5" />
                Certified guides + full support crew
              </li>
              <li class="flex items-start gap-2">
                <Check size={14} class="text-safari-600 flex-shrink-0 mt-0.5" />
                Oxygen, pulse oximeter, medical kits
              </li>
              <li class="flex items-start gap-2">
                <Check size={14} class="text-safari-600 flex-shrink-0 mt-0.5" />
                Fair porter wages, KPAP-aligned
              </li>
              <li class="flex items-start gap-2">
                <Check size={14} class="text-safari-600 flex-shrink-0 mt-0.5" />
                Private portable toilets on every trek
              </li>
            </ul>
          </div>

          <div class="bg-white border border-dusk-100 rounded-2xl p-6">
            <p class="eyebrow text-safari-700 mb-3">Climb with conscience</p>
            <p class="text-sm text-dusk-600 leading-relaxed">
              We pay our crew above local standards, provide proper equipment, and carry all waste off the mountain. Your booking supports dignified work and helps keep Kilimanjaro pristine.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-content">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="eyebrow text-safari-600 mb-3">Why this route</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900">
          What makes {route.data.name} stand out
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto">
        {route.data.highlights.map((highlight) => (
          <div class="flex items-start gap-3 p-5 rounded-xl bg-dusk-50 border border-dusk-100 hover:border-savannah-300/60 transition-colors">
            <span class="w-8 h-8 rounded-lg bg-savannah-100 text-savannah-700 flex items-center justify-center flex-shrink-0">
              <Check size={16} />
            </span>
            <p class="text-dusk-800 leading-relaxed">{highlight}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Safety & comfort -->
  <section class="section bg-safari-900 text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <Image
        src={tazamaImages.cta}
        alt="Mountain trail scenery background"
        width={1920}
        height={1080}
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-safari-900 via-safari-900/95 to-safari-900"></div>

    <div class="container-content relative z-10">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="eyebrow text-savannah-300 mb-3">Safety & Comfort</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight mb-4">
          The details that keep you moving upward.
        </h2>
        <p class="text-dusk-200 text-lg">
          Altitude is the real test on Kilimanjaro. We stack the odds in your favor with careful pacing, daily health checks, and gear you can rely on.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 backdrop-blur-sm hover:bg-white/10 transition-colors">
          <span class="w-11 h-11 rounded-xl bg-savannah-500/20 text-savannah-300 flex items-center justify-center mb-4">
            <HeartPulse size={22} />
          </span>
          <h3 class="font-display text-lg text-white mb-2">Daily health checks</h3>
          <p class="text-sm text-dusk-200/80 leading-relaxed">Oxygen saturation, pulse, and symptom reviews every morning and evening.</p>
        </div>
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 backdrop-blur-sm hover:bg-white/10 transition-colors">
          <span class="w-11 h-11 rounded-xl bg-savannah-500/20 text-savannah-300 flex items-center justify-center mb-4">
            <Stethoscope size={22} />
          </span>
          <h3 class="font-display text-lg text-white mb-2">Rescue-ready crew</h3>
          <p class="text-sm text-dusk-200/80 leading-relaxed">Wilderness First Responder guides with oxygen, stretcher, and emergency comms.</p>
        </div>
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 backdrop-blur-sm hover:bg-white/10 transition-colors">
          <span class="w-11 h-11 rounded-xl bg-savannah-500/20 text-savannah-300 flex items-center justify-center mb-4">
            <Droplets size={22} />
          </span>
          <h3 class="font-display text-lg text-white mb-2">Private toilets</h3>
          <p class="text-sm text-dusk-200/80 leading-relaxed">Portable camp toilets at every stop for hygiene, privacy, and dignity.</p>
        </div>
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 backdrop-blur-sm hover:bg-white/10 transition-colors">
          <span class="w-11 h-11 rounded-xl bg-savannah-500/20 text-savannah-300 flex items-center justify-center mb-4">
            <Clock size={22} />
          </span>
          <h3 class="font-display text-lg text-white mb-2">Pole pole pacing</h3>
          <p class="text-sm text-dusk-200/80 leading-relaxed">Slow walking, rest days, and sleep-low ascents built into the itinerary.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Preparation -->
  <section class="section bg-white">
    <div class="container-content">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="eyebrow text-safari-600 mb-4">Prepare for Success</p>
          <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-5">
            Your part of the partnership.
          </h2>
          <p class="text-dusk-700 leading-relaxed text-lg mb-6">
            We handle permits, logistics, crew, and meals. Your job is to arrive fit, well-equipped, and ready to walk slowly. The better you prepare, the more you will enjoy every camp and every sunrise.
          </p>
          <div class="space-y-4">
            {[
              { icon: Clock, title: 'Train over 8–12 weeks', body: 'Build endurance with hiking, cycling, or swimming. Add a weighted daypack in the final month.' },
              { icon: Compass, title: 'Break in your boots', body: 'Blisters end more treks than fatigue. Wear your trekking boots on long walks before you fly.' },
              { icon: Mountain, title: 'Practice layering', body: 'Summit night can drop below -15°C. Learn to add and remove layers quickly.' },
              { icon: Users, title: 'Trust the team', body: 'Your guide sets the pace. Pole pole is not slow - it is the fastest way to the top.' },
            ].map((item) => (
              <div class="flex items-start gap-4 p-4 rounded-xl bg-dusk-50 border border-dusk-100">
                <span class="w-10 h-10 rounded-xl bg-safari-100 text-safari-700 flex items-center justify-center flex-shrink-0">
                  <item.icon size={18} />
                </span>
                <div>
                  <p class="font-medium text-safari-900">{item.title}</p>
                  <p class="text-sm text-dusk-600 leading-relaxed">{item.body}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="aspect-[4/3] rounded-2xl overflow-hidden shadow-lifted">
          <Image
            src={tazamaImages.prep}
            alt="Kilimanjaro trekking team preparing for the day's hike"
            width={800}
            height={600}
            class="w-full h-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-dusk-50">
    <div class="container-content">
      <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <div class="bg-safari-50 rounded-2xl border border-safari-100 p-7 md:p-8">
          <div class="flex items-center gap-3 mb-5">
            <span class="w-10 h-10 rounded-xl bg-safari-600 text-white flex items-center justify-center">
              <Check size={20} />
            </span>
            <h3 class="font-display text-2xl text-safari-900">What's included</h3>
          </div>
          <ul class="space-y-3">
            {(route.data.inclusions as any[])?.map((item: any) => (
              <li class="flex items-start gap-3 text-dusk-700">
                <Check size={16} class="text-safari-600 flex-shrink-0 mt-1" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-white rounded-2xl border border-dusk-100 p-7 md:p-8">
          <div class="flex items-center gap-3 mb-5">
            <span class="w-10 h-10 rounded-xl bg-dusk-300 text-dusk-900 flex items-center justify-center">
              <X size={20} />
            </span>
            <h3 class="font-display text-2xl text-dusk-900">Not included</h3>
          </div>
          <ul class="space-y-3">
            {(route.data.exclusions as any[])?.map((item: any) => (
              <li class="flex items-start gap-3 text-dusk-700">
                <X size={16} class="text-dusk-400 flex-shrink-0 mt-1" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-content">
      <div class="flex items-end justify-between mb-8">
        <div>
          <p class="eyebrow text-safari-600 mb-3">Compare</p>
          <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900">
            Other Kilimanjaro routes
          </h2>
        </div>
        <a href="/kilimanjaro" class="hidden md:inline-flex items-center gap-2 text-safari-700 hover:text-safari-900 font-medium">
          See all 7 routes
          <ArrowRight size={16} />
        </a>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {relatedRoutes.map((r) => {
          const dots = Array.from({ length: 5 }, (_, k) => k < (r.data.scenery ?? 0));
          return (
            <a
              href={`/kilimanjaro/${r.id}`}
              class="group bg-dusk-50 rounded-2xl p-6 border border-dusk-100 hover:border-savannah-300/60 hover:shadow-lifted hover:-translate-y-1 transition-all"
            >
              <div class="flex items-start justify-between mb-4">
                <div>
                  <p class="text-[10px] uppercase tracking-[0.18em] text-savannah-700 mb-1">{r.data.tagline}</p>
                  <h3 class="font-display text-xl text-safari-900 group-hover:text-safari-700 transition-colors">{r.data.name}</h3>
                </div>
                <span class="w-8 h-8 rounded-full bg-white text-safari-700 flex items-center justify-center group-hover:bg-safari-700 group-hover:text-white transition-colors">
                  <ArrowRight size={14} />
                </span>
              </div>
              <p class="text-sm text-dusk-600 leading-relaxed mb-5 line-clamp-3">{r.data.summary}</p>
              <div class="flex flex-wrap gap-2 text-xs mb-4">
                <span class="px-2 py-1 rounded-md bg-white text-dusk-700 border border-dusk-100">{r.data.durationDays} days</span>
                <span class="px-2 py-1 rounded-md bg-white text-dusk-700 border border-dusk-100">{r.data.successRate}</span>
                <span class="px-2 py-1 rounded-md bg-white text-dusk-700 border border-dusk-100">{difficultyLabel[r.data.difficulty ?? '']}</span>
              </div>
              <div class="flex items-center justify-between pt-4 border-t border-dusk-200/60">
                <div class="flex gap-0.5">
                  {dots.map((filled) => (
                    <span class={`w-1.5 h-1.5 rounded-full ${filled ? 'bg-savannah-500' : 'bg-dusk-200'}`}></span>
                  ))}
                </div>
                <span class="text-xs text-dusk-500">{trafficLabel[r.data.traffic ?? '']} · {r.data.accommodation}</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  {routeTreks.length > 0 && (
    <section class="section bg-dusk-50">
      <div class="container-content">
        <div class="flex items-end justify-between mb-8">
          <div>
            <p class="eyebrow text-safari-600 mb-3">Choose your trek</p>
            <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900">
              Ready-made {route.data.name} itineraries
            </h2>
          </div>
          <a href="/trekking" class="hidden md:inline-flex items-center gap-2 text-safari-700 hover:text-safari-900 font-medium">
            See all treks
            <ArrowRight size={16} />
          </a>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {routeTreks.map((trek) => (
            <a
              href={`/trekking/${trek.id}`}
              class="group relative overflow-hidden rounded-2xl bg-white border border-dusk-100 hover:border-safari-300 hover:shadow-lifted transition-all"
            >
              <div class="aspect-[4/3] overflow-hidden bg-dusk-200">
                <Image
                  src={trek.data.hero || ''}
                  alt={trek.data.title}
                  width={600}
                  height={450}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="p-5">
                <h3 class="font-display text-xl text-safari-900 mb-2 group-hover:text-safari-700 transition-colors">{trek.data.title}</h3>
                <p class="text-sm text-dusk-600 leading-relaxed mb-3 line-clamp-2">{trek.data.excerpt}</p>
                <div class="flex flex-wrap gap-2 text-xs">
                  <span class="px-2 py-1 rounded-md bg-dusk-50 text-dusk-700 border border-dusk-100">{trek.data.successRate}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section bg-safari-900 text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-15">
      <Image
        src={tazamaImages.cta}
        alt="Mountain trail scenery background"
        width={1920}
        height={1080}
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-safari-900 via-safari-900/95 to-safari-900"></div>

    <div class="container-content relative z-10">
      <div class="max-w-3xl mx-auto text-center">
        <p class="eyebrow text-savannah-300 mb-3">Ready to climb?</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight mb-5">
          Plan your {route.data.name} climb
        </h2>
        <p class="text-lg text-dusk-100/90 mb-8">
