---
import PublicLayout from '@/layouts/PublicLayout.astro';
import { ArrowRight, Camera, MapPin } from '@lucide/astro';
import { withPublisher } from '@/lib/jsonld';

const photos = [
  { src: 'https://images.unsplash.com/photo-1516426122078-c23e76319801?w=1600&q=80&auto=format&fit=crop', alt: 'Lion on the savannah', category: 'Wildlife', location: 'Serengeti' },
  { src: 'https://images.unsplash.com/photo-1505881502353-a1986add3762?w=1600&q=80&auto=format&fit=crop', alt: 'Zanzibar beach at sunset', category: 'Zanzibar', location: 'Nungwi' },
  { src: 'https://images.unsplash.com/photo-1547471080-7cc2caa01a7e?w=1600&q=80&auto=format&fit=crop', alt: 'Elephants in the wild', category: 'Wildlife', location: 'Tarangire' },
  { src: 'https://images.unsplash.com/photo-1535941339077-2dd1c7963098?w=1600&q=80&auto=format&fit=crop', alt: 'Wildebeest migration', category: 'Wildlife', location: 'Mara River' },
  { src: 'https://images.unsplash.com/photo-1504432842672-1a79f78e4084?w=1600&q=80&auto=format&fit=crop', alt: 'Maasai village', category: 'Culture', location: 'Ngorongoro' },
  { src: 'https://images.unsplash.com/photo-1518733057094-95b53143d2a7?w=1600&q=80&auto=format&fit=crop', alt: 'Romantic dinner on safari', category: 'Safari', location: 'Lake Manyara' },
  { src: 'https://images.unsplash.com/photo-1589308078059-be1415eab4c3?w=1600&q=80&auto=format&fit=crop', alt: 'Kilimanjaro summit at sunrise', category: 'Kilimanjaro', location: 'Uhuru Peak' },
  { src: 'https://images.unsplash.com/photo-1601275253872-8470e23f0a96?w=1600&q=80&auto=format&fit=crop', alt: 'Stone Town alley', category: 'Zanzibar', location: 'Stone Town' },
  { src: 'https://images.unsplash.com/photo-1502175353174-a7a1e8a2b3c2?w=1600&q=80&auto=format&fit=crop', alt: 'Family on safari', category: 'Safari', location: 'Ngorongoro' },
  { src: 'https://images.unsplash.com/photo-1444464666168-49d633b86797?w=1600&q=80&auto=format&fit=crop', alt: 'Lilac-breasted roller', category: 'Birding', location: 'Manyara' },
  { src: 'https://images.unsplash.com/photo-1500099817043-86d46000d58f?w=1600&q=80&auto=format&fit=crop', alt: 'Cheetah on the plains', category: 'Wildlife', location: 'Serengeti' },
  { src: 'https://images.unsplash.com/photo-1504898770365-cf1bdbd205c4?w=1600&q=80&auto=format&fit=crop', alt: 'Giraffes at sunset', category: 'Wildlife', location: 'Tarangire' },
  { src: 'https://images.unsplash.com/photo-1542038784456-1ea8e935640e?w=1600&q=80&auto=format&fit=crop', alt: 'Leopard in a tree', category: 'Wildlife', location: 'Serengeti' },
  { src: 'https://images.unsplash.com/photo-1612264257985-0ce4d4c70e1e?w=1600&q=80&auto=format&fit=crop', alt: 'Sunrise over the savannah', category: 'Safari', location: 'Serengeti' },
  { src: 'https://images.unsplash.com/photo-1535083783855-76ae62b2914e?w=1600&q=80&auto=format&fit=crop', alt: 'Zebras crossing', category: 'Wildlife', location: 'Serengeti' },
  { src: 'https://images.unsplash.com/photo-1567608198472-a03d5e4b9ed0?w=1600&q=80&auto=format&fit=crop', alt: 'Beach at sunset', category: 'Zanzibar', location: 'Kendwa' },
  { src: 'https://images.unsplash.com/photo-1551085254-e96b210db58a?w=1600&q=80&auto=format&fit=crop', alt: 'Spice farm', category: 'Zanzibar', location: 'Stone Town' },
  { src: 'https://images.unsplash.com/photo-1547721064-da6cfb341d50?w=1600&q=80&auto=format&fit=crop', alt: 'Herd of elephants', category: 'Wildlife', location: 'Tarangire' },
  { src: 'https://images.unsplash.com/photo-1517824806704-9040b037703b?w=1600&q=80&auto=format&fit=crop', alt: 'Crater view from the rim', category: 'Safari', location: 'Ngorongoro' },
  { src: 'https://images.unsplash.com/photo-1551431009-a802eeec77b1?w=1600&q=80&auto=format&fit=crop', alt: 'Hot air balloon over the Serengeti', category: 'Safari', location: 'Serengeti' },
  { src: 'https://images.unsplash.com/photo-1500964757637-c85e8a162699?w=1600&q=80&auto=format&fit=crop', alt: 'Hadzabe hunter', category: 'Culture', location: 'Lake Eyasi' },
  { src: 'https://images.unsplash.com/photo-1505252585461-04db1eb84625?w=1600&q=80&auto=format&fit=crop', alt: 'Hippo pool', category: 'Wildlife', location: 'Ngorongoro' },
  { src: 'https://images.unsplash.com/photo-1551845041-63e8e76836ea?w=1600&q=80&auto=format&fit=crop', alt: 'Dhow at sunset', category: 'Zanzibar', location: 'Nungwi' },
  { src: 'https://images.unsplash.com/photo-1564677815547-2c8f9e8e8dfd?w=1600&q=80&auto=format&fit=crop', alt: 'Buffalo herd', category: 'Wildlife', location: 'Serengeti' },
];

const allCategories = ['All', ...Array.from(new Set(photos.map((p) => p.category))).sort()];
---

<PublicLayout
  title="Gallery — Tanzania Safari Photos & Videos"
  description="A photo gallery from across Tanzania — the Serengeti, Kilimanjaro, Zanzibar, and the cultural sites. Curated by the Springbok team in Arusha."
  transparentHeader={true}
>
  <!-- Hero -->
  <section class="relative h-[60vh] min-h-[420px] w-full overflow-hidden bg-safari-900 text-white">
    <img
      src="https://images.unsplash.com/photo-1516426122078-c23e76319801?w=1920&q=80&auto=format&fit=crop"
      alt="Tanzania gallery"
      class="absolute inset-0 w-full h-full object-cover scale-105"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-tr from-black/85 via-black/45 to-black/20"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-black/40"></div>

    <div class="container-content relative z-10 h-full flex flex-col justify-end pb-12 md:pb-16 pt-32">
      <div class="max-w-3xl">
        <p class="eyebrow text-savannah-300 text-[11px] md:text-xs uppercase tracking-[0.18em] mb-3">
          <Camera size={12} class="inline-block mr-1 -mt-0.5" /> Field photography · 2025–2026
        </p>

        <h1 class="font-display text-[2.6rem] sm:text-6xl md:text-7xl lg:text-display-lg font-medium tracking-tight text-white mb-5 md:mb-6">
          The Springbok<br />
          <span class="italic font-normal text-savannah-300">gallery.</span>
        </h1>

        <p class="text-lg md:text-xl text-dusk-100/90 max-w-2xl leading-relaxed font-light">
          A curated selection of photos from across Tanzania — the wildlife, the landscapes, the people, and the coast. All shot on location by our team and guests.
        </p>
      </div>
    </div>
  </section>

  <!-- Filter -->
  <section class="bg-safari-900 text-white border-t border-white/10 sticky top-20 z-30 backdrop-blur">
    <div class="container-content">
      <div class="flex flex-wrap items-center gap-2 py-4">
        <span class="text-xs uppercase tracking-wider text-dusk-300 mr-2">Filter</span>
        {allCategories.map((cat) => (
          <button
            data-filter={cat}
            class="gallery-filter px-3 py-1.5 rounded-full text-xs uppercase tracking-wider text-dusk-200 hover:bg-white/10 hover:text-white transition-colors"
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery grid -->
  <section class="section bg-dusk-50">
    <div class="container-content">
      <div id="gallery-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3 md:gap-4">
        {photos.map((photo, i) => (
          <figure
            data-category={photo.category}
            class:list={[
              'gallery-item group relative overflow-hidden rounded-xl bg-dusk-200 cursor-pointer',
              i % 7 === 0 || i % 7 === 4 ? 'sm:col-span-2 sm:row-span-2' : '',
            ]}
          >
            <div class:list={[
              'aspect-square',
              i % 7 === 0 || i % 7 === 4 ? 'sm:aspect-square' : '',
            ]}>
              <img
                src={photo.src}
                alt={photo.alt}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading={i < 8 ? 'eager' : 'lazy'}
                decoding="async"
              />
            </div>
            <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/85 via-black/40 to-transparent p-4 translate-y-2 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300">
              <p class="text-white text-sm font-medium leading-tight mb-1">{photo.alt}</p>
              <p class="text-dusk-200 text-xs flex items-center gap-1">
                <MapPin size={10} />
                {photo.location}
              </p>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section bg-white">
    <div class="container-content">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center max-w-4xl mx-auto">
        <div>
          <p class="font-display text-4xl md:text-5xl text-savannah-500">{photos.length}+</p>
          <p class="text-xs uppercase tracking-[0.18em] text-dusk-500 mt-2">Photos in the gallery</p>
        </div>
        <div>
          <p class="font-display text-4xl md:text-5xl text-savannah-500">{allCategories.length - 1}</p>
          <p class="text-xs uppercase tracking-[0.18em] text-dusk-500 mt-2">Categories</p>
        </div>
        <div>
          <p class="font-display text-4xl md:text-5xl text-savannah-500">15+</p>
          <p class="text-xs uppercase tracking-[0.18em] text-dusk-500 mt-2">National parks covered</p>
        </div>
        <div>
          <p class="font-display text-4xl md:text-5xl text-savannah-500">1,100+</p>
          <p class="text-xs uppercase tracking-[0.18em] text-dusk-500 mt-2">Bird species seen</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section bg-safari-900 text-white">
    <div class="container-content">
      <div class="max-w-3xl mx-auto text-center">
        <p class="eyebrow text-savannah-300 mb-3">Inspired?</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight mb-5">
          See it for yourself
        </h2>
        <p class="text-lg text-dusk-100/90 mb-8">
          Tell us what you want to see, and we'll design a trip around it — private guides, the right lodges, and the right timing.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/contact" class="btn btn-primary px-8 py-3.5">
            Get a draft itinerary
            <ArrowRight size={16} />
          </a>
          <a href="/tours" class="btn btn-outline-light px-8 py-3.5 border-white/30 hover:bg-white hover:text-safari-900">
            See ready-made tours
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- JSON-LD -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(withPublisher({
    '@context': 'https://schema.org',
    '@type': 'ImageGallery',
    name: 'Tanzania Safari Gallery',
    description: 'A photo gallery from across Tanzania — wildlife, landscapes, culture, and the coast.',
    provider: {
      '@type': 'Organization',
      name: 'Springbok Expeditions',
      url: 'https://springbokexpeditions.com',
    },
  }))} />
</PublicLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.gallery-filter');
  const items = document.querySelectorAll<HTMLElement>('.gallery-item');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;

      buttons.forEach((b) => {
        b.classList.remove('bg-savannah-500', 'text-safari-900', 'font-semibold');
        b.classList.add('text-dusk-200');
      });
      btn.classList.add('bg-savannah-500', 'text-safari-900', 'font-semibold');
      btn.classList.remove('text-dusk-200');

      items.forEach((item) => {
        const matches = filter === 'All' || item.dataset.category === filter;
        (item as HTMLElement).style.display = matches ? '' : 'none';
      });
    });
  });
</script>
