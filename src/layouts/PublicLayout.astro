---
import '@fontsource-variable/fraunces/wght.css';
import '@fontsource-variable/inter/wght.css';
import '@/styles/global.css';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import { siteInfo, absoluteUrl } from '@/lib/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  hideHeader?: boolean;
  hideFooter?: boolean;
  transparentHeader?: boolean;
  type?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  author?: string;
  imageAlt?: string;
}

const {
  title,
  description,
  ogImage,
  noindex = false,
  hideHeader = false,
  hideFooter = false,
  transparentHeader = false,
  type = 'website',
  publishedTime,
  modifiedTime,
  author = siteInfo.name,
  imageAlt,
} = Astro.props;

// Static site settings
const dbSiteName: string | undefined = undefined;
const contact: { phone?: string; whatsapp?: string; email?: string; address?: string } = {};
const social: { facebook?: string; instagram?: string; whatsapp?: string; tripadvisor?: string } = {};
const footer: { copyright?: string; tagline?: string } = {};

const resolvedName = dbSiteName || siteInfo.name;
const fullTitle = title
  ? (title.includes(resolvedName) ? title : `${title} | ${resolvedName}`)
  : `${resolvedName} | Premium Tanzania Safaris & Kilimanjaro Climbs`;

const finalDescription = description || siteInfo.description;
const canonicalUrl = new URL(Astro.url.pathname, siteInfo.url).toString();
const finalOgImage = ogImage || siteInfo.defaultOgImage;
const ogImageUrl = finalOgImage.startsWith('http') ? finalOgImage : absoluteUrl(finalOgImage);
const finalImageAlt = imageAlt || fullTitle;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content={siteInfo.themeColor} />
    <meta name="color-scheme" content="light" />
    <meta name="geo.region" content={siteInfo.address.countryCode} />
    <meta name="geo.placename" content={siteInfo.address.city} />

    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <title>{fullTitle}</title>
    <meta name="description" content={finalDescription} />
    <meta name="author" content={author} />

    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={finalImageAlt} />
    <meta property="og:site_name" content={resolvedName} />
    <meta property="og:locale" content="en_US" />
    {publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime.toISOString()} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={finalDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={finalImageAlt} />

    <link rel="preconnect" href="https://images.unsplash.com" />
    <link rel="preconnect" href="https://res.cloudinary.com" />
    <link rel="dns-prefetch" href="https://res.cloudinary.com" />

    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col bg-dusk-50 text-dusk-900">
    {!hideHeader && <Header transparent={transparentHeader} siteName={resolvedName} />}
    <main class:list={["flex-1", !transparentHeader && "pt-20"]}>
      <slot />
    </main>
    {!hideFooter && <Footer siteName={resolvedName} contact={contact} social={social} footer={footer} />}
  </body>
</html>
