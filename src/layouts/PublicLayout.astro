---
import '@fontsource-variable/fraunces/wght.css';
import '@fontsource-variable/inter/wght.css';
import '@/styles/global.css';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import { siteInfo, absoluteUrl } from '@/lib/site';
import { SEO } from 'astro-seo';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  hideHeader?: boolean;
  hideFooter?: boolean;
  transparentHeader?: boolean;
  type?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  author?: string;
  imageAlt?: string;
}

const {
  title,
  description,
  ogImage,
  noindex = false,
  hideHeader = false,
  hideFooter = false,
  transparentHeader = false,
  type = 'website',
  publishedTime,
  modifiedTime,
  author = siteInfo.name,
  imageAlt,
} = Astro.props;

const resolvedName = siteInfo.name;
const contact = {
  phone: siteInfo.phone,
  whatsapp: siteInfo.whatsapp,
  email: siteInfo.email,
  address: `${siteInfo.address.city}, ${siteInfo.address.country}`,
};
const social = {
  facebook: siteInfo.social.facebook,
  instagram: siteInfo.social.instagram,
  tripadvisor: siteInfo.social.tripadvisor,
};
const footer = {
  tagline: siteInfo.tagline,
};
const fullTitle = title
  ? (title.includes(resolvedName) ? title : `${title} | ${resolvedName}`)
  : `${resolvedName} | Premium Tanzania Safaris & Kilimanjaro Climbs`;

const finalDescription = description || siteInfo.description;
const canonicalUrl = new URL(Astro.url.pathname, siteInfo.url).toString();
const finalOgImage = ogImage || siteInfo.defaultOgImage;
const ogImageUrl = finalOgImage.startsWith('http') ? finalOgImage : absoluteUrl(finalOgImage);
const finalImageAlt = imageAlt || fullTitle;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content={siteInfo.themeColor} />
    <meta name="color-scheme" content="light" />
    <meta name="geo.region" content={siteInfo.address.countryCode} />
    <meta name="geo.placename" content={siteInfo.address.city} />

    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <SEO
      title={fullTitle}
      description={finalDescription}
      canonical={canonicalUrl}
      openGraph={{
        basic: {
          title: fullTitle,
          type: type,
          image: ogImageUrl,
          url: canonicalUrl,
        },
        image: {
          alt: finalImageAlt,
        },
        optional: {
          description: finalDescription,
          siteName: resolvedName,
          locale: 'en_US',
          ...(publishedTime && { publishedTime: publishedTime.toISOString() }),
          ...(modifiedTime && { modifiedTime: modifiedTime.toISOString() }),
          ...(author && { author }),
        },
      }}
      twitter={{
        card: 'summary_large_image',
        title: fullTitle,
        description: finalDescription,
        image: ogImageUrl,
        imageAlt: finalImageAlt,
      }}
      extend={{
        link: [
          { rel: 'preconnect', href: 'https://images.unsplash.com' },
          { rel: 'preconnect', href: 'https://res.cloudinary.com' },
          { rel: 'dns-prefetch', href: 'https://res.cloudinary.com' },
        ],
        meta: [
          { name: 'author', content: author },
        ],
      }}
    />

    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col bg-dusk-50 text-dusk-900">
    {!hideHeader && <Header transparent={transparentHeader} siteName={resolvedName} />}
    <main class:list={["flex-1", !transparentHeader && "pt-20"]}>
      <slot />
    </main>
    {!hideFooter && <Footer siteName={resolvedName} contact={contact} social={social} footer={footer} />}
  </body>
</html>
