---
interface Props {
  size?: number;
  class?: string;
  style?: string;
}

const { size = 24, class: cls, style } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  width={size}
  height={size}
  class={cls}
  style={style}
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
>
  <circle cx="12" cy="13" r="7" />
  <circle cx="8" cy="10" r="2.5" />
  <circle cx="16" cy="10" r="2.5" />
  <circle cx="8" cy="10" r="1" fill="currentColor" stroke="none" />
  <circle cx="16" cy="10" r="1" fill="currentColor" stroke="none" />
  <path d="M5 7.5L7.5 10" />
  <path d="M19 7.5L16.5 10" />
  <polygon points="11,12.5 13,12.5 12,14" fill="currentColor" stroke="none" />
</svg>
