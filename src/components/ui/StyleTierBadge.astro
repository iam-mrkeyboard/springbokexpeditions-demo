---
import { STYLE_TIERS, type StyleTier } from '@/lib/badges';

interface Props {
  tier: StyleTier;
  size?: 'sm' | 'md' | 'lg';
  showIcon?: boolean;
  variant?: 'solid' | 'chip' | 'soft';
  class?: string;
}

const { tier, size = 'md', showIcon = true, variant = 'chip', class: className = '' } = Astro.props;
const tierConfig = STYLE_TIERS[tier];
const Icon = tierConfig.icon;

// Pick the right style for the variant
const variantClass = variant === 'solid'
  ? tierConfig.accent
  : variant === 'soft'
  ? tierConfig.bg
  : tierConfig.chip;
---

<span class={`tier-badge tier-badge-${size} tier-badge-${variant} ${variantClass} ${className}`}>
  {showIcon && <Icon class="tier-badge-icon" aria-hidden="true" />}
  <span class="tier-badge-label">{tierConfig.label}</span>
</span>

<style>
  .tier-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 9999px;
    white-space: nowrap;
    line-height: 1;
    transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: 0 1px 2px rgba(15, 42, 28, 0.08);
  }
  .tier-badge:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(15, 42, 28, 0.15);
  }
  .tier-badge-sm { padding: 0.3125rem 0.625rem; font-size: 0.625rem; gap: 0.25rem; }
  .tier-badge-sm .tier-badge-icon { width: 0.6875rem; height: 0.6875rem; }
  .tier-badge-md { padding: 0.4375rem 0.8125rem; font-size: 0.6875rem; }
  .tier-badge-md .tier-badge-icon { width: 0.75rem; height: 0.75rem; }
  .tier-badge-lg { padding: 0.5625rem 1.125rem; font-size: 0.75rem; gap: 0.5rem; }
  .tier-badge-lg .tier-badge-icon { width: 0.875rem; height: 0.875rem; }
  .tier-badge-icon {
    flex-shrink: 0;
  }
  .tier-badge-label {
    letter-spacing: 0.1em;
  }
</style>
