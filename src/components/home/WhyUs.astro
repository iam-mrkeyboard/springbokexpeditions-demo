---
import { Leaf, Heart, Users, Compass } from '@lucide/astro';

const promises = [
  {
    icon: Compass,
    title: 'Expertly Curated Safaris',
    body: 'Whether it\'s the Great Migration in the Serengeti, the majestic Ngorongoro Crater, or trekking Mount Kilimanjaro, we provide tailor-made experiences that match your travel style.',
  },
  {
    icon: Users,
    title: 'Local Expertise',
    body: 'Our guides are highly knowledgeable about Tanzania\'s wildlife, history, and hidden gems.',
  },
  {
    icon: Leaf,
    title: 'Sustainable & Ethical Travel',
    body: 'We support local communities and conservation efforts, ensuring responsible tourism.',
  },
  {
    icon: Heart,
    title: 'Personalized Service',
    body: 'Whether you prefer luxury lodges or off-the-grid adventures, we design trips that suit your budget and preferences.',
  },
];
---

<section class="section bg-dusk-50">
  <div class="container-content">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div>
        <span class="inline-block bg-savannah-100 text-savannah-800 px-2 py-0.5 rounded text-[11px] font-bold tracking-wider uppercase mb-4">
          Why Springbok
        </span>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-6">
          A tour operator that <span class="italic text-savannah-700">actually lives</span> in Tanzania
        </h2>
        <p class="text-dusk-700 text-lg leading-relaxed mb-6">
          We're not a booking platform. We're a small, locally-owned team based in Arusha, the gateway to every Tanzanian safari.
        </p>
        <p class="text-dusk-700 text-lg leading-relaxed mb-8">
          That means better prices, real expertise, and the kind of flexibility that turns a good trip into an unforgettable one.
        </p>
        <a href="/about" class="btn btn-secondary">Learn more</a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {promises.map((p) => (
          <div class="bg-white rounded-2xl p-6 shadow-soft">
            <div class="w-12 h-12 rounded-xl bg-savannah-100 flex items-center justify-center mb-4">
              <p.icon size={22} class="text-savannah-700" />
            </div>
            <h3 class="font-display text-lg font-medium text-safari-900 mb-2">{p.title}</h3>
            <p class="text-sm text-dusk-700 leading-relaxed">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
