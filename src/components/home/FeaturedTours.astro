---
import { ArrowRight } from '@lucide/astro';
import { isValidStyleTier, isValidExperienceBadge, getStyleTier, getExperienceBadge } from '@/lib/badges';
import Badge from '@/components/ui/Badge.astro';
import { Image } from 'astro:assets';

interface Tour {
  slug: string;
  title: string;
  durationDays: number;
  summary: string;
  hero: string;
  destination: string;
  type: string;
  typeLabel?: string;
  styles?: string[];
  badges?: string[];
}

interface Props {
  tours: Tour[];
  eyebrow?: string;
  heading?: string;
  subheading?: string;
}

const {
  tours = [],
  eyebrow = 'Featured Itineraries',
  heading = 'Signature safaris, ready to book',
  subheading = "Hand-picked routes that combine Tanzania's most iconic parks and experiences. Customize any of them, or use them as inspiration for your own.",
} = Astro.props;
---

<section class="section bg-white">
  <div class="container-content">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
      <div class="max-w-2xl">
        <p class="eyebrow mb-3">{eyebrow}</p>
        <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900">
          {heading}
        </h2>
        <p class="text-dusk-700 text-lg leading-relaxed mt-4">{subheading}</p>
      </div>
      <a href="/tours" class="btn btn-ghost self-start md:self-auto">
        View all safaris
        <ArrowRight size={16} />
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {tours.slice(0, 9).map((tour) => {
        const tier = tour.styles && isValidStyleTier(tour.styles[0])
          ? tour.styles[0]
          : null;
        const tierMeta = tier ? getStyleTier(tier) : null;
        const badges = (tour.badges || []).filter(isValidExperienceBadge).slice(0, 3);
        return (
          <a href={`/tours/${tour.slug}`} class="card card-hover group block">
            <div class="relative aspect-[4/3] overflow-hidden">
              <Image
                src={tour.hero}
                alt={tour.title}
                width={600}
                height={450}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
              {tour.type && (
                <div class="absolute top-3 right-3">
                  <Badge label={tour.typeLabel || tour.type} size="sm" variant="type" />
                </div>
              )}
              {tier && tierMeta && (
                <div class="absolute top-3 left-3">
                  <Badge label={tierMeta.label} icon={tierMeta.icon} tier={tier} size="sm" variant="chip" />
                </div>
              )}
            </div>
            <div class="p-6">
              <h3 class="font-display text-xl font-medium text-safari-900 mb-2 group-hover:text-savannah-700 transition-colors">
                {tour.title}
              </h3>
              <p class="text-sm text-dusk-700 leading-relaxed mb-3 line-clamp-2">{tour.summary}</p>

              {badges.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mb-3">
                  {badges.map((badgeKey) => {
                    const meta = getExperienceBadge(badgeKey);
                    return <Badge label={meta.label} icon={meta.icon} size="xs" variant="soft" />;
                  })}
                </div>
              )}
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>
