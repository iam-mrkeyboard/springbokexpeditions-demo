---
import { ArrowRight } from '@lucide/astro';
import { cloudinaryVideoUrl, cloudinaryImageUrl } from '@/lib/cloudinary';

interface Props {
  eyebrow?: string;
  headingLine1?: string;
  headingLine2?: string;
  headingItalic?: string;
  posterUrl?: string;
  videoSrc?: string;
  videoSrcMobile?: string;
  ctaLabel?: string;
  ctaHref?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryHref?: string;
  priceLine?: string;
  body?: string;
}

const {
  eyebrow = 'Safaris · Kilimanjaro · Zanzibar',
  headingLine1 = 'Your Tanzania trip.',
  headingLine2 = 'Built by the people',
  headingItalic = 'who live here.',
  posterUrl = cloudinaryImageUrl('spring/hero-bg-poster_oz8n9n') || '/hero-bg-poster.jpg',
  videoSrc = cloudinaryVideoUrl('spring/hero-bg_llkoyg') || '/hero-bg.mp4',
  videoSrcMobile = cloudinaryVideoUrl('spring/hero-bg-mobile_xo9pvc') || '/hero-bg-mobile.mp4',
  ctaLabel = 'Plan with us',
  ctaHref = '/contact',
  ctaSecondaryLabel = 'See our safaris',
  ctaSecondaryHref = '/tours',
  body = 'Tailor-made safaris, Kilimanjaro climbs, and Zanzibar weeks — designed, booked, and guided by the same Arusha team. No middlemen, no call centres.',
} = Astro.props;
---

<section class="relative h-[100svh] min-h-[640px] w-full overflow-hidden bg-safari-900 text-white">
  <!-- Background: Cloudinary-hosted MP4, autoplays muted + loops. Two sources: 720p desktop, 540p mobile. -->
  <div class="absolute inset-0 z-0 overflow-hidden bg-safari-900">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster={posterUrl}
      class="absolute inset-0 w-full h-full object-cover scale-105"
    >
      <source src={videoSrcMobile} type="video/mp4" media="(max-width: 768px)" />
      <source src={videoSrc} type="video/mp4" />
    </video>

    <div class="absolute inset-0 bg-gradient-to-tr from-black/80 via-black/40 to-black/20"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-black/40"></div>
  </div>

  <!-- Content — bottom-left, leaving the rest of the hero visible -->
  <div class="container-content relative z-10 h-full flex flex-col justify-end pb-20 md:pb-24 pt-32">
    <div class="max-w-2xl">
      <div class="flex items-center gap-3 mb-5 md:mb-6">
        <span class="h-px w-10 md:w-14 bg-savannah-500"></span>
        <p class="eyebrow text-savannah-300 text-[11px] md:text-xs uppercase tracking-[0.18em]">{eyebrow}</p>
      </div>

      <h1 class="font-display text-[2.6rem] leading-[1.02] sm:text-5xl md:text-6xl lg:text-7xl font-medium tracking-tight text-white mb-5 md:mb-6">
        {headingLine1}<br />
        <span class="text-white/85">{headingLine2}</span><br />
        <span class="italic font-normal text-savannah-300">{headingItalic}</span>
      </h1>

      <p class="text-base md:text-lg text-dusk-100/85 max-w-xl mb-6 md:mb-8 leading-relaxed font-light">
        {body}
      </p>

      <div class="flex flex-wrap items-center gap-3 md:gap-4">
        <a href={ctaHref} class="btn btn-primary px-6 md:px-7 py-3 md:py-3.5">
          {ctaLabel}
          <ArrowRight size={16} />
        </a>
        <a
          href={ctaSecondaryHref}
          class="btn btn-outline-light px-6 md:px-7 py-3 md:py-3.5 border-white/30 hover:bg-white hover:text-safari-900"
        >
          {ctaSecondaryLabel}
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom-right: scroll indicator -->
  <div class="absolute bottom-6 right-6 md:right-10 z-20 hidden md:flex flex-col items-center gap-2 text-dusk-300/80 text-[10px] uppercase tracking-[0.3em]">
    <span class="rotate-90 origin-center whitespace-nowrap">Scroll</span>
    <span class="w-px h-10 bg-gradient-to-b from-savannah-500/80 to-transparent"></span>
  </div>
</section>
