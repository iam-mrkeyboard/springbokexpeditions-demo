---
import { Calendar, Sun } from '@lucide/astro';

const months = [
  { name: 'Jan', migration: 'high', wildlife: 'high', kilimanjaro: 'high' },
  { name: 'Feb', migration: 'high', wildlife: 'high', kilimanjaro: 'high' },
  { name: 'Mar', migration: 'med', wildlife: 'high', kilimanjaro: 'med' },
  { name: 'Apr', migration: 'low', wildlife: 'med', kilimanjaro: 'low' },
  { name: 'May', migration: 'low', wildlife: 'med', kilimanjaro: 'low' },
  { name: 'Jun', migration: 'med', wildlife: 'high', kilimanjaro: 'high' },
  { name: 'Jul', migration: 'high', wildlife: 'high', kilimanjaro: 'high' },
  { name: 'Aug', migration: 'high', wildlife: 'high', kilimanjaro: 'high' },
  { name: 'Sep', migration: 'high', wildlife: 'high', kilimanjaro: 'high' },
  { name: 'Oct', migration: 'med', wildlife: 'high', kilimanjaro: 'high' },
  { name: 'Nov', migration: 'med', wildlife: 'med', kilimanjaro: 'med' },
  { name: 'Dec', migration: 'high', wildlife: 'high', kilimanjaro: 'med' },
];

const ratings = { high: 'bg-sunset-500', med: 'bg-savannah-300', low: 'bg-dusk-200' };
---

<section class="section bg-white">
  <div class="container-content">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <p class="eyebrow mb-3">Best Time to Visit</p>
      <h2 class="text-display-sm md:text-display-md font-display font-medium tracking-tight text-safari-900 mb-5">
        Tanzania, month by month
      </h2>
      <p class="text-dusk-700 text-lg leading-relaxed">
        Tanzania is a year-round destination, but every season has its highlights. Here's a quick guide to help you choose.
      </p>
    </div>

    <div class="bg-dusk-50 rounded-3xl p-6 md:p-10">
      <!-- Calendar grid -->
      <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-12 gap-2 mb-8">
        {months.map((m) => (
          <div class="text-center">
            <div class="text-xs font-medium text-dusk-700 mb-2">{m.name}</div>
            <div class="space-y-1">
              <div class={`h-2 rounded-full ${ratings[m.migration as keyof typeof ratings]}`} title={`Migration: ${m.migration}`}></div>
              <div class={`h-2 rounded-full ${ratings[m.wildlife as keyof typeof ratings]}`} title={`Wildlife: ${m.wildlife}`}></div>
              <div class={`h-2 rounded-full ${ratings[m.kilimanjaro as keyof typeof ratings]}`} title={`Kilimanjaro: ${m.kilimanjaro}`}></div>
            </div>
          </div>
        ))}
      </div>

      <!-- Legend -->
      <div class="flex flex-wrap items-center justify-center gap-6 mb-10 text-sm text-dusk-700">
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-sunset-500"></span> Peak
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-savannah-300"></span> Shoulder
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-dusk-200"></span> Low
        </div>
        <span class="text-dusk-500">·</span>
        <span>Migration · Wildlife · Kilimanjaro</span>
      </div>

      <!-- Season highlights -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <div class="bg-white rounded-2xl p-6">
          <div class="flex items-center gap-2 mb-3">
            <Calendar size={18} class="text-savannah-700" />
            <h3 class="font-display text-lg font-medium text-safari-900">Calving Season</h3>
          </div>
          <p class="text-sm text-dusk-700 leading-relaxed">
            <strong class="text-safari-900">January – March.</strong> Over 500,000 calves are born on the Ndutu Plains. Predators are everywhere. A photographer's dream.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-6">
          <div class="flex items-center gap-2 mb-3">
            <Calendar size={18} class="text-savannah-700" />
            <h3 class="font-display text-lg font-medium text-safari-900">Mara River Crossings</h3>
          </div>
          <p class="text-sm text-dusk-700 leading-relaxed">
            <strong class="text-safari-900">July – October.</strong> The world's most dramatic wildlife spectacle. Wildebeest plunge into crocodile-infested waters in the northern Serengeti.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-6">
          <div class="flex items-center gap-2 mb-3">
            <Sun size={18} class="text-savannah-700" />
            <h3 class="font-display text-lg font-medium text-safari-900">Dry Season</h3>
          </div>
          <p class="text-sm text-dusk-700 leading-relaxed">
            <strong class="text-safari-900">June – October.</strong> Best wildlife viewing across all parks. Animals congregate at water sources. Clear skies, cool nights.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
