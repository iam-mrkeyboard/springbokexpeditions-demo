---
import {
  Wind, Trees, Users, MapPin, Ship, Moon, UtensilsCrossed,
  Compass, Send, Check, X, ArrowLeft, ArrowRight
} from '@lucide/astro';

interface Props {
  tour: {
    id: string;
    data: {
      title: string;
      durationDays: number;
      type: string;
    };
  };
}

const { tour } = Astro.props;
const modalId = `enquiry-modal-${tour.id}`;
const today = new Date().toISOString().split('T')[0];

const activities = [
  { value: 'hot-air-balloon', label: 'Hot Air Balloon Safaris', sub: 'Soar above the Serengeti at sunrise', icon: Wind },
  { value: 'walking-safari', label: 'Walking Safaris', sub: 'Track wildlife on foot with armed rangers', icon: Trees },
  { value: 'cultural-tours', label: 'Cultural Tours', sub: 'Meet the Maasai, Hadzabe, and local tribes', icon: Users },
  { value: 'arusha-city-tour', label: 'Arusha City Tour', sub: 'Discover local markets and Maasai culture', icon: MapPin },
  { value: 'canoeing', label: 'Canoeing Safaris', sub: 'Paddle among hippos and flamingos', icon: Ship },
  { value: 'night-game-drive', label: 'Night Game Drive', sub: 'Spot nocturnal predators active after dark', icon: Moon },
  { value: 'bush-dining', label: 'Bush Lunch / Dinner', sub: 'Dine in the wild savannah', icon: UtensilsCrossed },
  { value: 'stone-town-tour', label: 'Stone Town Tour', sub: 'Explore historic Stone Town and spice farms', icon: Compass }
];

const budgetOptions = [
  { value: 'under-2000', label: 'Under $2,000' },
  { value: '2000-4000', label: '$2,000–$4,000' },
  { value: '4000-6000', label: '$4,000–$6,000' },
  { value: '6000-plus', label: '$6,000+' }
];
---

<dialog
  id={modalId}
  class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 m-0 rounded-2xl border border-dusk-100 shadow-xl max-w-2xl w-[95%] p-0 bg-white backdrop:bg-black/40 backdrop:backdrop-blur-xs overflow-hidden outline-hidden focus:outline-hidden"
  closedby="any"
  aria-labelledby={`${modalId}-title`}
>
  <!-- Modal Header / Tour Info -->
  <div class="bg-safari-900 text-white px-4 py-3 sm:px-6 sm:py-4 flex items-center justify-between border-b border-safari-800">
    <div>
      <p id={`${modalId}-top-label`} class="text-[10px] md:text-xs uppercase tracking-[0.18em] text-savannah-300 font-semibold mb-0.5">Custom Quote Request</p>
      <h3 id={`${modalId}-title`} class="font-display text-base md:text-lg font-medium text-white truncate max-w-[240px] xs:max-w-[320px] sm:max-w-[400px] md:max-w-[500px]">
        {tour.data.title}
      </h3>
    </div>
    <button
      type="button"
      class="close-modal-btn text-dusk-300 hover:text-white p-1 rounded-lg hover:bg-safari-800 transition-colors"
      aria-label="Close modal"
    >
      <X size={20} />
    </button>
  </div>

  <!-- Wizard Progress Bar -->
  <div class="px-4 sm:px-6 pt-4 modal-progress-bar">
    <div class="flex items-center justify-between mb-1.5">
      <p class="text-[10px] uppercase tracking-[0.15em] text-savannah-700 font-bold" id={`${modalId}-step-label`}>Step 1 of 3</p>
      <p class="text-[10px] text-dusk-500 font-medium" id={`${modalId}-step-title`}>Trip Details</p>
    </div>
    <div class="w-full h-1 bg-dusk-100 rounded-full overflow-hidden">
      <div id={`${modalId}-progress-fill`} class="h-full bg-safari-600 rounded-full transition-all duration-300 ease-out" style="width: 33.3%"></div>
    </div>
  </div>

  <!-- Forms Section -->
  <form id={`${modalId}-form`} class="px-4 sm:px-8 pb-6 sm:pb-8 pt-4 sm:pt-6 focus:outline-hidden">
    <input type="hidden" name="tourId" value={tour.id} />
    <input type="hidden" name="tourTitle" value={tour.data.title} />

    <!-- STEP 1: Travel Details -->
    <div class="step-pane space-y-6" data-step="1" data-title="Trip Details">
      <div class="text-center sm:text-left mb-2">
        <h4 class="font-display text-lg text-safari-900 font-semibold mb-1">Tell us about your plans</h4>
        <p class="text-xs text-dusk-500">Provide details so we can tailor the pricing and options.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <label for={`${modalId}-adults`} class="block text-xs font-semibold text-safari-900 mb-1.5">
            Adults
          </label>
          <select
            id={`${modalId}-adults`}
            name="adults"
            class="w-full px-4 py-2.5 bg-dusk-50 border border-dusk-200 rounded-xl text-sm text-dusk-900 focus:outline-hidden focus:ring-1 focus:ring-safari-600 focus:border-transparent transition cursor-pointer"
          >
            <option value="2">2 adults (Standard)</option>
            <option value="1">1 adult (Solo)</option>
            <option value="3">3 adults</option>
            <option value="4">4 adults</option>
            <option value="5">5 adults</option>
            <option value="6">6 adults</option>
            <option value="7">7 adults</option>
            <option value="8">8+ adults</option>
          </select>
        </div>
        <div>
          <label for={`${modalId}-children`} class="block text-xs font-semibold text-safari-900 mb-1.5">
            Children <span class="text-dusk-400 font-normal">(optional)</span>
          </label>
          <select
            id={`${modalId}-children`}
            name="children"
            class="w-full px-4 py-2.5 bg-dusk-50 border border-dusk-200 rounded-xl text-sm text-dusk-900 focus:outline-hidden focus:ring-1 focus:ring-safari-600 focus:border-transparent transition cursor-pointer"
          >
            <option value="0">None</option>
            <option value="1">1 child</option>
            <option value="2">2 children</option>
            <option value="3">3 children</option>
            <option value="4">4 children</option>
            <option value="5">5+ children</option>
          </select>
        </div>

        <div>
          <label for={`${modalId}-when`} class="block text-xs font-semibold text-safari-900 mb-1.5">
            Preferred travel date <span class="text-sunset-500">*</span>
          </label>
          <input
            type="date"
            id={`${modalId}-when`}
            name="when"
            min={today}
            required
            class="w-full px-4 py-2.5 bg-dusk-50 border border-dusk-200 rounded-xl text-sm text-dusk-900 focus:outline-hidden focus:ring-1 focus:ring-safari-600 focus:border-transparent transition cursor-pointer"
          />
          <p class="text-[10px] text-sunset-600 mt-1 hidden" id={`${modalId}-error-when`}>Please select a preferred travel date.</p>
        </div>
      </div>

      <div>
        <label class="block text-xs font-semibold text-safari-900 mb-2">
          Estimated budget per person <span class="text-dusk-400 font-normal">(USD)</span>
        </label>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
          {budgetOptions.map((opt) => (
            <label class="cursor-pointer group block">
              <input type="radio" name="budget" value={opt.value} class="sr-only peer budget-radio" />
              <div class="px-2 sm:px-4 py-2.5 text-center text-xs font-medium rounded-xl border border-dusk-200 bg-white text-dusk-700 peer-checked:bg-safari-50 peer-checked:border-safari-600 peer-checked:text-safari-900 hover:bg-dusk-50 transition-colors">
                {opt.label}
              </div>
            </label>
          ))}
        </div>
        <div class="flex items-center mt-3">
          <input
            type="checkbox"
            id={`${modalId}-budget-flexible`}
            name="budgetFlexible"
            value="true"
            class="h-4 w-4 rounded border-dusk-300 text-safari-600 focus:ring-safari-500 cursor-pointer"
          />
          <label for={`${modalId}-budget-flexible`} class="ml-2 text-xs font-semibold text-dusk-700 cursor-pointer select-none">
            I'm flexible with my budget
          </label>
        </div>
      </div>

      <div>
        <label for={`${modalId}-message`} class="block text-xs font-semibold text-safari-900 mb-1.5">
          Special requests or details
        </label>
        <textarea
          id={`${modalId}-message`}
          name="message"
          rows="3"
          class="w-full px-4 py-2.5 bg-dusk-50 border border-dusk-200 rounded-xl text-sm text-dusk-900 focus:outline-hidden focus:ring-1 focus:ring-safari-600 focus:border-transparent transition resize-none"
          placeholder="e.g. Diet requirements, specific accommodations, celebrating a special occasion, etc."
        ></textarea>
      </div>
    </div>

    <!-- STEP 2: Activities Checkboxes -->
    <div class="step-pane space-y-6 hidden" data-step="2" data-title="Choose Activities">
      <div class="text-center sm:text-left mb-4">
        <h4 class="font-display text-lg text-safari-900 font-semibold mb-1">Add activities to your itinerary</h4>
        <p class="text-xs text-dusk-500">Select any optional experiences you'd like to combine with your tour.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 max-h-[300px] overflow-y-auto pr-1">
        {activities.map((act) => (
          <label class="step-card cursor-pointer group block">
            <input type="checkbox" name="activities" value={act.value} class="sr-only peer activity-cb" />
            <div class="relative p-3.5 rounded-xl border-2 border-dusk-200 bg-dusk-50/50 h-full peer-checked:border-savannah-600 peer-checked:bg-savannah-50/40 hover:border-savannah-300 transition-all flex items-start gap-3">
              <span class="w-8 h-8 rounded-lg bg-safari-100 text-safari-700 flex items-center justify-center shrink-0 group-hover:bg-safari-600 group-hover:text-white transition-colors">
                <act.icon size={16} />
              </span>
              <div class="pr-4">
                <p class="font-display text-sm font-semibold text-safari-900 leading-tight">{act.label}</p>
                <p class="text-[11px] text-dusk-500 mt-0.5 leading-snug">{act.sub}</p>
              </div>
              <div class="card-dot absolute top-3.5 right-3.5 w-4.5 h-4.5 rounded border border-dusk-300 bg-white flex items-center justify-center transition-colors">
                <svg class="check-svg w-2.5 h-2.5 text-white opacity-0 transition-opacity" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M2 6l3 3 5-6"/></svg>
              </div>
            </div>
          </label>
        ))}
      </div>

      <!-- None fallback checkbox -->
      <label class="none-card cursor-pointer group block mt-3">
        <input type="checkbox" id={`${modalId}-none-cb`} name="activities" value="none" class="sr-only peer none-cb" />
        <div class="relative p-3 rounded-xl border-2 border-dusk-200 bg-dusk-50/50 peer-checked:border-safari-600 peer-checked:bg-safari-50/30 hover:border-safari-300 transition-all flex items-center gap-3">
          <span class="w-8 h-8 rounded-lg bg-safari-100 text-safari-700 flex items-center justify-center shrink-0 group-hover:bg-safari-600 group-hover:text-white transition-colors">
            <Check size={16} />
          </span>
          <div>
            <p class="font-display text-sm font-semibold text-safari-900 leading-tight">No optional activities</p>
            <p class="text-[11px] text-dusk-500 leading-none mt-0.5">Just the standard tour itinerary is perfect</p>
          </div>
          <div class="card-dot absolute top-3.5 right-3.5 w-4.5 h-4.5 rounded border border-dusk-300 bg-white flex items-center justify-center transition-colors">
            <svg class="check-svg w-2.5 h-2.5 text-white opacity-0 transition-opacity" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M2 6l3 3 5-6"/></svg>
          </div>
        </div>
      </label>
    </div>

    <!-- STEP 3: Contact Information -->
    <div class="step-pane space-y-6 hidden" data-step="3" data-title="Contact Details">
      <div class="text-center sm:text-left mb-2">
        <h4 class="font-display text-lg text-safari-900 font-semibold mb-1">Where should we send your quote?</h4>
        <p class="text-xs text-dusk-500">Provide your contact info to receive the custom itinerary dossier.</p>
      </div>

      <div>
        <label for={`${modalId}-name`} class="block text-xs font-semibold text-safari-900 mb-1.5">
          Full name <span class="text-sunset-500">*</span>
        </label>
        <input
          type="text"
          id={`${modalId}-name`}
          name="name"
          required
          autocomplete="name"
          class="w-full px-4 py-2.5 bg-dusk-50 border border-dusk-200 rounded-xl text-sm text-dusk-900 focus:outline-hidden focus:ring-1 focus:ring-safari-600 focus:border-transparent transition"
          placeholder="John Smith"
        />
        <p class="text-[10px] text-sunset-600 mt-1 hidden" id={`${modalId}-error-name`}>Please enter your full name.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for={`${modalId}-email`} class="block text-xs font-semibold text-safari-900 mb-1.5">
            Email address <span class="text-sunset-500">*</span>
          </label>
          <input
            type="email"
            id={`${modalId}-email`}
            name="email"
            required
            autocomplete="email"
            class="w-full px-4 py-2.5 bg-dusk-50 border border-dusk-200 rounded-xl text-sm text-dusk-900 focus:outline-hidden focus:ring-1 focus:ring-safari-600 focus:border-transparent transition"
            placeholder="john@example.com"
          />
          <p class="text-[10px] text-sunset-600 mt-1 hidden" id={`${modalId}-error-email`}>Please enter a valid email address.</p>
        </div>

        <div>
          <label for={`${modalId}-phone`} class="block text-xs font-semibold text-safari-900 mb-1.5">
            Phone / WhatsApp <span class="text-dusk-400 font-normal">(optional)</span>
          </label>
          <input
            type="tel"
            id={`${modalId}-phone`}
            name="phone"
            autocomplete="tel"
            class="w-full px-4 py-2.5 bg-dusk-50 border border-dusk-200 rounded-xl text-sm text-dusk-900 focus:outline-hidden focus:ring-1 focus:ring-safari-600 focus:border-transparent transition"
            placeholder="+1 (555) 000-0000"
          />
        </div>
      </div>

      <!-- Turnstile Captcha Widget -->
      <div id={`${modalId}-turnstile-container`} class="flex justify-center pt-2">
        <div class="cf-turnstile" data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '0x4AAAAAAA_replace_with_your_site_key'} data-callback="onTurnstileCallback" data-theme="light"></div>
      </div>

      <!-- Spam Protections -->
      <div aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden">
        <label for={`${modalId}-website`}>Website (leave empty)</label>
        <input type="text" id={`${modalId}-website`} name="website" tabindex="-1" autocomplete="off" />
      </div>
      <input type="hidden" id={`${modalId}-ts`} name="_ts" value="" />
      <input type="hidden" id={`${modalId}-turnstileToken`} name="turnstileToken" value="" />
    </div>

    <!-- Error Banner -->
    <div id={`${modalId}-general-error`} class="mt-4 p-3 bg-sunset-50 border border-sunset-200 rounded-xl text-xs text-sunset-800 hidden text-center">
    </div>

    <!-- Navigation Buttons -->
    <div class="flex items-center justify-between border-t border-dusk-100 pt-4 sm:pt-5 mt-4 sm:mt-6 modal-nav">
      <button
        type="button"
        id={`${modalId}-back-btn`}
        class="px-4 py-2 text-xs font-semibold text-dusk-600 hover:text-safari-900 transition-colors flex items-center gap-1.5 invisible"
      >
        <ArrowLeft size={14} /> Back
      </button>

      <button
        type="button"
        id={`${modalId}-next-btn`}
        class="btn btn-primary justify-center text-xs px-5 py-2 cursor-pointer"
      >
        Continue <ArrowRight size={14} />
      </button>

      <button
        type="submit"
        id={`${modalId}-submit-btn`}
        class="btn btn-primary justify-center text-xs px-5 py-2 hidden cursor-pointer"
      >
        <Send size={14} /> <span id={`${modalId}-submit-btn-text`}>Send Quote Request</span>
      </button>
    </div>
  </form>

  <!-- SUCCESS STATE -->
  <div id={`${modalId}-success-pane`} class="p-8 text-center space-y-5 hidden">
    <div class="w-16 h-16 bg-safari-50 text-safari-700 rounded-full flex items-center justify-center mx-auto shadow-inner">
      <Check size={32} class="animate-bounce" />
    </div>
    
    <div class="space-y-2">
      <h4 class="font-display text-xl md:text-2xl text-safari-900 font-bold">Jambo! Request Received</h4>
      <p id={`${modalId}-success-text`} class="text-sm text-dusk-600 max-w-md mx-auto leading-relaxed">
        Your enquiry for the <strong>{tour.data.title}</strong> is on its way to our team in Arusha. We will get back to you with a custom quote within 24 hours.
      </p>
    </div>

    <div class="pt-4 flex flex-col sm:flex-row gap-3 justify-center items-center">
      <a
        id={`${modalId}-whatsapp-success-btn`}
        href="https://wa.me/255784136616"
        target="_blank"
        rel="noopener"
        class="w-full sm:w-auto px-5 py-2.5 bg-[#25D366] hover:bg-[#20ba5a] text-white rounded-xl font-semibold text-sm flex items-center justify-center gap-2 shadow-soft transition-colors"
      >
        <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.513 2.262 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.965C16.59 1.977 14.113.953 11.5.953c-5.442 0-9.865 4.379-9.87 9.808-.001 1.716.463 3.393 1.343 4.887L1.975 22.02l6.672-1.866zM17.49 14.5c-.29-.145-1.72-.85-1.99-.95-.27-.1-.47-.145-.66.15-.19.29-.74.95-.91 1.15-.17.195-.34.22-.63.075-.29-.145-1.22-.45-2.325-1.434-.86-.77-1.44-1.72-1.61-2.01-.17-.29-.02-.45.13-.594.13-.13.29-.34.435-.51.15-.17.2-.29.3-.48.1-.19.05-.36-.025-.51-.075-.15-.66-1.59-.9-2.18-.24-.58-.48-.5-.66-.51-.17-.01-.37-.01-.57-.01-.2 0-.52.075-.79.37-.27.29-1.02 1-1.02 2.44 0 1.44 1.05 2.83 1.2 3.02.15.19 2.07 3.16 5.003 4.43.7.3 1.25.48 1.68.62.7.22 1.34.19 1.84.11.56-.08 1.72-.7 1.96-1.38.24-.68.24-1.26.17-1.38-.07-.12-.27-.195-.56-.34z"/></svg>
        Chat on WhatsApp
      </a>
      <button
        type="button"
        class="close-modal-btn w-full sm:w-auto px-5 py-2.5 bg-dusk-100 hover:bg-dusk-200 text-dusk-800 rounded-xl font-semibold text-sm transition-colors cursor-pointer"
      >
        Close Window
      </button>
    </div>
  </div>
</dialog>

<script is:inline define:vars={{ modalId }}>
  (function() {
    const dialog = document.getElementById(modalId);
    if (!dialog) return;

    // Load Turnstile callback helper in global scope
    window.onTurnstileCallback = function(token) {
      const tokenInput = dialog.querySelector('input[name="turnstileToken"]');
      if (tokenInput) {
        tokenInput.value = token;
      }
    };

    // Close buttons handler
    const closeBtns = dialog.querySelectorAll('.close-modal-btn');
    closeBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        dialog.close();
      });
    });

    // Handle clicks outside the dialog for light-dismiss on unsupported browsers (Safari)
    if (!('closedBy' in HTMLDialogElement.prototype)) {
      dialog.addEventListener('click', (event) => {
        if (event.target !== dialog) return;
        const rect = dialog.getBoundingClientRect();
        const isDialogContent = (
          rect.top <= event.clientY &&
          event.clientY <= rect.top + rect.height &&
          rect.left <= event.clientX &&
          event.clientX <= rect.left + rect.width
        );
        if (!isDialogContent) {
          dialog.close();
        }
      });
    }

    // Wizard logic
    let currentStep = 1;
    const totalSteps = 3;
    const stepsPanes = dialog.querySelectorAll('.step-pane');
    const backBtn = document.getElementById(`${modalId}-back-btn`);
    const nextBtn = document.getElementById(`${modalId}-next-btn`);
    const submitBtn = document.getElementById(`${modalId}-submit-btn`);
    const stepLabel = document.getElementById(`${modalId}-step-label`);
    const stepTitle = document.getElementById(`${modalId}-step-title`);
    const progressFill = document.getElementById(`${modalId}-progress-fill`);
    const form = document.getElementById(`${modalId}-form`);
    const successPane = document.getElementById(`${modalId}-success-pane`);
    const generalError = document.getElementById(`${modalId}-general-error`);
    const tsField = document.getElementById(`${modalId}-ts`);
    let submissionSource = 'email';

    // Reset wizard and open handler
    dialog.addEventListener('close', () => {
      // Clean up states
      form.classList.remove('hidden');
      dialog.querySelector('.modal-progress-bar').classList.remove('hidden');
      successPane.classList.add('hidden');
      generalError.classList.add('hidden');
      form.reset();
      
      // Reset Turnstile if it exists
      if (window.turnstile) {
        window.turnstile.reset(dialog.querySelector('.cf-turnstile'));
      }
      
      showStep(1);
    });

    // Listen to custom event to open the modal
    dialog.addEventListener('open-enquiry', (e) => {
      submissionSource = e.detail?.source || 'email';
      
      // Update top header label
      const topLabel = document.getElementById(`${modalId}-top-label`);
      if (topLabel) {
        topLabel.textContent = submissionSource === 'whatsapp' ? 'WhatsApp Enquiry' : 'Custom Quote Request';
      }

      // Reset step 3 submit button text if needed
      const submitTextSpan = document.getElementById(`${modalId}-submit-btn-text`);
      if (submitTextSpan) {
        submitTextSpan.textContent = submissionSource === 'whatsapp' ? 'Start WhatsApp Chat' : 'Send Quote Request';
      }

      if (tsField) tsField.value = String(Date.now());
      dialog.showModal();
    });

    // Mutual exclusion logic for "none" optional activity card
    const activityCBs = dialog.querySelectorAll('.activity-cb');
    const noneCB = document.getElementById(`${modalId}-none-cb`);

    activityCBs.forEach(cb => {
      cb.addEventListener('change', () => {
        if (cb.checked && noneCB) {
          noneCB.checked = false;
        }
      });
    });

    if (noneCB) {
      noneCB.addEventListener('change', () => {
        if (noneCB.checked) {
          activityCBs.forEach(cb => {
            cb.checked = false;
          });
        }
      });
    }

    // Mutual exclusion logic for budget "I'm flexible" checkbox
    const budgetRadios = dialog.querySelectorAll('.budget-radio');
    const flexibleBudgetCB = document.getElementById(`${modalId}-budget-flexible`);

    if (flexibleBudgetCB) {
      flexibleBudgetCB.addEventListener('change', () => {
        if (flexibleBudgetCB.checked) {
          budgetRadios.forEach(radio => {
            radio.checked = false;
          });
        }
      });
    }

    budgetRadios.forEach(radio => {
      radio.addEventListener('change', () => {
        if (radio.checked && flexibleBudgetCB) {
          flexibleBudgetCB.checked = false;
        }
      });
    });

    // Step display helper
    function showStep(stepNum) {
      currentStep = stepNum;
      
      // Show/hide panes
      stepsPanes.forEach(pane => {
        const paneStep = parseInt(pane.getAttribute('data-step') || '0');
        if (paneStep === stepNum) {
          pane.classList.remove('hidden');
          if (stepTitle) {
            stepTitle.textContent = pane.getAttribute('data-title') || '';
          }
        } else {
          pane.classList.add('hidden');
        }
      });

      // Update progress fill
      if (progressFill) {
        progressFill.style.width = `${(stepNum / totalSteps) * 100}%`;
      }
      if (stepLabel) {
        stepLabel.textContent = `Step ${stepNum} of ${totalSteps}`;
      }

      // Update buttons visibility
      if (backBtn) {
        if (stepNum === 1) {
          backBtn.classList.add('invisible');
        } else {
          backBtn.classList.remove('invisible');
        }
      }

      if (stepNum === totalSteps) {
        if (nextBtn) nextBtn.classList.add('hidden');
        if (submitBtn) {
          submitBtn.classList.remove('hidden');
          const submitTextSpan = document.getElementById(`${modalId}-submit-btn-text`);
          if (submitTextSpan) {
            submitTextSpan.textContent = submissionSource === 'whatsapp' ? 'Start WhatsApp Chat' : 'Send Quote Request';
          }
        }
      } else {
        if (nextBtn) nextBtn.classList.remove('hidden');
        if (submitBtn) submitBtn.classList.add('hidden');
      }
    }

    // Navigation events
    nextBtn?.addEventListener('click', () => {
      if (validateCurrentStep()) {
        showStep(currentStep + 1);
      }
    });

    backBtn?.addEventListener('click', () => {
      showStep(currentStep - 1);
    });

    function validateCurrentStep() {
      // Clear errors
      generalError.classList.add('hidden');
      document.getElementById(`${modalId}-error-name`).classList.add('hidden');
      document.getElementById(`${modalId}-error-email`).classList.add('hidden');
      const whenError = document.getElementById(`${modalId}-error-when`);
      if (whenError) whenError.classList.add('hidden');

      if (currentStep === 1) {
        const whenInput = document.getElementById(`${modalId}-when`);
        if (!whenInput || !whenInput.value) {
          if (whenError) whenError.classList.remove('hidden');
          return false;
        }
        return true;
      }

      if (currentStep === 3) {
        const nameInput = document.getElementById(`${modalId}-name`);
        const emailInput = document.getElementById(`${modalId}-email`);
        let isValid = true;

        if (!nameInput.value.trim()) {
          document.getElementById(`${modalId}-error-name`).classList.remove('hidden');
          isValid = false;
        }

        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!emailInput.value.trim() || !emailRegex.test(emailInput.value.trim())) {
          document.getElementById(`${modalId}-error-email`).classList.remove('hidden');
          isValid = false;
        }

        return isValid;
      }
      return true;
    }

    // Form Submission
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (currentStep !== totalSteps) return;

      if (!validateCurrentStep()) return;

      // Disable buttons
      if (submitBtn) {
        submitBtn.disabled = true;
        const msg = submissionSource === 'whatsapp' ? 'Opening WhatsApp...' : 'Sending Quote Request...';
        submitBtn.innerHTML = `<span class="animate-pulse">${msg}</span>`;
      }
      if (backBtn) backBtn.disabled = true;

      generalError.classList.add('hidden');

      try {
        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
        
        // Handle multiple values for activities array
        const selectedActivities = [];
        form.querySelectorAll('input[name="activities"]:checked').forEach(cb => {
          if (cb.value !== 'none') {
            selectedActivities.push(cb.value);
          }
        });
        data.activities = selectedActivities;

        // Map budgetFlexible checkbox value to 'flexible' budget value
        if (data.budgetFlexible === 'true') {
          data.budget = 'flexible';
        }

        // Parse adults and children count and calculate total travelers
        const adultsVal = data.adults ? parseInt(data.adults) : 2;
        const childrenVal = data.children ? parseInt(data.children) : 0;
        data.adults = adultsVal;
        data.children = childrenVal;
        data.travelers = adultsVal + childrenVal;

        const res = await fetch('/api/enquire', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        const result = await res.json().catch(() => ({ error: 'Submission failed' }));

        if (!res.ok) {
          throw new Error(result.error || 'Failed to submit quote request. Please try again.');
        }

        // Format a beautiful pre-filled message for WhatsApp
        const tourTitleVal = data.tourTitle;
        const nameVal = data.name;
        const dateVal = data.when;
        const budgetVal = data.budget;
        const requestsVal = data.message;
        
        let activitiesVal = 'None';
        if (Array.isArray(data.activities) && data.activities.length > 0) {
          activitiesVal = data.activities.map(a => {
            return a.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
          }).join(', ');
        }

        let budgetLabel = '';
        if (budgetVal === 'under-2000') budgetLabel = 'Under $2,000';
        else if (budgetVal === '2000-4000') budgetLabel = '$2,000-$4,000';
        else if (budgetVal === '4000-6000') budgetLabel = '$4,000-$6,000';
        else if (budgetVal === '6000-plus') budgetLabel = '$6,000+';
        else if (budgetVal === 'flexible') budgetLabel = 'Flexible';

        let waMessage = `Hi Springbok! My name is ${nameVal}. I am interested in the "${tourTitleVal}" safari tour.\n\n`;
        waMessage += `My travel preferences:\n`;
        if (dateVal) waMessage += `- Preferred Date: ${dateVal}\n`;
        
        let groupBreakdown = `${adultsVal} ${adultsVal === 1 ? 'adult' : 'adults'}`;
        if (childrenVal > 0) {
          groupBreakdown += `, ${childrenVal} ${childrenVal === 1 ? 'child' : 'children'}`;
        }
        waMessage += `- Group Size: ${groupBreakdown} (Total ${adultsVal + childrenVal} travelers)\n`;
        
        if (budgetLabel) waMessage += `- Estimated Budget: ${budgetLabel}\n`;
        if (activitiesVal && activitiesVal !== 'None') waMessage += `- Added Activities: ${activitiesVal}\n`;
        if (requestsVal) waMessage += `- Special Requests: ${requestsVal}\n`;
        waMessage += `\nEmail: ${data.email}`;
        if (data.phone) waMessage += `\nPhone: ${data.phone}`;

        const waLink = `https://wa.me/255784136616?text=${encodeURIComponent(waMessage)}`;

        // Setup WhatsApp link on success
        const whatsappBtn = document.getElementById(`${modalId}-whatsapp-success-btn`);
        if (whatsappBtn) {
          whatsappBtn.href = waLink;
        }

        // Dynamically update success message text
        const successText = document.getElementById(`${modalId}-success-text`);
        if (successText) {
          if (submissionSource === 'whatsapp') {
            successText.innerHTML = `Your details for the <strong>${tourTitleVal}</strong> have been recorded. We are redirecting you to WhatsApp to start your chat. If the chat didn't open automatically, please click the button below.`;
          } else {
            successText.innerHTML = `Your enquiry for the <strong>${tourTitleVal}</strong> is on its way to our team in Arusha. We will get back to you with a custom quote within 24 hours.`;
          }
        }

        // Redirect directly if selected source is WhatsApp
        if (submissionSource === 'whatsapp') {
          window.open(waLink, '_blank');
        }

        // Transition to success screen
        form.classList.add('hidden');
        dialog.querySelector('.modal-progress-bar').classList.add('hidden');
        successPane.classList.remove('hidden');

      } catch (err) {
        console.error('[Enquiry form error]:', err);
        generalError.textContent = err.message;
        generalError.classList.remove('hidden');
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          const btnText = submissionSource === 'whatsapp' ? 'Start WhatsApp Chat' : 'Send Quote Request';
          submitBtn.innerHTML = `<svg class="w-3.5 h-3.5 mr-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg> <span id="${modalId}-submit-btn-text">${btnText}</span>`;
        }
        if (backBtn) backBtn.disabled = false;
      }
    });

    // Set step 1 initially
    showStep(1);
  })();
</script>

<style>
  .step-pane {
    animation: modalPaneFadeSlide 0.3s ease-out;
  }
  @keyframes modalPaneFadeSlide {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Styles for checking states using CSS :has() */
  .step-card:has(input:checked) .card-dot {
    border-color: var(--color-savannah-600);
    background-color: var(--color-savannah-600);
  }
  .step-card:has(input:checked) .check-svg {
    opacity: 1;
  }
  
  .none-card:has(input:checked) .card-dot {
    border-color: var(--color-safari-600);
    background-color: var(--color-safari-600);
  }
  .none-card:has(input:checked) .check-svg {
    opacity: 1;
  }
</style>
