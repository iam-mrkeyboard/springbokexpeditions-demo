---
import { Star } from '@lucide/astro';
import Badge from '@/components/ui/Badge.astro';

interface Props {
  tour: {
    data: {
      title: string;
      hero: string;
      excerpt: string;
      featured?: boolean;
    };
  };
  typeLabel: string;
}

const { tour, typeLabel } = Astro.props;
---

<section class="relative h-[70vh] min-h-[500px] md:h-[80vh] md:min-h-[600px] lg:h-[85vh] lg:min-h-[650px] flex items-end overflow-hidden bg-safari-900 text-white">
  <div class="absolute inset-0 z-0">
    <img
      src={tour.data.hero}
      alt={tour.data.title}
      class="w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <!-- Dark overlay to ensure top navigation and breadcrumb legibility -->
    <div class="absolute inset-0 bg-safari-950/35"></div>
    <!-- Gradient overlay to enhance text legibility at the bottom -->
    <div class="absolute inset-0 bg-gradient-to-t from-safari-900/95 via-safari-900/50 to-transparent"></div>
  </div>

  <div class="container-content relative z-10 pb-12">
    <nav class="flex items-center gap-2 text-sm text-dusk-200 mb-6">
      <a href="/" class="hover:text-white">Home</a>
      <span>/</span>
      <a href="/tours" class="hover:text-white">Tours</a>
      <span>/</span>
      <span class="text-dusk-300">{tour.data.title}</span>
    </nav>



    <h1 class="text-display-md md:text-display-lg font-display font-medium tracking-tight text-white max-w-3xl mb-4">
      {tour.data.title}
    </h1>
    <p class="text-lg md:text-xl text-dusk-100/90 max-w-2xl leading-relaxed">
      {tour.data.excerpt}
    </p>
  </div>
</section>
