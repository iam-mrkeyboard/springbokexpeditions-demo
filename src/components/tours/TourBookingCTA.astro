---
import { Mail, MessageCircle } from '@lucide/astro';

interface Props {
  tour: {
    id: string;
    data: {
      title: string;
    };
  };
}

const { tour } = Astro.props;
const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP || '255784136616';
const whatsappLink = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(`Hi Springbok! I'm interested in the "${tour.data.title}" tour. Could you share more details and availability?`)}`;
---

<div class="bg-white border border-dusk-100 rounded-2xl shadow-soft overflow-hidden">
  <!-- Booking buttons -->
  <div class="p-6 space-y-3">
    <a
      href={`/contact?tour=${tour.id}`}
      class="btn btn-primary w-full justify-center"
    >
      <Mail size={16} />
      Enquire About This Tour
    </a>
    <a
      href={whatsappLink}
      target="_blank"
      rel="noopener"
      class="btn bg-[#25D366] text-white hover:bg-[#20ba5a] w-full justify-center"
    >
      <MessageCircle size={16} />
      Chat on WhatsApp
    </a>
  </div>

  <!-- Trust signals -->
  <div class="px-6 pb-6 pt-2 space-y-2 text-xs text-dusk-600">
    <div class="flex items-center gap-2">
      <span class="text-savannah-500">✓</span> Free, no-obligation enquiry
    </div>
    <div class="flex items-center gap-2">
      <span class="text-savannah-500">✓</span> Response within 24 hours
    </div>
    <div class="flex items-center gap-2">
      <span class="text-savannah-500">✓</span> Customize any itinerary
    </div>
  </div>
</div>
