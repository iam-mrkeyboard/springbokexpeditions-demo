---
import { Mail, MessageCircle } from '@lucide/astro';
import TourEnquiryModal from './TourEnquiryModal.astro';

interface Props {
  tour: {
    id: string;
    data: {
      title: string;
      durationDays: number;
      type: string;
    };
  };
}
const { tour } = Astro.props;
---

<div class="bg-white border border-dusk-100 rounded-2xl shadow-soft overflow-hidden">
  <!-- Booking buttons -->
  <div class="p-6 space-y-3">
    <button
      type="button"
      id={`open-enquiry-btn-${tour.id}`}
      class="btn btn-primary w-full justify-center cursor-pointer"
    >
      <Mail size={16} />
      Request a Custom Quote
    </button>
    <button
      type="button"
      id={`open-whatsapp-btn-${tour.id}`}
      class="btn bg-[#25D366] text-white hover:bg-[#20ba5a] w-full justify-center cursor-pointer"
    >
      <MessageCircle size={16} />
      Chat on WhatsApp
    </button>
  </div>

  <TourEnquiryModal tour={tour} />

  <script is:inline define:vars={{ tourId: tour.id }}>
    (function() {
      const btn = document.getElementById(`open-enquiry-btn-${tourId}`);
      const waBtn = document.getElementById(`open-whatsapp-btn-${tourId}`);
      const modal = document.getElementById(`enquiry-modal-${tourId}`);
      
      if (btn && modal) {
        btn.addEventListener('click', () => {
          modal.dispatchEvent(new CustomEvent('open-enquiry', { detail: { source: 'email' } }));
        });
      }
      if (waBtn && modal) {
        waBtn.addEventListener('click', () => {
          modal.dispatchEvent(new CustomEvent('open-enquiry', { detail: { source: 'whatsapp' } }));
        });
      }
    })();
  </script>

  <!-- Trust signals -->
  <div class="px-6 pb-6 pt-2 space-y-2 text-xs text-dusk-600">
    <div class="flex items-center gap-2">
      <span class="text-savannah-500">✓</span> Free, no-obligation enquiry
    </div>
    <div class="flex items-center gap-2">
      <span class="text-savannah-500">✓</span> Response within 24 hours
    </div>
    <div class="flex items-center gap-2">
      <span class="text-savannah-500">✓</span> Customize any itinerary
    </div>
  </div>
</div>
