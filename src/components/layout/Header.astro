---
import { Phone, Mail, Menu, X, ChevronDown } from '@lucide/astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { CATEGORY_CONFIG, getToursForCategory, ALL_CATEGORIES, type TourCategory } from '@/lib/safari-categories';

interface Props {
  transparent?: boolean;
  siteName: string;
}

const { transparent = false } = Astro.props;

const kiliTreks = (await getCollection('trekking'))
  .filter((t) => t.data.mountain === 'kilimanjaro')
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

const meruTreks = (await getCollection('trekking'))
  .filter((t) => t.data.mountain === 'meru')
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

const safariCategories = await Promise.all(
  ALL_CATEGORIES.map(async (key: TourCategory) => {
    const tours = await getToursForCategory(key);
    const config = CATEGORY_CONFIG[key];
    return {
      key,
      label: config.pluralLabel,
      href: `/tours/${key}`,
      tours: tours.map((t) => ({
        label: t.data.title,
        href: `/tours/${t.id}`,
      })),
    };
  })
);

const navItems = [
  {
    label: 'Safaris',
    href: '/tours',
    children: safariCategories.map((cat) => ({
      label: cat.label,
      href: cat.href,
      desc: `${cat.tours.length} ${cat.tours.length === 1 ? 'itinerary' : 'itineraries'}`,
      subChildren: cat.tours,
    })),
  },
  {
    label: 'Destinations',
    href: '/destinations',
    children: [
      { label: 'Serengeti', href: '/destinations/serengeti-national-park', desc: 'Endless plains · Iconic wildlife' },
      { label: 'Ngorongoro', href: '/destinations/ngorongoro-crater', desc: 'Natural wonder · African Eden' },
      { label: 'Tarangire', href: '/destinations/tarangire-national-park', desc: 'Elephants · Ancient baobabs' },
      { label: 'Lake Manyara', href: '/destinations/lake-manyara-national-park', desc: 'Tree-climbing lions · Flamingos' },
      { label: 'Kilimanjaro', href: '/kilimanjaro', desc: 'Roof of Africa · 5,895m' },
      { label: 'Mount Meru', href: '/mount-meru', desc: '4,566m · Best Kili acclimatization' },
      { label: 'Zanzibar Beach', href: '/destinations/zanzibar-archipelago', desc: 'Spice Island · White sand beaches' },
    ],
  },
  {
    label: 'Trekking',
    href: '/trekking',
    children: [
      {
        label: 'Mount Kilimanjaro',
        href: '/kilimanjaro',
        desc: '6 routes · 5,895m · Roof of Africa',
        subChildren: kiliTreks.map((t) => ({
          label: t.data.title,
          href: `/trekking/${t.id}`,
        })),
      },
      {
        label: 'Mount Meru',
        href: '/mount-meru',
        desc: '4 days · 4,566m · Best Kili acclimatization',
        subChildren: meruTreks.map((t) => ({
          label: t.data.title,
          href: `/trekking/${t.id}`,
        })),
      },
    ],
  },
  {
    label: 'Zanzibar',
    href: '/zanzibar',
    children: null,
  },
  {
    label: 'Experiences',
    href: '/experiences',
    children: [
      {
        label: 'Hot Air Balloon Safaris',
        href: '/experiences/hot-air-balloon-safaris',
        desc: 'Soar over the Serengeti at dawn',
      },
      {
        label: 'Walking Safaris',
        href: '/experiences/walking-safaris',
        desc: 'Track wildlife on foot with armed rangers',
      },
      {
        label: 'Cultural Tours',
        href: '/experiences/cultural-tours',
        desc: 'Meet Maasai, Hadzabe & Datoga tribes',
      },
      {
        label: 'Arusha City Tour',
        href: '/experiences/arusha-city-tour',
        desc: 'Discover Tanzanite, local cuisine & Maasai markets',
      },
      {
        label: 'Zanzibar Stone Town Tour',
        href: '/experiences/zanzibar-stone-town-tour',
        desc: 'Explore UNESCO historic alleys and spice farms',
      },
      {
        label: 'Canoeing Safaris',
        href: '/experiences/canoeing-safaris',
        desc: 'Paddle among flamingos & hippos',
      },
      {
        label: 'Night Game Drive',
        href: '/experiences/night-game-drive',
        desc: 'Spot active nocturnal predators',
      },
      {
        label: 'Bush Lunch / Dinner',
        href: '/experiences/bush-lunch-dinner',
        desc: 'Wilderness dining under the stars',
      },
    ],
  },
  {
    label: 'Traveler Tips',
    href: '/blog',
    children: null,
  },
  {
    label: 'About',
    href: '/about',
    children: null,
  },
  {
    label: 'Contact',
    href: '/contact',
    children: null,
  },
];

const currentPath = Astro.url.pathname;
---

<header
  id='site-header'
  data-transparent={transparent ? 'true' : 'false'}
  class:list={[
    'fixed top-0 left-0 right-0 z-50 w-full transition-all duration-300',
    transparent
      ? 'site-header--transparent text-white'
      : 'bg-white/95 backdrop-blur-md text-dusk-900 border-b border-dusk-100',
  ]}
>
  <!-- Top contact bar -->
  <div
    class:list={[
      'hidden lg:block border-b header-contact-border',
      transparent ? 'border-white/10' : 'border-dusk-100',
    ]}
  >
    <div
      class='container-content flex justify-end items-center gap-6 py-2 text-xs'
    >
      <a
        href='tel:+255784136616'
        class:list={[
          'header-contact-link flex items-center gap-1.5 transition-colors',
          'hover:text-savannah-600',
          transparent ? 'text-white' : 'text-dusk-700',
        ]}
      >
        <Phone size={13} />
        <span>+255 784 136 616</span>
      </a>
      <a
        href='mailto:info@springbokexpeditions.com'
        class:list={[
          'header-contact-link flex items-center gap-1.5 transition-colors',
          'hover:text-savannah-600',
          transparent ? 'text-white' : 'text-dusk-700',
        ]}
      >
        <Mail size={13} />
        <span>info@springbokexpeditions.com</span>
      </a>
    </div>
  </div>

  <!-- Main nav -->
  <div class='container-content'>
    <div class='flex items-center justify-between h-20'>
      <!-- Logo -->
      <a href='/' class='flex items-center gap-3 group'>
        <Image
          src='/logo.png'
          alt='Springbok Expeditions'
          class='object-cover header-logo-img'
          height={50}
          width={200}
        />
      </a>

      <!-- Desktop nav -->
      <nav class='hidden lg:flex items-center gap-1'>
        {
          navItems.map((item) => (
            <div class='relative group'>
              <a
                href={item.href}
                class:list={[
                  'inline-flex items-center gap-1 px-2 py-2 text-sm font-medium transition-colors whitespace-nowrap',
                  'hover:text-savannah-600',
                  currentPath === item.href ||
                  (item.href !== '/' && currentPath.startsWith(item.href))
                    ? 'text-savannah-600'
                    : '',
                ]}>
                {item.label}
                {item.children && (
                  <ChevronDown
                    size={14}
                    class='transition-transform group-hover:rotate-180'
                  />
                )}
              </a>
              {item.children && (
                <div class='invisible opacity-0 group-hover:visible group-hover:opacity-100 transition-all absolute left-1/2 -translate-x-1/2 top-full pt-3 w-[420px] z-10'>
                  <div class='bg-white rounded-xl shadow-elevated border border-dusk-100 p-3 grid grid-cols-1 gap-1'>
                    {item.children.map((child: any) => (
                      child.subChildren ? (
                        <div class='relative subgroup group/sub'>
                          <a
                            href={child.href}
                            class='flex items-center justify-between px-3 py-2.5 rounded-lg hover:bg-dusk-50 transition-colors group/item'>
                            <div class='flex flex-col'>
                              <span class='font-medium text-sm text-dusk-900 group-hover/item:text-savannah-700'>
                                {child.label}
                              </span>
                              {child.desc && (
                                <span class='text-xs text-dusk-600 mt-0.5'>
                                  {child.desc}
                                </span>
                              )}
                            </div>
                            <ChevronDown size={12} class='-rotate-90 text-dusk-400' />
                          </a>
                          <div class='subgroup-panel opacity-0 pointer-events-none group-hover/sub:opacity-100 group-focus-within/sub:opacity-100 group-hover/sub:pointer-events-auto group-focus-within/sub:pointer-events-auto transition-opacity duration-200 absolute left-full top-0 w-[360px] z-20'>
                            <div class='bg-white rounded-xl shadow-elevated border border-dusk-100 p-3 grid grid-cols-1 gap-1 max-h-[480px] overflow-y-auto'>
                              {child.subChildren.map((sub: any) => (
                                <a
                                  href={sub.href}
                                  class='block px-3 py-2 rounded-lg hover:bg-dusk-50 transition-colors text-sm text-dusk-800 hover:text-savannah-700'
                                >
                                  {sub.label}
                                </a>
                              ))}
                            </div>
                          </div>
                        </div>
                      ) : (
                        <a
                          href={child.href}
                          class='flex flex-col px-3 py-2.5 rounded-lg hover:bg-dusk-50 transition-colors group/item'>
                          <span class='font-medium text-sm text-dusk-900 group-hover/item:text-savannah-700'>
                            {child.label}
                          </span>
                          {child.desc && (
                            <span class='text-xs text-dusk-600 mt-0.5'>
                              {child.desc}
                            </span>
                          )}
                        </a>
                      )
                    ))}
                  </div>
                </div>
              )}
            </div>
          ))
        }
      </nav>

      <!-- CTA button -->
      <div class='hidden lg:flex items-center gap-3'>
        <a href='/plan-my-trip' class='btn btn-primary'> Plan Your Safari </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id='mobile-menu-btn'
        class='lg:hidden p-2 -mr-2'
        aria-label='Toggle menu'
        aria-expanded='false'
      >
        <Menu size={24} id='menu-icon-open' />
        <X size={24} id='menu-icon-close' class='hidden' />
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id='mobile-menu'
    class='lg:hidden border-t border-dusk-100 bg-white mobile-menu-panel'
  >
    <nav class='container-content py-6 space-y-1'>
      {
        navItems.map((item) => (
          <div>
            <a
              href={item.href}
              class='block px-3 py-2.5 text-base font-medium text-dusk-900 hover:bg-dusk-50 rounded-lg'>
              {item.label}
            </a>
            {item.children && (
              <div class='pl-4 space-y-1'>
                {item.children.map((child: any) => (
                  child.subChildren ? (
                    <div class='mobile-accordion'>
                      <button
                        type='button'
                        class='mobile-accordion-toggle flex items-center justify-between w-full px-3 py-2 text-sm text-dusk-700 hover:text-savannah-700'
                        data-target={`mob-${item.label.toLowerCase()}-${child.label.toLowerCase().replace(/\s+/g, '-')}`}
                      >
                        <span>{child.label}</span>
                        <ChevronDown size={14} class='mobile-chevron transition-transform' />
                      </button>
                      <div
                        id={`mob-${item.label.toLowerCase()}-${child.label.toLowerCase().replace(/\s+/g, '-')}`}
                        class='mobile-submenu pl-3 pb-1 space-y-0.5'
                      >
                        <a
                          href={child.href}
                          class='block px-3 py-1.5 text-xs text-savannah-700 font-medium'
                        >
                          View all {child.label.toLowerCase()} →
                        </a>
                        {child.subChildren.map((sub: any) => (
                          <a
                            href={sub.href}
                            class='block px-3 py-1.5 text-xs text-dusk-600 hover:text-savannah-700'
                          >
                            {sub.label}
                          </a>
                        ))}
                      </div>
                    </div>
                  ) : (
                    <a
                      href={child.href}
                      class='block px-3 py-2 text-sm text-dusk-700 hover:text-savannah-700'>
                      {child.label}
                    </a>
                  )
                ))}
              </div>
            )}
          </div>
        ))
      }
      <div class='pt-4'>
        <a href='/plan-my-trip' class='btn btn-primary w-full'>Plan Your Safari</a>
      </div>
    </nav>
  </div>
</header>

<style>
  .mobile-menu-panel {
    max-height: 0;
    opacity: 0;
    visibility: hidden;
    overflow: hidden;
    transition: max-height 350ms cubic-bezier(0.4, 0, 0.2, 1),
                opacity 250ms cubic-bezier(0.4, 0, 0.2, 1),
                visibility 0ms linear 350ms;
  }
  .mobile-menu-panel.open {
    max-height: 80vh;
    opacity: 1;
    visibility: visible;
    overflow-y: auto;
    transition: max-height 350ms cubic-bezier(0.4, 0, 0.2, 1),
                opacity 250ms cubic-bezier(0.4, 0, 0.2, 1),
                visibility 0ms linear 0ms;
  }

  .mobile-submenu {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 300ms cubic-bezier(0.4, 0, 0.2, 1),
                opacity 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .mobile-submenu.open {
    max-height: 600px;
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-menu-panel,
    .mobile-menu-panel.open,
    .mobile-submenu,
    .mobile-submenu.open {
      transition: none;
    }
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('open');
    if (isOpen) {
      iconOpen?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
      btn.setAttribute('aria-expanded', 'true');
    } else {
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
    }
  });

  // Mobile accordion for nested menu items
  document.querySelectorAll('.mobile-accordion-toggle').forEach((toggle) => {
    toggle.addEventListener('click', (e) => {
      e.preventDefault();
      const targetId = (toggle as HTMLElement).dataset.target;
      const target = targetId ? document.getElementById(targetId) : null;
      const chevron = toggle.querySelector('.mobile-chevron');
      target?.classList.toggle('open');
      chevron?.classList.toggle('rotate-180');
    });
  });

  // Scroll-based header background: transparent at top, solid white once scrolled
  const header = document.getElementById('site-header');
  if (header && header.dataset.transparent === 'true') {
    const SCROLL_THRESHOLD = 60;
    let ticking = false;

    const update = () => {
      const scrolled = window.scrollY > SCROLL_THRESHOLD;
      header.classList.toggle('is-scrolled', scrolled);
      ticking = false;
    };

    const onScroll = () => {
      if (!ticking) {
        window.requestAnimationFrame(update);
        ticking = true;
      }
    };

    update();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
